+#ifndef THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FONT_ALLOWLIST_H_
+#define THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FONT_ALLOWLIST_H_
+
+#include <array>
+#include <string_view>
+
+namespace blink::fingerprinting {
+
+// Canonical font set for the fork's **Windows 10/11 persona**.
+//
+// Goal: defeat CSS font-probing (the "what fonts are installed" fingerprint
+// vector) by making every persona instance present the same font surface
+// regardless of the host OS. Pages probe by setting `font-family: "X"` on
+// a measurement element and observing whether text metrics change vs a
+// fallback. Our gate (FontCache::GetOrCreateFontPlatformData calling
+// IsAllowedFontFamilyStrict()) returns `nullptr` for any family NOT in
+// this list, forcing CSS to cascade to the next family.
+//
+// Membership rule: fonts that ship with **every supported Windows 10/11
+// SKU** (Home, Pro, Enterprise, Education) as part of the base OS — *not*
+// Office bundles, *not* Adobe bundles, *not* developer-installed extras.
+// Sources cross-referenced:
+//   * Microsoft Learn: "Fonts shipped with Windows 10/11" reference list
+//   * Windows 10/11 default font registry (HKLM\SOFTWARE\Microsoft\
+//     Windows NT\CurrentVersion\Fonts) on stock OEM images
+//   * Empirical anonymity-set blending: this is the union that maximises
+//     the count of Windows users we look identical to.
+//
+// We INTENTIONALLY drop macOS-specific families (-apple-system, Helvetica,
+// Menlo, Monaco, Lucida Grande, BlinkMacSystemFont) from this list:
+// our persona claims Windows, so exposing those would be a near-unique
+// "Windows-with-Mac-fonts" tell.
+//
+// Wiring (FINGERPRINT_ISOLATION_PLAN.md task #9):
+//   - `FontCache::GetOrCreateFontPlatformData` (font_cache.cc): returns
+//     nullptr for any family where IsAllowedFontFamilyStrict() is false.
+//   - Generic sentinels (sans-serif, monospace, …) are resolved upstream
+//     by the CSS font fallback engine into concrete family names before
+//     reaching this gate.
+//   - Web @font-face / FontCustomPlatformData bypasses this gate
+//     (pages bundling their own fonts is fine — no fingerprint leak).
+//   - Empty family and macOS internal dot-prefixed system names pass
+//     through (defaults / internal Blink fallbacks).
+
+inline constexpr std::array<std::string_view, 59> kAllowedFontFamilies = {
+    // Sans-serif — system UI fonts that ship with every Windows 10/11
+    "system-ui",
+    "Arial",
+    "Arial Black",
+    "Bahnschrift",
+    "Calibri",
+    "Calibri Light",
+    "Candara",
+    "Comic Sans MS",
+    "Corbel",
+    "Ebrima",
+    "Franklin Gothic Medium",
+    "Gadugi",
+    "Impact",
+    "Leelawadee UI",
+    "Lucida Sans Unicode",
+    "Malgun Gothic",
+    "Microsoft Himalaya",
+    "Microsoft JhengHei",
+    "Microsoft New Tai Lue",
+    "Microsoft PhagsPa",
+    "Microsoft Sans Serif",
+    "Microsoft Tai Le",
+    "Microsoft YaHei",
+    "Microsoft Yi Baiti",
+    "Mongolian Baiti",
+    "Myanmar Text",
+    "Nirmala UI",
+    "Segoe MDL2 Assets",
+    "Segoe Print",
+    "Segoe Script",
+    "Segoe UI",
+    "Segoe UI Emoji",
+    "Segoe UI Historic",
+    "Segoe UI Symbol",
+    "Sylfaen",
+    "Tahoma",
+    "Trebuchet MS",
+    "Verdana",
+    "Yu Gothic",
+    "Yu Gothic UI",
+    // Serif
+    "Cambria",
+    "Cambria Math",
+    "Constantia",
+    "Gabriola",
