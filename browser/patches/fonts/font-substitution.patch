 #include "third_party/blink/renderer/platform/fonts/alternate_font_family.h"
@@ -141,6 +143,57 @@ const FontPlatformData* FontCache::GetFontPlatformData(
   }
 #endif
 
+  // Fingerprint isolation (FINGERPRINT_ISOLATION_PLAN.md task #9): only
+  // resolve allowlisted system family names so pages can't probe which
+  // fonts the host has installed via CSS family-fallback timing. Empty
+  // family is a "give me the default" request and is preserved. Generic
+  // sentinels (sans-serif, monospace, …) are resolved upstream by the CSS
+  // font fallback engine into concrete family names before reaching this
+  // function, so they aren't affected. Web @font-face / FontCustomPlatformData
+  // bypasses this path entirely.
+  //
+  // 2026-05-30: STRICT allowlist — only the canonical Win 10/11 base font
+  // set is visible to page-driven probes. A CreepJS run surfaced our Linux
+  // build's DejaVu / Liberation / Noto-* (incl. rare scripts like Yezidi,
+  // Gondi, Canadian Aboriginal) as the "38% like headless" tell: real Win 11
+  // users have NONE of these. The strict allowlist hides them at the
+  // FontPlatformData layer so probes via CSS measurement / FontFace local()
+  // get nullptr and conclude "font not installed". Internal Blink fallback
+  // (-webkit-standard etc.) goes through FontFallbackList::GetFontData →
+  // FontCache::GetFontData directly, bypassing this gate, so pages without
+  // an explicit font-family still render.
+  //
+  // 2026-05-31: the entire gate is Mac-excluded. The strict allowlist is
+  // calibrated for the Linux VPS deployment, where the Win-clone TTFs are
+  // installed at /usr/local/share/fonts/chromfish-win-clones/ so the persona-
+  // approved family names (Calibri, Franklin Gothic, etc.) resolve to disk
+  // files. On Mac dev builds those clones aren't installed, so the allowlist
+  // would reject every requested family AND every system fallback (Helvetica,
+  // SF Pro, Menlo) — Chrome's font matcher then returns nullptr to layout,
+  // NULL-derefs during glyph rendering, and crashes the renderer (SIGSEGV/
+  // SIGABRT, observed on amiunique.org, CreepJS, browserleaks). Skip the gate
+  // entirely on Mac so pages render normally.
+#if !BUILDFLAG(IS_MAC)
+  if (creation_params.CreationType() == kCreateFontByFamily &&
+      !creation_params.Family().empty()) {
+    const std::string family_utf8 = creation_params.Family().Utf8();
+    if (!fingerprinting::IsAllowedFontFamilyStrict(family_utf8)) {
+      return nullptr;
+    }
+    // Note: an earlier revision substituted Mac-default font names
+    // (Helvetica/Menlo/Lucida Grande/Times) to Win-equivalents (Arial/
+    // Consolas/Times New Roman) at this layer when the persona claimed
+    // Windows. That broke canvas measureText behavior — real Win Chrome
+    // with `font-family: Helvetica` falls back to `-webkit-standard`
+    // (Times New Roman), NOT Arial, so substituting to Arial here
+    // produced widths that real Win Chrome would never produce. Better
+    // to leave these family names alone here and rely on
+    // FontFallbackList::GetFontData's aggressive skip
+    // (IsMacOnlyFontFamilyAggressive) which causes the CSS cascade to
+    // continue past the family — matching Win Chrome's natural fallback.
+  }
+#endif
+
   return font_platform_data_cache_.GetOrCreateFontPlatformData(
       this, font_description, creation_params, alternate_font_name);
 }
