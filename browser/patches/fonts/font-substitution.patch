@@ -101,6 +101,91 @@ inline const AtomicString& AlternateFamilyName(
     return font_family_names::kArial;
   }
 
+#if BUILDFLAG(IS_MAC)
+  // Lightweight-fork: route Win-typical font-family names to the libre
+  // equivalents installed via tools/activate_lean_fonts.py. Without this,
+  // fpjs's font enumeration probe sees these Win-default fonts as missing
+  // (contradicting our Windows persona). Aliasing to Arial / Courier New /
+  // Times New Roman (which Blink resolves to Arimo / Cousine / Tinos via
+  // CoreText on this host) makes them register as installed. Widths won't
+  // be perfectly Win-accurate, but presence beats absence. Only reached on
+  // alternate-lookup path — Windows natively has these so this branch is
+  // never hit there.
+  // Expanded list — these are the exact font names a real Win11 Chrome
+  // returns from fpjs's font probe (verified via real-hardware capture).
+  // Aliasing them all to one of the three libre families we install via
+  // tools/activate_lean_fonts.py makes them appear "installed" with
+  // metric values that differ from the monospace fallback baseline.
+  // Sans-serif and decorative Win fonts → Arial (resolves to Arimo)
+  if (EqualIgnoringAsciiCase(family_name, "Segoe UI") ||
+      EqualIgnoringAsciiCase(family_name, "Segoe UI Light") ||
+      EqualIgnoringAsciiCase(family_name, "Segoe UI Semibold") ||
+      EqualIgnoringAsciiCase(family_name, "Segoe UI Black") ||
+      EqualIgnoringAsciiCase(family_name, "Segoe UI Symbol") ||
+      EqualIgnoringAsciiCase(family_name, "Segoe UI Emoji") ||
+      EqualIgnoringAsciiCase(family_name, "Tahoma") ||
+      EqualIgnoringAsciiCase(family_name, "Verdana") ||
+      EqualIgnoringAsciiCase(family_name, "Trebuchet MS") ||
+      EqualIgnoringAsciiCase(family_name, "Microsoft Sans Serif") ||
+      EqualIgnoringAsciiCase(family_name, "Arial Black") ||
+      EqualIgnoringAsciiCase(family_name, "Calibri") ||
+      EqualIgnoringAsciiCase(family_name, "Calibri Light") ||
+      EqualIgnoringAsciiCase(family_name, "Candara") ||
+      EqualIgnoringAsciiCase(family_name, "Corbel") ||
+      EqualIgnoringAsciiCase(family_name, "Franklin Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "Franklin Gothic Medium") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Sans") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Sans Unicode") ||
+      EqualIgnoringAsciiCase(family_name, "Impact") ||
+      EqualIgnoringAsciiCase(family_name, "Haettenschweiler") ||
+      EqualIgnoringAsciiCase(family_name, "Agency FB") ||
+      EqualIgnoringAsciiCase(family_name, "Century Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "Comic Sans MS") ||
+      EqualIgnoringAsciiCase(family_name, "Leelawadee") ||
+      EqualIgnoringAsciiCase(family_name, "Leelawadee UI") ||
+      EqualIgnoringAsciiCase(family_name, "MS UI Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "MS Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "MS PGothic") ||
+      EqualIgnoringAsciiCase(family_name, "Microsoft Uighur") ||
+      EqualIgnoringAsciiCase(family_name, "Microsoft YaHei") ||
+      EqualIgnoringAsciiCase(family_name, "Microsoft JhengHei") ||
+      EqualIgnoringAsciiCase(family_name, "Yu Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "Malgun Gothic") ||
+      EqualIgnoringAsciiCase(family_name, "Marlett") ||
+      EqualIgnoringAsciiCase(family_name, "MS Reference Specialty") ||
+      EqualIgnoringAsciiCase(family_name, "MS Outlook")) {
+    return font_family_names::kArial;
+  }
+  // Monospace Win fonts → Courier New (resolves to Cousine)
+  if (EqualIgnoringAsciiCase(family_name, "Consolas") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Console") ||
+      EqualIgnoringAsciiCase(family_name, "MS Mincho") ||
+      EqualIgnoringAsciiCase(family_name, "MS PMincho")) {
+    return font_family_names::kCourierNew;
+  }
+  // Serif Win fonts → Times New Roman (resolves to Tinos)
+  if (EqualIgnoringAsciiCase(family_name, "Cambria") ||
+      EqualIgnoringAsciiCase(family_name, "Cambria Math") ||
+      EqualIgnoringAsciiCase(family_name, "Constantia") ||
+      EqualIgnoringAsciiCase(family_name, "Georgia") ||
+      EqualIgnoringAsciiCase(family_name, "Palatino Linotype") ||
+      EqualIgnoringAsciiCase(family_name, "Century") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Bright") ||
+      EqualIgnoringAsciiCase(family_name, "Bookman Old Style") ||
+      EqualIgnoringAsciiCase(family_name, "Garamond") ||
+      EqualIgnoringAsciiCase(family_name, "Book Antiqua")) {
+    return font_family_names::kTimesNewRoman;
+  }
+  // Cursive/script Win fonts → Times New Roman as approximation
+  if (EqualIgnoringAsciiCase(family_name, "Monotype Corsiva") ||
+      EqualIgnoringAsciiCase(family_name, "Pristina") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Calligraphy") ||
+      EqualIgnoringAsciiCase(family_name, "Lucida Handwriting") ||
+      EqualIgnoringAsciiCase(family_name, "Edwardian Script ITC")) {
+    return font_family_names::kTimesNewRoman;
+  }
+#endif
+
   return g_empty_atom;
 }
 
