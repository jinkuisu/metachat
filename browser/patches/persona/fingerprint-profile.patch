+
+#ifndef THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FINGERPRINT_PROFILE_H_
+#define THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FINGERPRINT_PROFILE_H_
+
+#include <cstdint>
+#include <string>
+
+#include "third_party/blink/public/common/common_export.h"
+
+namespace blink::fingerprinting {
+
+// Seed-derived runtime persona. Every field that the fork spoofs lives
+// here so a single uint64 controls the entire persona surface. Same seed
+// → identical persona across processes (browser + every renderer in a
+// session must observe the same values, so we derive deterministically).
+struct BLINK_COMMON_EXPORT FingerprintProfile {
+  // ---- Seed (preserved for downstream isolation routines) ----
+  // Mixed-via-SplitMix64 64-bit seed used to derive this persona. Kept on
+  // the profile so per-seed routines (e.g. the audio-sample isolation in
+  // fingerprint_audio_isolation) can mix it in: same seed → same output,
+  // different seeds → divergent output.
+  uint64_t persona_seed;
+
+  // ---- Identity ----
+  unsigned chrome_major_version;             // 148
+  std::string chrome_full_version;           // "148.0.7778.179"
+  std::string brand;                         // "Google Chrome"
+
+  // ---- UA + OS ----
+  std::string user_agent;                    // Full UA string
+  std::string unified_platform;              // "Windows NT 10.0; Win64; x64"
+  std::string navigator_platform;            // "Win32"
+  std::string ua_metadata_platform;          // "Windows"
+  std::string ua_metadata_platform_version;  // "15.0.0" (Win11) | "10.0.0" (Win10)
+  std::string ua_metadata_architecture;      // "x86"
+  std::string ua_metadata_bitness;           // "64"
+  std::string ua_metadata_model;             // ""
+  bool ua_metadata_mobile;                   // false
+  bool ua_metadata_wow64;                    // false
+
+  // ---- Hardware ----
+  unsigned hardware_concurrency;             // 8
+  float device_memory_gb;                    // 8.0
+
+  // ---- Screen ----
+  int screen_width;                          // 1920
+  int screen_height;                         // 1080
+  int available_screen_left;                 // 0
+  int available_screen_top;                  // 0
+  int available_screen_width;                // 1920
+  int available_screen_height;               // 1040 (Win taskbar = 40px)
+  unsigned color_depth;                      // 24
+  double device_pixel_ratio;                 // 1.0
+  int outer_window_width;                    // = screen width (content area)
+  int outer_window_height;                   // = available screen height
+
+  // ---- WebGL ----
+  bool webgpu_enabled;                       // true
+  std::string webgl_vendor;                  // "Google Inc. (Intel)"
+  std::string webgl_renderer;                // ANGLE string
+
+  // WebGL parameter limits — canonical Win+ANGLE values.
+  int webgl_max_texture_size;
+  int webgl_max_cube_map_texture_size;
+  int webgl_max_renderbuffer_size;
+  int webgl_max_viewport_dim;
+  int webgl_max_vertex_attribs;
+  int webgl_max_vertex_uniform_vectors;
+  int webgl_max_fragment_uniform_vectors;
+  int webgl_max_varying_vectors;
+  int webgl_max_texture_image_units;
+  int webgl_max_vertex_texture_image_units;
+  int webgl_max_combined_texture_image_units;
+  int webgl_max_draw_buffers;
+  int webgl_max_color_attachments;
+  int webgl_3d_max_texture_size;
+  int webgl_max_array_texture_layers;
+  int webgl_max_samples;
+  int webgl_max_vertex_uniform_blocks;
+  int webgl_max_fragment_uniform_blocks;
+  int webgl_max_uniform_block_size;
+  int webgl_precision_float_bits;
+  int webgl_precision_range_min;
+  int webgl_precision_range_max;
+
+  // ---- Canvas / audio / device behavior ----
+  bool canvas_readback_enabled;              // true (return pixels, don't block)
+  bool media_device_enumeration_enabled;     // false
+  float audio_sample_rate;                   // 48000.0 (Win WASAPI default)
+  double audio_base_latency;                 // 0.01
+  double audio_output_latency;               // 0.015
+};
+
+// Derives a coherent persona from a seed. Same seed → same persona.
+// Pools are curated to match common Chrome-on-Windows distributions
+// (StatCounter / amiunique 30-day aggregates). Coherence rules ensure
+// e.g. the WebGL renderer string matches the GPU vendor field and the UA
+// platform-version matches the Win10/11 variant.
+BLINK_COMMON_EXPORT FingerprintProfile DeriveFromSeed(uint64_t seed);
+
+// Process-wide singleton. First call reads `--persona-seed=N` from the
+// process command line (via base::CommandLine::ForCurrentProcess()); if
+// the switch is absent or invalid, defaults to seed 0 (the canonical
+// reference persona — Chrome 148 / Win 11 / Intel UHD 770 / 1920x1080).
+// Subsequent calls return the same profile.
+//
+// Thread-safe: lazy-initialized with std::call_once.
+BLINK_COMMON_EXPORT const FingerprintProfile& Current();
+
+}  // namespace blink::fingerprinting
+
+#endif  // THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FINGERPRINT_PROFILE_H_
