+// found in the LICENSE file.
+
+#ifndef THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FONT_ALLOWLIST_H_
+#define THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FONT_ALLOWLIST_H_
+
+#include <array>
+#include <string_view>
+
+namespace blink::fingerprinting {
+
+// Canonical font set for the fork's **Windows 10/11 persona**.
+//
+// Goal: defeat CSS font-probing (the "what fonts are installed" fingerprint
+// vector) by making every persona instance present the same font surface
+// regardless of the host OS. Pages probe by setting `font-family: "X"` on
+// a measurement element and observing whether text metrics change vs a
+// fallback. Our gate (FontCache::GetOrCreateFontPlatformData calling
+// IsAllowedFontFamilyStrict()) returns `nullptr` for any family NOT in
+// this list, forcing CSS to cascade to the next family.
+//
+// Membership rule: fonts that ship with **every supported Windows 10/11
+// SKU** (Home, Pro, Enterprise, Education) as part of the base OS — *not*
+// Office bundles, *not* Adobe bundles, *not* developer-installed extras.
+// Sources cross-referenced:
+//   * Microsoft Learn: "Fonts shipped with Windows 10/11" reference list
+//   * Windows 10/11 default font registry (HKLM\SOFTWARE\Microsoft\
+//     Windows NT\CurrentVersion\Fonts) on stock OEM images
+//   * Empirical anonymity-set blending: this is the union that maximises
+//     the count of Windows users we look identical to.
+//
+// We INTENTIONALLY drop macOS-specific families (-apple-system, Helvetica,
+// Menlo, Monaco, Lucida Grande, BlinkMacSystemFont) from this list:
+// our persona claims Windows, so exposing those would be a near-unique
+// "Windows-with-Mac-fonts" tell.
+//
+// Wiring (FINGERPRINT_ISOLATION_PLAN.md task #9):
+//   - `FontCache::GetOrCreateFontPlatformData` (font_cache.cc): returns
+//     nullptr for any family where IsAllowedFontFamilyStrict() is false.
+//   - Generic sentinels (sans-serif, monospace, …) are resolved upstream
+//     by the CSS font fallback engine into concrete family names before
+//     reaching this gate.
+//   - Web @font-face / FontCustomPlatformData bypasses this gate
+//     (pages bundling their own fonts is fine — no fingerprint leak).
+//   - Empty family and macOS internal dot-prefixed system names pass
+//     through (defaults / internal Blink fallbacks).
+
+inline constexpr std::array<std::string_view, 59> kAllowedFontFamilies = {
+    // Sans-serif — system UI fonts that ship with every Windows 10/11
+    "system-ui",
+    "Arial",
+    "Arial Black",
+    "Bahnschrift",
+    "Calibri",
+    "Calibri Light",
+    "Candara",
+    "Comic Sans MS",
+    "Corbel",
+    "Ebrima",
+    "Franklin Gothic Medium",
+    "Gadugi",
+    "Impact",
+    "Leelawadee UI",
+    "Lucida Sans Unicode",
+    "Malgun Gothic",
+    "Microsoft Himalaya",
+    "Microsoft JhengHei",
+    "Microsoft New Tai Lue",
+    "Microsoft PhagsPa",
+    "Microsoft Sans Serif",
+    "Microsoft Tai Le",
+    "Microsoft YaHei",
+    "Microsoft Yi Baiti",
+    "Mongolian Baiti",
+    "Myanmar Text",
+    "Nirmala UI",
+    "Segoe MDL2 Assets",
+    "Segoe Print",
+    "Segoe Script",
+    "Segoe UI",
+    "Segoe UI Emoji",
+    "Segoe UI Historic",
+    "Segoe UI Symbol",
+    "Sylfaen",
+    "Tahoma",
+    "Trebuchet MS",
+    "Verdana",
+    "Yu Gothic",
+    "Yu Gothic UI",
+    // Serif
+    "Cambria",
+    "Cambria Math",
+    "Constantia",
+    "Gabriola",
+    "Georgia",
+    "Palatino Linotype",
+    "Times New Roman",
+    // Monospace
+    "Consolas",
+    "Courier New",
+    "Lucida Console",
+    "MS Gothic",
+    // Symbol / dingbat
+    "Webdings",
+    "Marlett",
+    // 2026-05-30: extra Win 11 names matched by the commercial fingerprinter's 52-font
+    // probe that our clone setup specifically targets (the rest of
+    // the 52-list overlaps the existing entries above).
+    "Franklin Gothic",
+    "MS UI Gothic",
+    "PMingLiU",
+    "Segoe UI Light",
+    "Lucida Bright",
+    "Lucida Sans",
+};
+
+// Case-insensitive ASCII match (CSS family names are case-insensitive).
+constexpr bool EqualsAsciiCaseInsensitive(std::string_view a,
+                                          std::string_view b) {
+  if (a.size() != b.size())
+    return false;
+  for (size_t i = 0; i < a.size(); ++i) {
+    char ca = a[i];
+    char cb = b[i];
+    if (ca >= 'A' && ca <= 'Z')
+      ca = static_cast<char>(ca + ('a' - 'A'));
+    if (cb >= 'A' && cb <= 'Z')
+      cb = static_cast<char>(cb + ('a' - 'A'));
+    if (ca != cb)
+      return false;
+  }
+  return true;
+}
+
+// macOS-host fonts that fingerprinters specifically probe to detect
+// macOS — and that Blink's internal font cascade NEVER falls back to
+// (Blink uses generic-family resolution + the system-ui sentinel +
+// "Helvetica"/"Times"/"Lucida Grande" on Mac; the families below are
+// real disk-installed fonts that page-driven probing detects as
+// "installed" only on macOS hosts). Blocking these at GetFontPlatformData
+// makes them appear absent without breaking Blink's cascade.
+//
+// Sources: a fingerprint test site's font probe table (~700 fonts), filtered to
+// the subset that's macOS-default-installed but Windows-absent. Apple-
+// branded font names + CJK script-specific Mac fonts (Hiragino, PingFang,
+// Heiti, Songti, Kohinoor) dominate the list.
+// Plain C array so the count auto-sizes; size mismatch with
+// std::array<N> would otherwise be a compile-time bug. Iterated below
+// via range-for which works for both forms.
+inline constexpr std::string_view kMacOnlyFontFamilies[] = {
+    // Apple-branded
+    "Apple Braille", "Apple Chancery", "Apple Color Emoji",
+    "Apple LiGothic Medium", "Apple LiSung Light", "Apple SD Gothic Neo",
+    "Apple SD GothicNeo ExtraBold", "Apple Symbols", "AppleGothic",
+    "AppleMyungjo", "AquaKana", ".Aqua Kana",
+    // Apple-stylised classical
+    "American Typewriter", "Andale Mono", "Avenir", "Avenir Black",
+    "Avenir Book", "Avenir Next", "Avenir Next Condensed",
+    "Avenir Next Demi Bold", "Avenir Next Heavy", "Avenir Roman",
+    "Baghdad", "Baskerville", "Beirut", "Big Caslon", "Bodoni 72",
+    "Bodoni Ornaments", "Bradley Hand", "Brush Script MT",
+    "Chalkboard", "Chalkboard SE", "Chalkduster", "Charter", "Cochin",
+    "Copperplate", "Corsiva Hebrew", "Damascus", "DecoType Naskh",
+    "Didot", "DIN Alternate", "DIN Condensed", "Diwan Kufi",
+    "Diwan Thuluth", "Euphemia UCAS", "Farah", "Farisi", "Futura",
+    "Geeza Pro", "Geneva", "GenevaCY", "Gill Sans", "Heiti SC",
+    "Heiti TC", "Helvetica CY", "HelveticaCY", "Herculanum",
+    "Hoefler Text", "Hoefler Text Ornaments", "InaiMathi", "Kailasa",
+    "Kefa", "Krungthep", "KufiStandardGK", "Luminari", "Marion",
+    "Marker Felt", "Mishafi", "Mishafi Gold", "Monaco", "Mshtakan",
+    "Muna", "Nadeem", "New Peninim MT", "Noteworthy", "Optima",
+    "Osaka", "Osaka-Mono", "OsakaMono", "Palatino", "Papyrus",
+    "Phosphate", "PingFang HK", "PingFang SC", "PingFang TC",
+    "Plantagenet Cherokee", "Raanana", "Sana", "Sathu",
+    "SignPainter-HouseScript", "Silom", "Skia", "Snell Roundhand",
+    "Songti SC", "Songti TC", "STKaiti", "STSong", "STFangsong",
+    "STHeiti", "STXihei", "Sukhumvit Set", "System Font", "Thonburi",
+    "Trattatello", "Waseem", "Zapf Dingbats", "Zapfino",
+    // STIX science fonts (macOS-installed)
+    "STIXGeneral", "STIXIntegralsD", "STIXIntegralsSm",
+    "STIXIntegralsUp", "STIXIntegralsUpD", "STIXIntegralsUpSm",
+    "STIXNonUnicode", "STIXSizeFiveSym", "STIXSizeFourSym",
+    "STIXSizeOneSym", "STIXSizeThreeSym", "STIXSizeTwoSym",
+    "STIXVariants",
+    // Mac CJK / script-specific (almost all macOS Sangam / MN names)
+    "Bangla MN", "Bangla Sangam MN", "Devanagari MT",
+    "Devanagari Sangam MN", "Gujarati MT", "Gujarati Sangam MN",
+    "Gurmukhi MN", "Gurmukhi MT", "Gurmukhi Sangam MN", "ITF Devanagari",
+    "ITF Devanagari Marathi", "Kannada MN", "Kannada Sangam MN",
+    "Khmer MN", "Khmer Sangam MN", "Kohinoor Bangla",
+    "Kohinoor Devanagari", "Kohinoor Telugu", "Kokonor", "Lao MN",
+    "Lao Sangam MN", "Malayalam MN", "Malayalam Sangam MN",
+    "Mongolian Baiti", "Myanmar MN", "Myanmar Sangam MN", "Noto Nastaliq Urdu",
+    "Noto Sans Armenian", "Noto Sans Canadian Aboriginal",
+    "Noto Sans Kannada", "Noto Sans Myanmar", "Noto Sans Oriya",
+    "Noto Sans Yi", "Oriya MN", "Oriya Sangam MN", "Shree Devanagari 714",
+    "Sinhala MN", "Sinhala Sangam MN", "Tamil MN", "Tamil Sangam MN",
+    "Telugu MN", "Telugu Sangam MN", "Al Bayan", "Al Nile",
+    "Al Tarikh", "Ayuthaya", "Arial Hebrew", "GB18030 Bitmap",
+    "Hiragino Sans", "Hiragino Sans GB",
+    "Hiragino Kaku Gothic Pro", "Hiragino Kaku Gothic ProN",
+    "Hiragino Kaku Gothic Std", "Hiragino Kaku Gothic StdN",
+    "Hiragino Maru Gothic Pro", "Hiragino Maru Gothic ProN",
+    "Hiragino Mincho Pro", "Hiragino Mincho ProN",
+    // PT Sans/Mono/Serif — macOS-bundled (also available elsewhere, but
+    // their *default-installed* state is a Mac tell).
+    "PT Mono", "PT Sans", "PT Serif",
+    // NOTE: Helvetica / Helvetica Neue / Lucida Grande / Menlo / Times
+    // are deliberately NOT in this denylist. Blink's internal font
+    // cascade on macOS requests them in code paths we haven't fully
+    // mapped, and blocking them causes a renderer SIGSEGV on
+    // real-world pages (a fingerprint test site reproducibly). Even
+    // though the CoreText layer has Carlito/Caladea/etc. activated to
+    // satisfy CSS lookups for "Calibri"/"Cambria", Blink's internal
+    // path for the Mac defaults remains. Leaving them allowed means
+    // those 5 fonts still leak as a Mac signal — partial improvement
+    // only. The full fix requires identifying the specific Blink
+    // call-site that resolves to Helvetica/Times and routing it via
+    // an internal-only allowlist gate.
+};
+
+constexpr bool IsMacOnlyFontFamily(std::string_view family) {
+  for (std::string_view banned : kMacOnlyFontFamilies) {
+    if (EqualsAsciiCaseInsensitive(family, banned))
+      return true;
+  }
+  // Catch every name in the "Hiragino*", "Apple*", "PingFang*" family
+  // groups via prefix match — the static array above lists the most
+  // common variants but new style-variants land in upstream macOS each
+  // release. Prefix-matching keeps coverage without listing each one.
+  constexpr std::string_view kMacPrefixes[] = {
+      "Hiragino ", "Apple ", "PingFang ", "Heiti ", "Songti ",
+      "Kohinoor ", "STIXSize", "STIXIntegrals", "Geeza ", "Avenir ",
+      "Bodoni 72", "Hiragino Kaku",
+  };
+  for (std::string_view pre : kMacPrefixes) {
+    if (family.size() >= pre.size()) {
+      bool match = true;
+      for (size_t i = 0; i < pre.size(); ++i) {
+        char a = family[i];
+        char b = pre[i];
+        if (a >= 'A' && a <= 'Z') a = static_cast<char>(a + ('a' - 'A'));
+        if (b >= 'A' && b <= 'Z') b = static_cast<char>(b + ('a' - 'A'));
+        if (a != b) { match = false; break; }
+      }
+      if (match) return true;
+    }
+  }
+  return false;
+}
+
+// Aggressive: includes the 5 names that IsMacOnlyFontFamily deliberately
+// omits (Helvetica, Helvetica Neue, Lucida Grande, Menlo, Times). Safe to
+// use ONLY at FontFallbackList::GetFontData (the CSS font-stack iterator).
+// NEVER use at the IsAllowedFontFamilyStrict / GetFontPlatformData gate —
+// Blink's last-resort cascade requests those names directly and starves
+// without them, causing a renderer SIGSEGV. FontFallbackList is the right layer
+// because GetLastResortFallbackFont bypasses it via a direct
+// FontCache::GetFontData() call.
+constexpr bool IsMacOnlyFontFamilyAggressive(std::string_view family) {
+  if (IsMacOnlyFontFamily(family))
+    return true;
+  // The 5 deliberately-omitted names — block at the JS-probe layer only.
+  static constexpr std::string_view kExtra[] = {
+      "Helvetica Neue", "HelveticaNeue", "Helvetica",
+      "Menlo", "Lucida Grande", "LucidaGrande",
+  };
+  for (std::string_view name : kExtra) {
+    if (EqualsAsciiCaseInsensitive(family, name))
+      return true;
+  }
+  return false;
+}
+
+constexpr bool IsAllowedFontFamilyStrict(std::string_view family) {
+  if (family.empty())
+    return true;
+  if (family.front() == '.')
+    return true;
+  for (std::string_view allowed : kAllowedFontFamilies) {
+    if (EqualsAsciiCaseInsensitive(family, allowed))
+      return true;
+  }
+  return false;
+}
+
+}  // namespace blink::fingerprinting
+
+#endif  // THIRD_PARTY_BLINK_PUBLIC_COMMON_FINGERPRINTING_FONT_ALLOWLIST_H_
