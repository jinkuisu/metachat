@@ -0,0 +1,165 @@
+// ... (data_model.cc content)
+#include "chrome/browser/ui/webui/metachat/data_model.h"
+#include <string>
+#include "base/rand_util.h"
+#include "base/uuid.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/time/time.h"
+namespace metachat {
+// --- FingerprintConfig ---
+base::DictValue FingerprintConfig::ToDict() const {
+  base::DictValue d;
+  if (!platform.empty()) d.Set("platform", platform);
+  if (!user_agent.empty()) d.Set("user_agent", user_agent);
+  if (!locale.empty()) d.Set("locale", locale);
+  if (!timezone.empty()) d.Set("timezone", timezone);
+  if (screen_width > 0) d.Set("screen_width", screen_width);
+  if (screen_height > 0) d.Set("screen_height", screen_height);
+  if (color_depth > 0) d.Set("color_depth", color_depth);
+  if (device_pixel_ratio > 0.0) d.Set("device_pixel_ratio", device_pixel_ratio);
+  if (device_memory > 0.0) d.Set("device_memory", device_memory);
+  if (hardware_concurrency > 0) d.Set("hardware_concurrency", hardware_concurrency);
+  if (!webgl_vendor.empty()) d.Set("webgl_vendor", webgl_vendor);
+  if (!webgl_renderer.empty()) d.Set("webgl_renderer", webgl_renderer);
+  d.Set("canvas_noise_enabled", canvas_noise_enabled);
+  d.Set("canvas_noise_level", canvas_noise_level);
+  d.Set("audio_noise_enabled", audio_noise_enabled);
+  d.Set("audio_noise_level", audio_noise_level);
+  d.Set("webrtc_leak_shield_enabled", webrtc_leak_shield_enabled);
+  return d;
+}
+FingerprintConfig FingerprintConfig::FromDict(const base::DictValue& d) {
+  FingerprintConfig c;
+  if (auto* v = d.FindString("platform")) c.platform = *v;
+  if (auto* v = d.FindString("user_agent")) c.user_agent = *v;
+  if (auto* v = d.FindString("locale")) c.locale = *v;
+  if (auto* v = d.FindString("timezone")) c.timezone = *v;
+  c.screen_width = d.FindInt("screen_width").value_or(0);
+  c.screen_height = d.FindInt("screen_height").value_or(0);
+  c.color_depth = d.FindInt("color_depth").value_or(0);
+  c.device_pixel_ratio = d.FindDouble("device_pixel_ratio").value_or(0.0);
+  c.device_memory = d.FindDouble("device_memory").value_or(0.0);
+  c.hardware_concurrency = d.FindInt("hardware_concurrency").value_or(0);
+  if (auto* v = d.FindString("webgl_vendor")) c.webgl_vendor = *v;
+  if (auto* v = d.FindString("webgl_renderer")) c.webgl_renderer = *v;
+  c.canvas_noise_enabled = d.FindBool("canvas_noise_enabled").value_or(true);
+  c.canvas_noise_level = d.FindDouble("canvas_noise_level").value_or(0.5);
+  c.audio_noise_enabled = d.FindBool("audio_noise_enabled").value_or(true);
+  c.audio_noise_level = d.FindDouble("audio_noise_level").value_or(0.3);
+  c.webrtc_leak_shield_enabled = d.FindBool("webrtc_leak_shield_enabled").value_or(true);
+  return c;
+}
+// --- ProxyConfig ---
+base::DictValue ProxyConfig::ToDict() const {
+  base::DictValue d;
+  if (!mode.empty()) d.Set("mode", mode);
+  if (!host.empty()) d.Set("host", host);
+  if (port > 0) d.Set("port", port);
+  if (!username.empty()) d.Set("username", username);
+  if (!password.empty()) d.Set("password", password);
+  return d;
+}
+ProxyConfig ProxyConfig::FromDict(const base::DictValue& d) {
+  ProxyConfig c;
+  if (auto* v = d.FindString("mode")) c.mode = *v;
+  if (auto* v = d.FindString("host")) c.host = *v;
+  c.port = d.FindInt("port").value_or(0);
+  if (auto* v = d.FindString("username")) c.username = *v;
+  if (auto* v = d.FindString("password")) c.password = *v;
+  return c;
+}
+// --- Account ---
+base::DictValue Account::ToDict() const {
+  base::DictValue d;
+  d.Set("id", id); d.Set("type", type); d.Set("name", name);
+  if (!notes.empty()) d.Set("notes", notes);
+  d.Set("created_at", static_cast<double>(created_at));
+  d.Set("updated_at", static_cast<double>(updated_at));
+  d.Set("schema_version", schema_version);
+  d.Set("user_data_dir", user_data_dir);
+  d.Set("persona_seed", static_cast<double>(persona_seed));
+  d.Set("fingerprint", fingerprint.ToDict());
+  d.Set("proxy", proxy.ToDict());
+  return d;
+}
+Account Account::FromDict(const base::DictValue& d) {
+  Account a;
+  if (auto* v = d.FindString("id")) a.id = *v;
+  if (auto* v = d.FindString("type")) a.type = *v;
+  if (auto* v = d.FindString("name")) a.name = *v;
+  if (auto* v = d.FindString("notes")) a.notes = *v;
+  a.created_at = static_cast<int64_t>(d.FindDouble("created_at").value_or(0));
+  a.updated_at = static_cast<int64_t>(d.FindDouble("updated_at").value_or(0));
+  a.schema_version = d.FindInt("schema_version").value_or(1);
+  if (auto* v = d.FindString("user_data_dir")) a.user_data_dir = *v;
+  a.persona_seed = static_cast<uint64_t>(d.FindDouble("persona_seed").value_or(0));
+  if (auto* v = d.FindDict("fingerprint")) a.fingerprint = FingerprintConfig::FromDict(*v);
+  if (auto* v = d.FindDict("proxy")) a.proxy = ProxyConfig::FromDict(*v);
+  return a;
+}
+// --- RuntimeState ---
+base::DictValue RuntimeState::ToDict() const {
+  base::DictValue d;
+  d.Set("account_id", account_id); d.Set("status", status);
+  if (!error_message.empty()) d.Set("error_message", error_message);
+  d.Set("unread_count", unread_count);
+  d.Set("last_seen", static_cast<double>(last_seen));
+  if (!status_text.empty()) d.Set("status_text", status_text);
+  if (!current_url.empty()) d.Set("current_url", current_url);
+  if (!current_title.empty()) d.Set("current_title", current_title);
+  d.Set("cdp_port", cdp_port); d.Set("pid", pid);
+  return d;
+}
+RuntimeState RuntimeState::FromDict(const base::DictValue& d) {
+  RuntimeState s;
+  if (auto* v = d.FindString("account_id")) s.account_id = *v;
+  if (auto* v = d.FindString("status")) s.status = *v;
+  if (auto* v = d.FindString("error_message")) s.error_message = *v;
+  s.unread_count = d.FindInt("unread_count").value_or(0);
+  s.last_seen = static_cast<int64_t>(d.FindDouble("last_seen").value_or(0));
+  if (auto* v = d.FindString("status_text")) s.status_text = *v;
+  if (auto* v = d.FindString("current_url")) s.current_url = *v;
+  if (auto* v = d.FindString("current_title")) s.current_title = *v;
+  s.cdp_port = d.FindInt("cdp_port").value_or(0);
+  s.pid = d.FindInt("pid").value_or(0);
+  return s;
+}
+// --- EventLog ---
+base::DictValue EventLog::ToDict() const {
+  base::DictValue d;
+  d.Set("id", id); d.Set("timestamp", static_cast<double>(timestamp));
+  d.Set("account_id", account_id); d.Set("category", category);
+  d.Set("event", event); d.Set("level", level);
+  d.Set("details", details);
+  if (!trace_id.empty()) d.Set("trace_id", trace_id);
+  return d;
+}
+EventLog EventLog::FromDict(const base::DictValue& d) {
+  EventLog e;
+  if (auto* v = d.FindString("id")) e.id = *v;
+  e.timestamp = static_cast<int64_t>(d.FindDouble("timestamp").value_or(0));
+  if (auto* v = d.FindString("account_id")) e.account_id = *v;
+  if (auto* v = d.FindString("category")) e.category = *v;
+  if (auto* v = d.FindString("event")) e.event = *v;
+  if (auto* v = d.FindString("level")) e.level = *v;
+  if (auto* v = d.FindString("details")) e.details = *v;
+  if (auto* v = d.FindString("trace_id")) e.trace_id = *v;
+  return e;
+}
+// --- Helpers ---
+base::ListValue AccountListToValue(const std::vector<Account>& accounts) {
+  base::ListValue list;
+  for (const auto& a : accounts) list.Append(a.ToDict());
+  return list;
+}
+std::vector<Account> AccountListFromValue(const base::ListValue& list) {
+  std::vector<Account> accounts;
+  accounts.reserve(list.size());
+  for (const auto& val : list) {
+    if (val.is_dict()) accounts.push_back(Account::FromDict(val.GetDict()));
+  }
+  return accounts;
+}
+std::string GenerateId() { return base::Uuid::GenerateRandomV4().AsLowercaseString(); }
+uint64_t GenerateSeed() { return base::RandUint64(); }
+}  // namespace metachat
