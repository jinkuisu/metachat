+// Borderless child window of `parent_view`'s NSWindow that shows a red circle
+// at the given CG screen coordinates. It is an ordered child of the parent
+// window, so it hides when the parent is hidden or miniaturized, but it
+// deliberately stays visible when the app is not frontmost
+// (setHidesOnDeactivate:NO). Repeated Show calls move the same window.
+void ShowCursorOverlay(gfx::NativeView parent_view,
+                       int screen_x,
+                       int screen_y);
+void UpdateCursorOverlay(int screen_x, int screen_y);
+void HideCursorOverlay();
+
+// Draws a hollow highlight box around the element the agent is acting on. The
+// rect (x,y,w,h) is in the web-content view's OWN coordinate space (CSS/DIP,
+// top-left origin); it is converted to screen coords via AppKit so it is
+// correct on any display / scale factor / window position. HideRectOverlay()
+// removes it. Repeated Show calls move/resize the same window.
+void ShowRectOverlay(gfx::NativeView parent_view,
+                     int x,
+                     int y,
+                     int width,
+                     int height);
+void HideRectOverlay();
