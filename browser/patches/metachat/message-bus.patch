diff --git a/third_party/blink/common/fingerprinting/fingerprint_profile.cc b/third_party/blink/common/fingerprinting/fingerprint_profile.cc
new file mode 100644
index 0000000000000..0a6d590bb4ae1
--- /dev/null
+++ b/third_party/blink/common/fingerprinting/fingerprint_profile.cc
@@ -0,0 +1,444 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "third_party/blink/public/common/fingerprinting/fingerprint_profile.h"
+
+#include <array>
+#include <cstdlib>
+#include <mutex>
+#include <random>
+#include <string>
+
+#include "base/command_line.h"
+#include "base/logging.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/stringprintf.h"
+
+namespace blink::fingerprinting {
+
+namespace {
+
+// Cmdline switches read at process startup.
+constexpr char kPersonaSeedSwitch[] = "persona-seed";
+// --persona-os=mac | win  (default: win). Selects which OS family the
+// persona claims. Mac for sites that gate Windows users more strictly
+// (e.g. sites where real Mac Chrome bypasses a managed bot challenge
+// that real Win Chrome has to solve). Win for everything else.
+constexpr char kPersonaOsSwitch[] = "persona-os";
+
+// ---- Persona pools ----
+//
+// All pools are std::array of trivially-destructible POD pairs so they
+// satisfy Chromium's `Wexit-time-destructors` policy without needing
+// base::NoDestructor wrapping.
+
+struct ChromeVer {
+  unsigned major;
+  const char* full;       // e.g. "148.0.7595.110"
+};
+
+struct WinVariant {
+  const char* label;      // "win11" | "win10"
+  const char* pv;         // platformVersion: "15.0.0" | "10.0.0"
+};
+
+struct MacVariant {
+  const char* label;      // "macos14" | "macos15"
+  const char* pv;         // platformVersion via UA-CH: "14.0.0" etc.
+};
+
+struct ScreenSize {
+  int w, h, avail_h;
+};
+
+struct WebGLGPU {
+  const char* vendor;
+  const char* renderer;
+};
+
+template <typename T>
+struct WeightedEntry {
+  T value;
+  double weight;
+};
+
+// Pinned to MATCH the engine: this tree is built from Chromium
+// 149.0.7827.115 (the current stable as of migration), so the persona
+// claims exactly 149.0.7827.115. Claiming the engine's own version is
+// the only way to stay consistent with feature-detected reality — a
+// persona one milestone behind (we previously claimed 148 on a 149
+// engine, after earlier claiming 148 on a 150 engine) risks UA-vs-engine
+// tampering hits if a probe gates on a 149-era API. Keep this in lockstep
+// with the checked-out Chromium tag whenever the engine is re-based.
+// The GREASE brand order is NOT hardcoded here: Chromium's built-in
+// GetGreasedUserAgentBrandList seeds its permutation from the major
+// version, so setting major=149 yields real-Chrome-149's brand order
+// (and Sec-CH-UA-Full-Version-List) automatically, byte-for-byte.
+constexpr std::array<WeightedEntry<ChromeVer>, 1> kChromeVersions = {{
+    {{149, "149.0.7827.115"}, 1.00},
+}};
+
+// Lock to Win 11 (15.0.0). Captured the bot detector WIN traffic on 2026-05-24 showed
+// 19.0.0 on the wire — but that signature is Server 2025 / cloud-VM
+// (build 26100+), NOT consumer desktops. Retail Win 11 22H2/23H2/24H2
+// users keep reporting 15.0.0 via the Sec-CH-UA-Platform-Version path
+// because Chrome's Universal API Contract version table caps at the
+// classical desktop release line. Claiming 19.0.0 would tag us as a
+// server/VM operator — exactly the population the bot detector treats more strictly.
+// Win 10 / 10.0.0 is rarely seen and was being rolled by ~35% of seeds
+// in an earlier version, observable as persona vs UA-CH inconsistency.
+constexpr std::array<WeightedEntry<WinVariant>, 1> kWinVariants = {{
+    {{"win11", "15.0.0"}, 1.00},
+}};
+
+// macOS variants. We lock to a recent Sonoma/Sequoia platformVersion
+// since the bot detector expects "real Mac user" Sec-CH-UA-Platform-Version when it
+// opts into high-entropy hints. The UA string itself is frozen by
+// Chrome's Reduce-User-Agent ("Macintosh; Intel Mac OS X 10_15_7") so
+// the UA major version varies but the OS substring does not.
+constexpr std::array<WeightedEntry<MacVariant>, 1> kMacVariants = {{
+    {{"sonoma", "14.0.0"}, 1.00},
+}};
+
+constexpr std::array<WeightedEntry<ScreenSize>, 9> kScreens = {{
+    {{1920, 1080, 1040}, 0.30},
+    {{1920, 1080, 1080}, 0.10},  // auto-hide taskbar
+    {{1366, 768,  728},  0.15},
+    {{1536, 864,  824},  0.10},
+    {{1440, 900,  860},  0.05},
+    {{2560, 1440, 1400}, 0.10},
+    {{1680, 1050, 1010}, 0.05},
+    {{1600, 900,  860},  0.05},
+    {{3840, 2160, 2120}, 0.10},
+}};
+
+// Hardware tiers: real desktop HW pairs core-count with RAM in
+// strongly-correlated ways. the commercial fingerprinter's anti-detect ML model trained
+// on real users flips to anti_detect_browser=true when it sees
+// implausible combinations (e.g. HC=20 + 16GB RAM — a 10-core HT CPU
+// almost always ships with 32GB+; HC=4 + 32GB — netbook CPU with
+// workstation RAM). Independently sampling HC and mem from flat pools
+// produces those off-distribution combos several percent of the time.
+//
+// Solution: pick a tier first, then draw HC and mem from that tier's
+// constrained pools. Tier weights from Steam Hardware Survey 2025-Q4.
+struct HwTier {
+  std::array<WeightedEntry<unsigned>, 3> hc;
+  std::array<WeightedEntry<float>, 2> mem;
+};
+
+// Tier weights reflect Intel UHD 770 user population on Steam Hardware
+// Survey: heavily weighted toward Tier 1-2 (entry laptop + mainstream
+// desktop). High-end tiers nearly extinct since IGP users rarely build
+// 16+ core workstation rigs. Concentrating mass on Tier 1-2 also drops
+// the fingerprinter VM ML score because integrated-GPU + mid-HW is the largest
+// real-user cluster and SwiftShader's perf signature matches it best.
+// 2026-05-30 reweighting: heavily weight Tier 1 (entry-laptop /
+// older-desktop / cloud-VPS-Win-Server). Real Chrome 148 on a cloud
+// Win VPS (the modal user pattern for our deployment niche) reports
+// HC=4 + 8GB. Tier 1 covers HC ∈ {4,6,8} and mem ∈ {4,8}. Pushing
+// Tier 1 to 75% concentrates personas near the real Win VPS shape
+// the fingerprinter's user histogram weights heaviest, while Tier 2 keeps a
+// small share for typical desktop users.
+constexpr std::array<WeightedEntry<HwTier>, 4> kHwTiers = {{
+    // Tier 1 — entry / older / cloud-Win-Server. 75%.
+    {{{{{4u, 0.65}, {6u, 0.20}, {8u, 0.15}}},
+      {{{4.0f, 0.30}, {8.0f, 0.70}}}}, 0.75},
+    // Tier 2 — mainstream desktop / gaming laptop. 22%.
+    {{{{{8u, 0.65}, {12u, 0.25}, {16u, 0.10}}},
+      {{{8.0f, 0.40}, {16.0f, 0.60}}}}, 0.22},
+    // Tier 3 — high-end gaming desktop. Rare at 2%.
+    {{{{{12u, 0.30}, {16u, 0.55}, {20u, 0.15}}},
+      {{{16.0f, 0.55}, {32.0f, 0.45}}}}, 0.02},
+    // Tier 4 — enthusiast / workstation. Vanishingly rare at 1%.
+    {{{{{16u, 0.30}, {20u, 0.40}, {24u, 0.30}}},
+      {{{32.0f, 0.65}, {64.0f, 0.35}}}}, 0.01},
+}};
+
+// WebGL renderer persona: switched from "Microsoft Basic Render Driver"
+// (WARP, the literal software-fallback for no-GPU Win machines) to a
+// real consumer GPU pool. WARP was the most honest answer for "no GPU
+// available" (since we render via --use-angle=swiftshader) but the fingerprinter
+// Pro's ML scores WARP at virtual_machine=0.985 — almost certain VM
+// classification — and downstream infers bot_type=nodriver from the
+// VM cluster. Claiming a real GPU shifts the inference cluster to
+// "normal desktop Win user".
+//
+// Trade-off: the underlying SwiftShader pixels we actually produce on
+// readPixels won't byte-match what an NVIDIA RTX 3060 + D3D11 ANGLE
+// would produce. Sites that hash readPixels output AND compare against
+// a vendor-specific baseline could catch the mismatch. the commercial fingerprinter's
+// public webgl_basics fingerprint is mostly string-based (vendor +
+// renderer + version) plus the extension/parameter hash list — those
+// we already pin to canonical values via fingerprint_profile, so the
+// hashes stay consistent. Pixel-level vendor-specific quirks (e.g.
+// NVIDIA's specific subpixel rendering of antialiased lines) are NOT
+// in the commercial fingerprinter's standard probe, so this is a low-risk swap.
+//
+// Pool of 3 common Win11 consumer GPUs (weighted by Steam Hardware
+// Survey share, roughly). NOTE: the weights are currently unused —
+// DeriveFromSeed forces index 1 (Intel UHD 770) for every persona (see
+// the WebGL-identity rationale in DeriveFromSeed). The NVIDIA/AMD entries
+// are retained as a menu for re-enabling per-seed GPU selection later.
+constexpr std::array<WeightedEntry<WebGLGPU>, 3> kWebGLGPUs = {{
+    // NVIDIA RTX 3060 — most common gaming desktop GPU on Steam (~7%
+    // share, biggest single discrete-GPU share).
+    {{"Google Inc. (NVIDIA)",
+      "ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0, D3D11)"},
+     0.50},
+    // Intel UHD 770 — most common integrated GPU on recent Win11
+    // laptops + low-end desktops. Lower-end persona matches lower
+    // device_memory / hardware_concurrency pools naturally.
+    {{"Google Inc. (Intel)",
+      "ANGLE (Intel, Intel(R) UHD Graphics 770 (0xA780) Direct3D11 vs_5_0 ps_5_0, D3D11)"},
+     0.35},
+    // AMD Radeon Vega — common AMD integrated GPU.
+    {{"Google Inc. (AMD)",
+      "ANGLE (AMD, AMD Radeon(TM) Graphics (0x000015D8) Direct3D11 vs_5_0 ps_5_0, D3D11)"},
+     0.15},
+}};
+
+// Weighted picker for std::array<WeightedEntry<T>, N>. Returns the
+// chosen entry's value (by const ref).
+template <typename T, size_t N>
+const T& WeightedPick(std::mt19937_64& rng,
+                      const std::array<WeightedEntry<T>, N>& pool) {
+  std::array<double, N> weights;
+  for (size_t i = 0; i < N; ++i) {
+    weights[i] = pool[i].weight;
+  }
+  std::discrete_distribution<size_t> dist(weights.begin(), weights.end());
+  return pool[dist(rng)].value;
+}
+
+}  // namespace
+
+FingerprintProfile DeriveFromSeed(uint64_t seed) {
+  // SplitMix64 decorrelates weak seeds (1, 2, 3 produce visibly similar
+  // streams under vanilla mt19937 init).
+  uint64_t mixed = seed + 0x9E3779B97F4A7C15ull;
+  mixed = (mixed ^ (mixed >> 30)) * 0xBF58476D1CE4E5B9ull;
+  mixed = (mixed ^ (mixed >> 27)) * 0x94D049BB133111EBull;
+  mixed = mixed ^ (mixed >> 31);
+
+  std::mt19937_64 rng(mixed);
+
+  FingerprintProfile p;
+  p.persona_seed = mixed;  // preserve for downstream isolation routines
+
+  // Identity
+  const ChromeVer& cv = WeightedPick(rng, kChromeVersions);
+  p.chrome_major_version = cv.major;
+  p.chrome_full_version = cv.full;
+  p.brand = "Google Chrome";
+
+  // OS variant. `--persona-os=mac` claims macOS Chrome (which the bot detector treats
+  // more leniently on some managed-challenge sites — captured
+  // 2026-05-24 from real Chrome 148 HARs: Mac UA gets 200 directly, Win
+  // UA gets the 307 → 403 → challenge loop). Default is Windows.
+  std::string os_pref = "win";
+  if (auto* cmd = base::CommandLine::ForCurrentProcess();
+      cmd && cmd->HasSwitch(kPersonaOsSwitch)) {
+    os_pref = cmd->GetSwitchValueASCII(kPersonaOsSwitch);
+  }
+
+  if (os_pref == "mac") {
+    const MacVariant& mv = WeightedPick(rng, kMacVariants);
+    // Chrome's Reduce-User-Agent freezes the Mac OS X token at 10_15_7.
+    p.unified_platform = "Macintosh; Intel Mac OS X 10_15_7";
+    p.navigator_platform = "MacIntel";
+    p.ua_metadata_platform = "macOS";
+    p.ua_metadata_platform_version = mv.pv;
+    // Apple Silicon: arm/64. Real Chrome ARM64 build on M1/M2/M3 reports
+    // architecture="arm" bitness="64". Rosetta/Intel Chrome would report
+    // architecture="x86". Our fork builds for arm64 by default so "arm"
+    // is the honest claim.
+    p.ua_metadata_architecture = "arm";
+    p.ua_metadata_bitness = "64";
+    p.ua_metadata_model = "";
+    p.ua_metadata_mobile = false;
+    p.ua_metadata_wow64 = false;
+  } else {
+    const WinVariant& wv = WeightedPick(rng, kWinVariants);
+    p.unified_platform = "Windows NT 10.0; Win64; x64";
+    p.navigator_platform = "Win32";
+    p.ua_metadata_platform = "Windows";
+    p.ua_metadata_platform_version = wv.pv;
+    p.ua_metadata_architecture = "x86";
+    p.ua_metadata_bitness = "64";
+    p.ua_metadata_model = "";
+    p.ua_metadata_mobile = false;
+    p.ua_metadata_wow64 = false;
+  }
+
+  // Full UA string built from chosen platform + major.
+  p.user_agent = base::StringPrintf(
+      "Mozilla/5.0 (%s) AppleWebKit/537.36 (KHTML, like Gecko) "
+      "Chrome/%u.0.0.0 Safari/537.36",
+      p.unified_platform.c_str(), p.chrome_major_version);
+
+  // Hardware — pick a CPU/RAM tier first, then draw from its
+  // constrained pools so HC and mem stay correlated (see kHwTiers
+  // comment for why). Save tier index for GPU pool selection below.
+  std::array<double, kHwTiers.size()> tier_weights;
+  for (size_t i = 0; i < kHwTiers.size(); ++i)
+    tier_weights[i] = kHwTiers[i].weight;
+  std::discrete_distribution<size_t> tier_dist(tier_weights.begin(),
+                                                tier_weights.end());
+  const size_t tier_idx = tier_dist(rng);
+  const HwTier& tier = kHwTiers[tier_idx].value;
+  p.hardware_concurrency = WeightedPick(rng, tier.hc);
+  p.device_memory_gb = WeightedPick(rng, tier.mem);
+  // 2026-06-01 cluster routing UNLOCKED. The previous override pinned
+  // every persona to HC=8/mem=16 to ride the "modal Win 11 desktop"
+  // ML cluster (VM ML floor of ~0.65). Empirically (3 different
+  // --persona-seed values via commercial fingerprinters) this also pinned every
+  // persona to the same fingerprinter visitor_id, defeating the per-seed
+  // cross-session-anonymity goal. The Steam-Hardware-Survey-weighted
+  // kHwTiers pool above already constrains HC/mem to combos that
+  // actually exist on real desktops, so unlocking is safe vs the
+  // "anti_detect_browser" ML model.
+
+  // Screen — pick once from kScreens. Earlier code picked AND then
+  // overwrote with hardcoded 1920×1080; that override is gone now.
+  // Variance here is one of the strongest fingerprinter-visitor-id drivers.
+  const ScreenSize& sc = WeightedPick(rng, kScreens);
+  p.screen_width = sc.w;
+  p.screen_height = sc.h;
+  p.available_screen_left = 0;
+  p.available_screen_top = 0;
+  p.available_screen_width = sc.w;
+  p.available_screen_height = sc.avail_h;
+
+  // Color depth. Real Win 11 desktops overwhelmingly report 24, but
+  // HDR / DCI-P3 / multi-monitor configs can report 30 or 32. Pool
+  // 24 at 92 % and 30 / 32 at 4 % each gives per-seed variance
+  // (different visitor_id per persona) without hitting the fingerprinter's
+  // "color_depth=32 with Win UA" anti-detect signal — 24 stays the
+  // overwhelming default and the minority values are within real-
+  // world prior distribution.
+  constexpr std::array<WeightedEntry<unsigned>, 3> kColorDepths = {{
+      {24u, 0.92},
+      {30u, 0.04},
+      {32u, 0.04},
+  }};
+  p.color_depth = WeightedPick(rng, kColorDepths);
+  p.device_pixel_ratio = 1.0;
+  // outer_window picks the inner content area dimensions of a real
+  // maximised browser on this screen size. Keep available_height as
+  // the cap (taskbar already accounted for in kScreens.avail_h).
+  p.outer_window_width = sc.w;
+  p.outer_window_height = sc.avail_h;
+
+  // Hardware (HC / memory_gb): chosen per persona above via WeightedPick
+  // over the tier-based picker (kHwTiers), which constrains the
+  // (CPU-cores, RAM) pair to combos that exist in the wild — no HC=20 with
+  // 16GB, no HC=4 with 32GB. Locking to a single (8, 8) collapsed every
+  // persona to the same commercial fingerprinters visitor_id; independent draws produced
+  // ~5% off-distribution personas the anti-detect ML flagged as tampered.
+  // We deliberately do NOT override HC / memory_gb here.
+
+  // WebGL identity. EMPIRICAL FINDING (2026-05-30 commercial fingerprinters tests):
+  // claiming NVIDIA RTX 3060 with SwiftShader as the actual backend
+  // makes the fingerprinter's VM ML jump to 0.95+ because it has a strong expected-
+  // perf profile for that GPU that we can't meet. Intel UHD 770 (and
+  // similar integrated IGPs) drops VM ML to ~0.85 because the perf
+  // expectation is low enough that SwiftShader's actual output looks
+  // plausible. Stock SwiftShader claiming "SwiftShader driver" itself
+  // scores VM ML 0.16 — the fingerprinter treats honest software rendering as
+  // legitimate.
+  //
+  // Choice: force Intel UHD 770 for all tiers. Loses some persona
+  // diversity (no NVIDIA / AMD options) but avoids the high-end-GPU-
+  // claim mismatch. tier_idx unused for GPU but still drives HC/mem.
+  // Index 1 = Intel UHD 770 in kWebGLGPUs.
+  (void)tier_idx;
+  const WebGLGPU& gpu = kWebGLGPUs[1].value;
+  // WebGPU re-enabled 2026-05-25: real Chrome 148 exposes navigator.gpu
+  // AND navigator.gpu.requestAdapter() returns a real GPUAdapter with
+  // info { vendor, architecture, ... }. Previous design left the surface
+  // present but had requestAdapter() return null, which bot-detection services
+  // the bot detector flags as "anti-detect surface fakery". Re-enabling the
+  // WebGPU service lets requestAdapter return the host's actual adapter
+  // — which on the Mac host exposes Apple/metal-3, contradicting the
+  // Win persona. The remaining work (out of scope of this fix) is to
+  // route adapter.info through the persona so it claims WARP / D3D12
+  // instead of leaking Apple. For now, having SOME adapter is better
+  // than having none: most real Chrome 148 users get an adapter.
+  p.webgpu_enabled = true;
+  p.webgl_vendor = gpu.vendor;
+  p.webgl_renderer = gpu.renderer;
+
+  // WebGL canonical limits — calibrated to Intel UHD 770 D3D11 on real
+  // Win 11. EMPIRICAL: matching SwiftShader's actual values exactly
+  // (8192/8192/etc) pushed the fingerprinter's VM ML to 0.97 because it maps us
+  // into the "Win Server on cloud VM" cluster (which scores VM=1.0).
+  // Keeping the Intel UHD spoof intentional-mismatch keeps us in the
+  // "weird-but-real Win user" cluster (VM ~0.72).
+  p.webgl_max_texture_size = 16384;
+  p.webgl_max_cube_map_texture_size = 16384;
+  p.webgl_max_renderbuffer_size = 16384;
+  p.webgl_max_viewport_dim = 32767;
+  p.webgl_max_vertex_attribs = 16;
+  // Real Win Chrome 148: MAX_VERTEX_UNIFORM_VECTORS = 4096 (not 1024 — earlier
+  // comment was wrong; ground truth from Win11 Chrome 148 dump).
+  // Intel UHD 770 D3D11 baseline (REVERTED 2026-05-30 — SwiftShader-
+  // exact alignment scored VM=0.97 cluster).
+  p.webgl_max_vertex_uniform_vectors = 4096;
+  p.webgl_max_fragment_uniform_vectors = 1024;
+  p.webgl_max_varying_vectors = 30;
+  p.webgl_max_texture_image_units = 16;
+  p.webgl_max_vertex_texture_image_units = 16;
+  p.webgl_max_combined_texture_image_units = 32;
+  p.webgl_max_draw_buffers = 8;
+  p.webgl_max_color_attachments = 8;
+  p.webgl_3d_max_texture_size = 2048;
+  p.webgl_max_array_texture_layers = 2048;
+  p.webgl_max_samples = 8;
+  p.webgl_max_vertex_uniform_blocks = 14;
+  p.webgl_max_fragment_uniform_blocks = 14;
+  p.webgl_max_uniform_block_size = 65536;
+  p.webgl_precision_float_bits = 23;
+  p.webgl_precision_range_min = 127;
+  p.webgl_precision_range_max = 127;
+
+  // Canvas / audio behavior (constant)
+  p.canvas_readback_enabled = true;
+  p.media_device_enumeration_enabled = false;
+  p.audio_sample_rate = 48000.0f;
+  p.audio_base_latency = 0.01;
+  // Win Chrome 148 WASAPI shared-mode typical: 0.01-0.02. Our prior
+  // 0.04 was Mac/Linux-typical, off-distribution for Win → small VM
+  // ML contribution.
+  p.audio_output_latency = 0.015;
+
+  return p;
+}
+
+const FingerprintProfile& Current() {
+  static FingerprintProfile* profile = nullptr;
+  static std::once_flag init_flag;
+  std::call_once(init_flag, []() {
+    uint64_t seed = 0;
+    const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+    if (cmd && cmd->HasSwitch(kPersonaSeedSwitch)) {
+      const std::string raw = cmd->GetSwitchValueASCII(kPersonaSeedSwitch);
+      uint64_t parsed = 0;
+      if (base::StringToUint64(raw, &parsed)) {
+        seed = parsed;
+      } else {
+        // Non-numeric seed: hash the raw string to a stable uint64, not 0.
+        seed = [&] { uint64_t h = 14695981039346656037ULL; for (unsigned char c : raw) { h ^= c; h *= 1099511628211ULL; } return h; }();  // FNV-1a (std::hash isn't stable across builds)
+      }
+    }
+    profile = new FingerprintProfile(DeriveFromSeed(seed));
+  // MetaChat: DVLOG - 记录指纹面具初始化
+  DVLOG(1) << "MetaChat: fingerprint profile initialized, seed=" << seed
+           << " persona-os="
+           << (cmd ? cmd->GetSwitchValueASCII("persona-os") : "(null)");
+  });
+  return *profile;
+}
+
+}  // namespace blink::fingerprinting
