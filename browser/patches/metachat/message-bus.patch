+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/window_manager.h"
+#include "base/logging.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_commands.h"
+#include "chrome/browser/ui/browser_navigator.h"
+#include "chrome/browser/ui/browser_navigator_params.h"
+#include "chrome/browser/ui/browser_window.h"
+#include "content/public/browser/web_contents.h"
+namespace metachat {
+WindowManager::WindowManager(Profile* host_profile) : host_profile_(host_profile) {}
+WindowManager::~WindowManager() {
+  for (auto& [id, entry] : windows_) {
+    if (entry.browser && entry.browser->window()) {
+      entry.browser->window()->Close();
+    }
+  }
+}
+Browser* WindowManager::OpenOrFocus(const std::string& account_id, const GURL& url) {
+  auto it = windows_.find(account_id);
+  if (it != windows_.end() && it->second.browser) {
+    DVLOG(1) << "WM: focus " << account_id;
+    it->second.browser->window()->Show();
+    return it->second.browser;
+  }
+  DVLOG(1) << "WM: create " << account_id;
+  Browser::CreateParams params(Browser::TYPE_NORMAL, host_profile_, false);
+  params.initial_bounds = gfx::Rect(100, 100, 1280, 800);
+  Browser* browser = Browser::Create(params);
+  NavigateParams nav_params(browser, url, ui::PAGE_TRANSITION_TYPED);
+  nav_params.disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+  Navigate(&nav_params);
+  windows_[account_id] = {browser, nav_params.navigated_or_inserted_contents.get()};
+  browser->window()->Show();
+  return browser;
+}
+void WindowManager::Hide(const std::string& account_id) {
+  auto it = windows_.find(account_id);
+  if (it != windows_.end() && it->second.browser && it->second.browser->window()) {
+    DVLOG(1) << "WM: hide " << account_id;
+    it->second.browser->window()->Hide();
+  }
+}
+void WindowManager::Close(const std::string& account_id) {
+  auto it = windows_.find(account_id);
+  if (it != windows_.end() && it->second.browser) {
+    DVLOG(1) << "WM: close " << account_id;
+    chrome::CloseWindow(it->second.browser);
+    windows_.erase(it);
+  }
+}
+Browser* WindowManager::GetBrowser(const std::string& account_id) const {
+  auto it = windows_.find(account_id);
+  return it != windows_.end() ? it->second.browser : nullptr;
+}
+content::WebContents* WindowManager::GetWebContents(const std::string& account_id) const {
+  auto it = windows_.find(account_id);
+  return it != windows_.end() ? it->second.web_contents : nullptr;
+}
+void WindowManager::Focus(const std::string& account_id) {
+  auto it = windows_.find(account_id);
+  if (it != windows_.end() && it->second.browser && it->second.browser->window()) {
+    it->second.browser->window()->Show();
+  }
+}
+}  // namespace metachat
