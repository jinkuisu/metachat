+// Copyright 2025 The MetaChat Authors.
+#ifndef CHROME_BROWSER_UI_WEBUI_METACHAT_CDP_BRIDGE_H_
+#define CHROME_BROWSER_UI_WEBUI_METACHAT_CDP_BRIDGE_H_
+#include <string>
+#include "base/memory/raw_ptr.h"
+#include "base/values.h"
+namespace content { class WebContents; }
+namespace metachat {
+// CdpBridge: proxies CDP commands to a WebContents.
+// Uses content::DevToolsAgentHost for protocol execution.
+class CdpBridge {
+ public:
+  CdpBridge();
+  // Attach to a WebContents. Returns CDP port or -1 on failure.
+  int Attach(content::WebContents* web_contents);
+  // Detach from current WebContents.
+  void Detach();
+  // Send a CDP command. Returns result dict or error dict.
+  base::Value::Dict SendCommand(const std::string& method,
+                                base::Value::Dict params);
+  bool IsAttached() const { return port_ > 0; }
+  int port() const { return port_; }
+ private:
+  int port_ = -1;
+  content::WebContents* attached_web_contents_ = nullptr;
+};
+}  // namespace metachat
+#endif
