+
+#include "base/memory/raw_ptr.h"
+#include "content/public/browser/web_contents.h"
+
+class Browser;
+class Profile;
+class GURL;
+
+namespace views {
+class WebView;
+}
+
+namespace metachat {
+
+constexpr int kSidebarWidth = 48;
+
+class WindowManager {
+ public:
+  explicit WindowManager(Browser* browser);
+  ~WindowManager();
+
+  void SwitchTo(const std::string& account_id, const GURL& url,
+                 const base::FilePath& profile_dir);
+  void Navigate(const std::string& account_id, const GURL& url);
+  void Close(const std::string& account_id);
+  void ShowDashboard();
+  void OnResize();
+  content::WebContents* GetWebContents(const std::string& account_id) const;
+
+ private:
+  struct AccountEntry {
+    std::unique_ptr<content::WebContents> web_contents;
+  };
+
+  raw_ptr<Browser> browser_;
+  std::unordered_map<std::string, AccountEntry> accounts_;
+  std::string active_account_id_;
+};
+
+}  // namespace metachat
