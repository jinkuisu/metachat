+// Copyright 2025 The MetaChat Authors. All rights reserved.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_METACHAT_DATA_MODEL_H_
+#define CHROME_BROWSER_UI_WEBUI_METACHAT_DATA_MODEL_H_
+
+#include <stdint.h>
+
+#include <string>
+#include <vector>
+
+#include "base/values.h"
+#include "base/version.h"
+
+namespace metachat {
+
+// --- FingerprintConfig -------------------------------------------------
+struct FingerprintConfig {
+  std::string platform;
+  std::string user_agent;
+  std::string locale;
+  std::string timezone;
+
+  int screen_width = 0;
+  int screen_height = 0;
+  int color_depth = 0;
+  double device_pixel_ratio = 0.0;
+
+  double device_memory = 0.0;
+  int hardware_concurrency = 0;
+
+  std::string webgl_vendor;
+  std::string webgl_renderer;
+
+  bool canvas_noise_enabled = true;
+  double canvas_noise_level = 0.5;
+  bool audio_noise_enabled = true;
+  double audio_noise_level = 0.3;
+  bool webrtc_leak_shield_enabled = true;
+
+  base::Value::Dict ToDict() const;
+  static FingerprintConfig FromDict(const base::Value::Dict& dict);
+};
+
+// --- ProxyConfig -------------------------------------------------------
+struct ProxyConfig {
+  std::string mode;
+  std::string host;
+  int port = 0;
+  std::string username;
+  std::string password;
+
+  base::Value::Dict ToDict() const;
+  static ProxyConfig FromDict(const base::Value::Dict& dict);
+};
+
+// --- Account -----------------------------------------------------------
+// One login session = one user-data-dir.
+struct Account {
+  std::string id;
+  std::string type;
+  std::string name;
+  std::string notes;
+
+  int64_t created_at = 0;
+  int64_t updated_at = 0;
+  int schema_version = 1;
+
+  std::string user_data_dir;
+  uint64_t persona_seed = 0;
+
+  FingerprintConfig fingerprint;
+  ProxyConfig proxy;
+
+  // Runtime (not persisted in accounts.json)
+  std::string status;
+  int cdp_port = 0;
+  int unread_count = 0;
+  int64_t last_active = 0;
+  std::string status_text;
+
+  base::Value::Dict ToDict() const;
+  static Account FromDict(const base::Value::Dict& dict);
+};
+
+// --- RuntimeState ------------------------------------------------------
+struct RuntimeState {
+  std::string account_id;
+  std::string status;
+  std::string error_message;
+  int unread_count = 0;
+  int64_t last_seen = 0;
+  std::string status_text;
+  std::string current_url;
+  std::string current_title;
+  int cdp_port = 0;
+  int pid = 0;
+
+  base::Value::Dict ToDict() const;
+  static RuntimeState FromDict(const base::Value::Dict& dict);
+};
+
+// --- EventLog ----------------------------------------------------------
+struct EventLog {
+  std::string id;
+  int64_t timestamp = 0;
+  std::string account_id;
+  std::string category;
+  std::string event;
+  std::string level;
+  std::string details;
+  std::string trace_id;
+
+  base::Value::Dict ToDict() const;
+  static EventLog FromDict(const base::Value::Dict& dict);
+};
+
+// --- Helpers -----------------------------------------------------------
+base::Value::List AccountListToValue(const std::vector<Account>& accounts);
+std::vector<Account> AccountListFromValue(const base::Value::List& list);
+
+std::string GenerateId();
+uint64_t GenerateSeed();
+
+}  // namespace metachat
+
+#endif  // CHROME_BROWSER_UI_WEBUI_METACHAT_DATA_MODEL_H_
diff --git a/chrome/browser/ui/webui/metachat/event_log.cc b/chrome/browser/ui/webui/metachat/event_log.cc
new file mode 100644
index 0000000000000..08cfcc4015447
--- /dev/null
+++ b/chrome/browser/ui/webui/metachat/event_log.cc
@@ -0,0 +1,51 @@
+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/event_log.h"
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/time/time.h"
+namespace metachat {
+EventLogger::EventLogger(const base::FilePath& log_dir) : log_dir_(log_dir) {
+  base::CreateDirectory(log_dir_);
+}
+void EventLogger::Log(const EventLog& entry) {
+  DVLOG(1) << "MetaChat: EventLog." << entry.type;
+  base::FilePath path = GetLogPathForDate(entry.timestamp);
+  std::vector<EventLog> events;
+  if (base::PathExists(path)) {
+    events = Query(0, 0);
+  }
+  events.push_back(entry);
+  base::Value::List list;
+  for (const auto& e : events) list.Append(e.ToDict());
+  std::string json;
+  base::JSONWriter::WriteWithOptions(list, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json);
+  if (!base::WriteFile(path, json)) {
+    LOG(WARNING) << "EventLogger: failed to write " << path;
+  }
+}
+std::vector<EventLog> EventLogger::Query(int64_t since, size_t limit) {
+  base::FilePath path = GetLogPathForDate(base::Time::Now().InMillisecondsSinceUnixEpoch());
+  if (!base::PathExists(path)) return {};
+  std::string json;
+  if (!base::ReadFileToString(path, &json)) return {};
+  auto parsed = base::JSONReader::Read(json);
+  if (!parsed || !parsed->is_list()) return {};
+  std::vector<EventLog> result;
+  for (const auto& val : parsed->GetList()) {
+    if (!val.is_dict()) continue;
+    EventLog e = EventLog::FromDict(val.GetDict());
+    if (since == 0 || e.timestamp >= since) result.push_back(e);
+  }
+  if (limit > 0 && result.size() > limit) result.resize(limit);
+  return result;
+}
+base::FilePath EventLogger::GetLogPathForDate(int64_t timestamp) const {
+  base::Time time = base::Time::FromMillisecondsSinceUnixEpoch(timestamp);
+  base::Time::Exploded exploded;
+  time.UTCExplode(&exploded);
+  std::string filename = base::StringPrintf("%04d-%02d-%02d.json",
+      exploded.year, exploded.month, exploded.day_of_month);
+  return log_dir_.AppendASCII(filename);
+}
+}  // namespace metachat
