+// Copyright 2025 The MetaChat Authors. All rights reserved.
+
+#include "chrome/browser/ui/webui/metachat/metachat_ui.h"
+
+#include <memory>
+
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/webui/metachat/message_bus.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+
+MetaChatUIConfig::MetaChatUIConfig()
+    : WebUIConfig(content::kChromeUIScheme, chrome::kChromeUIMetaChatHost) {}
+
+std::unique_ptr<content::WebUIController>
+MetaChatUIConfig::CreateWebUIController(content::WebUI* web_ui,
+                                        const GURL& url) {
+  return std::make_unique<MetaChatUI>(web_ui);
+}
+
+MetaChatUI::MetaChatUI(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  Profile* profile = Profile::FromWebUI(web_ui);
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kChromeUIMetaChatHost);
+  source->SetDefaultResource(100);
+  web_ui->AddMessageHandler(std::make_unique<MetaChatMessageBus>());
+}
+
+WEB_UI_CONTROLLER_TYPE_IMPL(MetaChatUI)

diff --git a/chrome/browser/ui/webui/metachat/message_bus.h b/chrome/browser/ui/webui/metachat/message_bus.h
new file mode 100644
--- /dev/null
+++ b/chrome/browser/ui/webui/metachat/message_bus.h
@@ -0,0 +1,53 @@
+// Copyright 2025 The MetaChat Authors. All rights reserved.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_METACHAT_MESSAGE_BUS_H_
+#define CHROME_BROWSER_UI_WEBUI_METACHAT_MESSAGE_BUS_H_
+
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/values.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+class Profile;
+
+// MetaChat Message Bus - centralized JS <-> C++ communication.
+// Protocol: chrome.send("metachat.dispatch", [channel, action, payload, requestId, meta])
+// Channels: accounts | webs | cdp | config | notification
+// Meta: {timestamp, traceId, source} for debugging
+class MetaChatMessageBus : public content::WebUIMessageHandler {
+ public:
+  MetaChatMessageBus();
+  ~MetaChatMessageBus() override;
+  void RegisterMessages() override;
+  void SendEvent(const std::string& channel,
+                 const std::string& event_name,
+                 base::Value::Dict payload);
+
+ private:
+  void HandleDispatch(const base::Value::List& args);
+  void SendResponse(const std::string& channel,
+                    const std::string& action,
+                    base::Value::Dict payload,
+                    const std::string& request_id);
+  base::Value::Dict MakeError(const std::string& code,
+                              const std::string& message);
+  void HandleAccounts(const std::string& action,
+                      const base::Value::Dict* payload,
+                      const std::string& request_id);
+  void HandleWebs(const std::string& action,
+                  const base::Value::Dict* payload,
+                  const std::string& request_id);
+  void HandleCdp(const std::string& action,
+                 const base::Value::Dict* payload,
+                 const std::string& request_id);
+  void HandleConfig(const std::string& action,
+                    const base::Value::Dict* payload,
+                    const std::string& request_id);
+  void HandleNotification(const std::string& action,
+                          const base::Value::Dict* payload,
+                          const std::string& request_id);
+  raw_ptr<Profile> profile_ = nullptr;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_METACHAT_MESSAGE_BUS_H_

diff --git a/chrome/browser/ui/webui/metachat/message_bus.cc b/chrome/browser/ui/webui/metachat/message_bus.cc
new file mode 100644
--- /dev/null
+++ b/chrome/browser/ui/webui/metachat/message_bus.cc
@@ -0,0 +1,178 @@
+// MetaChat: Message bus - WebUI - C++ bidirectional communication
+// Copyright 2025 The MetaChat Authors. All rights reserved.
+
+#include "base/logging.h"
+#include "chrome/browser/ui/webui/metachat/message_bus.h"
+
+#include <utility>
+
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/time/time.h"
+#include "base/trace_event/trace_event.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/web_ui.h"
+
+namespace {
+
+base::Value::Dict MakeResponse(const std::string& channel,
+                               const std::string& action_or_event,
+                               base::Value::Dict payload,
+                               const std::string& request_id,
+                               bool is_event) {
+  base::Value::Dict resp;
+  resp.Set("channel", channel);
+  if (is_event) {
+    resp.Set("event", action_or_event);
+  } else {
+    resp.Set("action", action_or_event);
+  }
+  resp.Set("payload", std::move(payload));
+  if (!request_id.empty()) {
+    resp.Set("requestId", request_id);
+  }
+  resp.Set("_serverTs", static_cast<double>(
+      base::Time::Now().InMillisecondsSinceUnixEpoch()));
+  return resp;
+}
+
+void LogMetaIfPresent(const base::Value::Dict* meta,
+                      const std::string& channel,
+                      const std::string& action,
+                      const std::string& request_id) {
+  if (!meta) return;
+  const std::string* trace_id = meta->FindString("traceId");
+  const std::string* source = meta->FindString("source");
+  double ts = meta->FindDouble("timestamp").value_or(0);
+  if (trace_id || source || ts > 0) {
+    DVLOG(1) << "MetaChat [" << channel << "." << action
+             << "] traceId=" << (trace_id ? *trace_id : "none")
+             << " source=" << (source ? *source : "unknown")
+             << " clientTs=" << base::NumberToString(static_cast<int64_t>(ts));
+  }
+}
+
+}  // namespace
+
+MetaChatMessageBus::MetaChatMessageBus() = default;
+MetaChatMessageBus::~MetaChatMessageBus() = default;
+
+void MetaChatMessageBus::RegisterMessages() {
+  profile_ = Profile::FromWebUI(web_ui());
+  web_ui()->RegisterMessageCallback(
+      "metachat.dispatch",
+      base::BindRepeating(&MetaChatMessageBus::HandleDispatch,
+                          base::Unretained(this)));
+}
+
+void MetaChatMessageBus::HandleDispatch(const base::Value::List& args) {
+  TRACE_EVENT0("metachat", "MetaChatMessageBus::HandleDispatch");
+  if (args.size() < 4) {
+    LOG(WARNING) << "MetaChatMessageBus: too few args (" << args.size() << ")";
+    return;
+  }
+  const std::string* channel = args[0].GetIfString();
+  const std::string* action = args[1].GetIfString();
+  const base::Value::Dict* payload = args[2].GetIfDict();
+  const std::string* request_id = args[3].GetIfString();
+  const base::Value::Dict* meta = nullptr;
+  if (args.size() >= 5) meta = args[4].GetIfDict();
+  if (!channel || !action || !request_id) {
+    LOG(WARNING) << "MetaChatMessageBus: invalid dispatch args";
+    return;
+  }
+  DVLOG(1) << "MetaChat: " << *channel << "." << *action
+           << " req=" << *request_id;
+  LogMetaIfPresent(meta, *channel, *action, *request_id);
+  if (*channel == "accounts")
+    HandleAccounts(*action, payload, *request_id);
+  else if (*channel == "webs")
+    HandleWebs(*action, payload, *request_id);
+  else if (*channel == "cdp")
+    HandleCdp(*action, payload, *request_id);
+  else if (*channel == "config")
+    HandleConfig(*action, payload, *request_id);
+  else if (*channel == "notification")
+    HandleNotification(*action, payload, *request_id);
+  else
+    SendResponse(*channel, *action,
+                 MakeError("unknown_channel", "Unknown: " + *channel),
+                 *request_id);
+}
+
+void MetaChatMessageBus::SendResponse(const std::string& channel,
+                                      const std::string& action,
+                                      base::Value::Dict payload,
+                                      const std::string& request_id) {
+  std::string json;
+  base::JSONWriter::Write(
+      MakeResponse(channel, action, std::move(payload), request_id, false),
+      &json);
+  web_ui()->CallJavascriptFunctionUnsafe("__metachat.onMessage",
+                                         base::Value(json));
+}
+
+void MetaChatMessageBus::SendEvent(const std::string& channel,
+                                   const std::string& event_name,
+                                   base::Value::Dict payload) {
+  std::string json;
+  base::JSONWriter::Write(
+      MakeResponse(channel, event_name, std::move(payload), "", true),
+      &json);
+  web_ui()->CallJavascriptFunctionUnsafe("__metachat.onMessage",
+                                         base::Value(json));
+}
+
+base::Value::Dict MetaChatMessageBus::MakeError(
+    const std::string& code, const std::string& message) {
+  base::Value::Dict err;
+  err.Set("_metachat_error_", code);
+  err.Set("message", message);
+  return err;
+}
+
+void MetaChatMessageBus::HandleAccounts(
+    const std::string& action, const base::Value::Dict* payload,
+    const std::string& request_id) {
+  if (action == "list") {
+    base::Value::Dict result;
+    result.Set("accounts", base::Value::List());
+    SendResponse("accounts", action, std::move(result), request_id);
+  } else {
+    SendResponse("accounts", action,
+        MakeError("not_implemented",
+            "accounts: " + action + " not implemented"), request_id);
+  }
+}
+
+void MetaChatMessageBus::HandleWebs(
+    const std::string& action, const base::Value::Dict* payload,
+    const std::string& request_id) {
+  SendResponse("webs", action,
+      MakeError("not_implemented", "webs: " + action + " not implemented"),
+      request_id);
+}
+
+void MetaChatMessageBus::HandleCdp(
+    const std::string& action, const base::Value::Dict* payload,
+    const std::string& request_id) {
+  SendResponse("cdp", action,
+      MakeError("not_implemented", "cdp: " + action + " not implemented"),
+      request_id);
+}
+
+void MetaChatMessageBus::HandleConfig(
+    const std::string& action, const base::Value::Dict* payload,
+    const std::string& request_id) {
+  SendResponse("config", action,
+      MakeError("not_implemented", "config: " + action + " not implemented"),
+      request_id);
+}
+
+void MetaChatMessageBus::HandleNotification(
+    const std::string& action, const base::Value::Dict* payload,
+    const std::string& request_id) {
+  SendResponse("notification", action,
+      MakeError("not_implemented",
+          "notification: " + action + " not implemented"), request_id);
+}
