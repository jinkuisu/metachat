+                                                       uint32_t type,
+                                                       bool normalized,
+                                                       int32_t stride,
+                                                       int32_t offset);
+
+  // Draw
+  static std::vector<uint8_t> WebGLDrawArrays(uint32_t id,
+                                              uint32_t mode,
+                                              int32_t first, int32_t count);
+  static std::vector<uint8_t> WebGLDrawElements(uint32_t id,
+                                                uint32_t mode,
+                                                int32_t count,
+                                                uint32_t type,
+                                                int32_t offset);
+
+  // Readback (returns ImageData reply; caller blocks via existing pattern).
+  static std::vector<uint8_t> WebGLReadPixels(uint32_t id,
+                                              int32_t x, int32_t y,
+                                              uint32_t w, uint32_t h,
+                                              uint32_t format, uint32_t type);
+};
+
+// Parsed result of a `TextMetrics` server reply.
+struct PLATFORM_EXPORT TextMetricReply {
+  float width;
+  float actual_bounding_box_ascent;
+  float actual_bounding_box_descent;
+  float font_bounding_box_ascent;
+  float font_bounding_box_descent;
+};
+
+// Parsed result of an `ImageData` server reply.
+struct PLATFORM_EXPORT ImageDataReply {
+  uint32_t canvas_id;
+  uint32_t width;
+  uint32_t height;
+  // RGBA8, premultiplied per canvas spec. std::vector instead of
+  // blink::Vector because the same struct round-trips through the
+  // platform/network layer which uses std-only containers.
+  std::vector<uint8_t> pixels
+      ALLOW_DISCOURAGED_TYPE("interop with canvas-bridge wire codec");
+};
+
+// Parsed result of a `Welcome` server reply.
+struct PLATFORM_EXPORT WelcomeReply {
+  uint32_t protocol_version;
+  std::string server_version;
+  std::string os;
+  std::string gpu_renderer;
+  std::string gpu_vendor;
+};
+
+class PLATFORM_EXPORT MsgParser {
+ public:
+  // Returns `std::nullopt` if `frame` is not a Welcome message or is
+  // malformed.
+  static std::optional<WelcomeReply> ParseWelcome(
+      base::span<const uint8_t> frame);
+
+  // Returns nullopt if `frame` is not an ImageData reply.
+  static std::optional<ImageDataReply> ParseImageData(
+      base::span<const uint8_t> frame);
+
+  // Returns nullopt if `frame` is not a TextMetrics reply or is
+  // malformed. The bridge issues a 1-family × 1-size request so the
+  // reply contains exactly one metric.
+  static std::optional<TextMetricReply> ParseTextMetrics(
+      base::span<const uint8_t> frame);
+};
+
+}  // namespace blink::canvas_bridge
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
