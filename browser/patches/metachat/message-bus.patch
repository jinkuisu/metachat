+MetaChatUIConfig::MetaChatUIConfig()
+    : WebUIConfig(content::kChromeUIScheme, chrome::kChromeUIMetaChatHost) {}
+
+std::unique_ptr<content::WebUIController>
+MetaChatUIConfig::CreateWebUIController(content::WebUI* web_ui,
+                                        const GURL& url) {
+  return std::make_unique<MetaChatUI>(web_ui);
+}
