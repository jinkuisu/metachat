+namespace {
+
+// Cubic bezier with control points biased perpendicular to the straight line.
+gfx::PointF HumanizeCubicBezier(gfx::PointF p0,
+                                gfx::PointF p1,
+                                gfx::PointF p2,
+                                gfx::PointF p3,
+                                double t) {
+  const double u = 1.0 - t;
+  return gfx::PointF(
+      u * u * u * p0.x() + 3 * u * u * t * p1.x() + 3 * u * t * t * p2.x() +
+          t * t * t * p3.x(),
+      u * u * u * p0.y() + 3 * u * u * t * p1.y() + 3 * u * t * t * p2.y() +
+          t * t * t * p3.y());
+}
+
+double HumanizeEaseInOut(double t) { return t * t * (3.0 - 2.0 * t); }
+
+double HumanizeGauss(double sigma, double clamp_abs) {
+  if (sigma <= 0) return 0.0;
+  const double u1 = std::max(1e-9, base::RandDouble());
+  const double u2 = base::RandDouble();
+  const double z = std::sqrt(-2.0 * std::log(u1)) * std::cos(2.0 * M_PI * u2);
+  return std::clamp(z * sigma, -clamp_abs, clamp_abs);
+}
+
+constexpr double kHumanizeDuration = 0.5;       // seconds
+constexpr int kHumanizeSamplesPerSec = 120;
+
+}  // namespace
+
 void InputHandler::DispatchMouseEvent(
     const std::string& event_type,
     double x,
@@ -1371,6 +1404,64 @@ void InputHandler::DispatchMouseEvent(
     std::optional<double> delta_y,
     std::optional<std::string> pointer_type,
     std::unique_ptr<DispatchMouseEventCallback> callback) {
+  // Lightweight-fork: when a mousePressed comes in, prepend a humanized
+  // bezier-curve motion from the last known cursor position to (x, y) before
+  // dispatching the press. Other event types pass through with cursor tracking.
+  const bool is_press = (event_type == "mousePressed");
+  const bool is_move = (event_type == "mouseMoved");
+  const gfx::PointF target(static_cast<float>(x), static_cast<float>(y));
+
+  if (is_press) {
+    const gfx::PointF start = last_cursor_position_;
+    const double dx = target.x() - start.x();
+    const double dy = target.y() - start.y();
+    const double dist = std::hypot(dx, dy);
+    if (dist >= 0.5) {
+      // Bow the path perpendicular to the straight line.
+      const double px = -dy / dist;
+      const double py = dx / dist;
+      const double bow1 = (base::RandDouble() * 0.30 - 0.15) * dist;
+      const double bow2 = (base::RandDouble() * 0.30 - 0.15) * dist;
+      const gfx::PointF cp1(start.x() + dx * 0.33 + px * bow1,
+                            start.y() + dy * 0.33 + py * bow1);
+      const gfx::PointF cp2(start.x() + dx * 0.66 + px * bow2,
+                            start.y() + dy * 0.66 + py * bow2);
+
+      const int steps = std::max(
+          8, static_cast<int>(kHumanizeDuration * kHumanizeSamplesPerSec));
+
+      // Pre-dispatch every move synchronously; we don't need timer-driven
+      // pacing for renderer event coalescing — the renderer treats them as
+      // ordered events. We DO need the press to fire after all moves so that
+      // pointerover/pointerenter resolve before pointerdown.
+      auto fire_move = [&](gfx::PointF p) {
+        auto mv = std::make_unique<blink::WebMouseEvent>(
+            blink::WebInputEvent::Type::kMouseMove,
+            blink::WebInputEvent::kNoModifiers, ui::EventTimeForNow());
+        mv->SetPositionInWidget(p.x(), p.y());
+        mv->SetPositionInScreen(p.x(), p.y());
+        mv->button = blink::WebMouseEvent::Button::kNoButton;
+        RenderWidgetHostImpl* widget_host =
+            host_ ? host_->GetRenderWidgetHost() : nullptr;
+        if (widget_host) {
+          widget_host->ForwardMouseEvent(*mv);
+        }
+      };
+      for (int i = 1; i <= steps; ++i) {
+        const double t = HumanizeEaseInOut(static_cast<double>(i) / steps);
+        gfx::PointF p = HumanizeCubicBezier(start, cp1, cp2, target, t);
+        p.set_x(static_cast<float>(p.x() + HumanizeGauss(0.4, 2.0)));
+        p.set_y(static_cast<float>(p.y() + HumanizeGauss(0.4, 2.0)));
+        fire_move(p);
+      }
+      // Exact landing without jitter so the press is at the requested coords.
+      fire_move(target);
+    }
+    last_cursor_position_ = target;
+  } else if (is_move) {
+    last_cursor_position_ = target;
+  }
+
   base::expected<std::unique_ptr<blink::WebMouseEvent>, protocol::Response>
       maybe_event = CreateWebMouseEvent(
           event_type, x, y, ScaleFactor(), std::move(modifiers),
