+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/cdp_bridge.h"
+#include "base/logging.h"
+#include "base/json/json_writer.h"
+#include "base/strings/string_number_conversions.h"
+#include "content/public/browser/devtools_agent_host.h"
+#include "content/public/browser/web_contents.h"
+namespace metachat {
+CdpBridge::CdpBridge() = default;
+CdpBridge::~CdpBridge() = default;
+int CdpBridge::Attach(content::WebContents* web_contents) {
+  if (!web_contents || attached_) return -1;
+  host_ = content::DevToolsAgentHost::GetOrCreateFor(web_contents);
+  if (!host_) return -1;
+  attached_ = host_->AttachClient(this);
+  return attached_ ? 0 : -1;
+}
+
+void CdpBridge::Detach() {
+  if (host_ && attached_) host_->DetachClient(this);
+  attached_ = false;
+  host_ = nullptr;
+}
+
+base::DictValue CdpBridge::SendCommand(const std::string& method,
+                                          base::DictValue params) {
+  if (!attached_ || !host_) {
+    base::DictValue err;
+    err.Set("error", "not_attached");
+    return err;
+  }
+  base::DictValue command;
+  command.Set("id", next_id_++);
+  command.Set("method", method);
+  command.Set("params", std::move(params));
+  std::string json;
+  base::JSONWriter::Write(command, &json);
+  host_->DispatchProtocolMessage(this, base::as_byte_span(json));
+  base::DictValue ok;
+  ok.Set("status", "sent");
+  return ok;
+}
+
+void CdpBridge::DispatchProtocolMessage(
+    content::DevToolsAgentHost* agent_host,
+    base::span<const uint8_t> message) {
+  DVLOG(1) << "CdpBridge: received " << message.size() << " bytes";
+}
+
+void CdpBridge::AgentHostClosed(
+    content::DevToolsAgentHost* agent_host) {
+  attached_ = false;
+  host_ = nullptr;
+}
+
+}  // namespace metachat
