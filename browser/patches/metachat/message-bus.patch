+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+
+const char kChromeUIMetaChatHost[] = "metachat";
+MetaChatUIConfig::MetaChatUIConfig()
+    : WebUIConfig(content::kChromeUIScheme, kChromeUIMetaChatHost) {}
+
+std::unique_ptr<content::WebUIController> MetaChatUIConfig::CreateWebUIController(
+    content::WebUI* web_ui, const GURL& url) {
+  return std::make_unique<MetaChatUI>(web_ui);
+}
+
+MetaChatUI::MetaChatUI(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  Profile* profile = Profile::FromWebUI(web_ui);
+  content::WebUIDataSource* source = content::WebUIDataSource::CreateAndAdd(
+      profile, kChromeUIMetaChatHost);
+  source->SetRequestFilter(
+      base::BindRepeating([](const std::string& path) { return true; }),
+      base::BindRepeating(
+          [](const std::string& path,
+             content::WebUIDataSource::GotDataCallback callback) {
+            base::FilePath exe_dir;
+            base::PathService::Get(base::FILE_EXE, &exe_dir);
+            base::FilePath file_path = exe_dir.DirName()
+                .Append(FILE_PATH_LITERAL("metachat_ui"))
+                .Append(base::FilePath::FromUTF8Unsafe(
+                    path == "/" ? "index.html" : path.substr(1)));
+            base::ThreadPool::PostTaskAndReplyWithResult(
+                FROM_HERE, {base::MayBlock()},
+                base::BindOnce(
+                    [](const base::FilePath& p)
+                        -> scoped_refptr<base::RefCountedString> {
+                      std::string content;
+                      if (!base::ReadFileToString(p, &content))
+                        return nullptr;
+                      return base::MakeRefCounted<base::RefCountedString>(
+                          std::move(content));
+                    },
+                    std::move(file_path)),
+                base::BindOnce(
+                    [](content::WebUIDataSource::GotDataCallback cb,
+                       scoped_refptr<base::RefCountedString> result) {
+                      std::move(cb).Run(std::move(result));
+                    },
+                    std::move(callback)));
+          }));
+  DVLOG(1) << "MetaChat: UI created";
+  web_ui->AddMessageHandler(std::make_unique<MetaChatMessageBus>());
+}
+
+WEB_UI_CONTROLLER_TYPE_IMPL(MetaChatUI)
