+namespace {
+
+// Cubic bezier at t in [0,1].
+gfx::PointF CubicBezier(gfx::PointF p0,
+                        gfx::PointF p1,
+                        gfx::PointF p2,
+                        gfx::PointF p3,
+                        double t) {
+  const double u = 1.0 - t;
+  return gfx::PointF(
+      u * u * u * p0.x() + 3 * u * u * t * p1.x() + 3 * u * t * t * p2.x() +
+          t * t * t * p3.x(),
+      u * u * u * p0.y() + 3 * u * u * t * p1.y() + 3 * u * t * t * p2.y() +
+          t * t * t * p3.y());
+}
+
+// Smoothstep — slow start, fast middle, slow end.
+double EaseInOut(double t) {
+  return t * t * (3.0 - 2.0 * t);
+}
+
+// Bounded gaussian using Box-Muller, clamped.
+double Gauss(double sigma, double clamp_abs) {
+  if (sigma <= 0) {
+    return 0.0;
+  }
+  const double u1 = std::max(1e-9, base::RandDouble());
+  const double u2 = base::RandDouble();
+  const double z = std::sqrt(-2.0 * std::log(u1)) * std::cos(2.0 * M_PI * u2);
+  return std::clamp(z * sigma, -clamp_abs, clamp_abs);
+}
+
+// Self-owned humanized-click state machine. Lives on the UI thread, drives
+// itself via base::OneShotTimer, and self-destructs when done (success or
+// after firing the CDP callback once).
+class HumanizedClickRunner {
+ public:
+  using CallbackPtr =
+      std::unique_ptr<BrowserHandler::HumanizedClickCallback>;
+
+  static void Start(base::WeakPtr<RenderWidgetHostImpl> rwh,
+                    base::WeakPtr<WebContents> web_contents,
+                    gfx::PointF target,
+                    double duration_seconds,
+                    bool no_click,
+                    bool visualize,
+                    CallbackPtr callback) {
+    new HumanizedClickRunner(std::move(rwh), std::move(web_contents), target,
+                             duration_seconds, no_click, visualize,
+                             std::move(callback));
+  }
+
+ private:
+  HumanizedClickRunner(base::WeakPtr<RenderWidgetHostImpl> rwh,
+                       base::WeakPtr<WebContents> web_contents,
+                       gfx::PointF target,
+                       double duration_seconds,
+                       bool no_click,
+                       bool visualize,
+                       CallbackPtr callback)
+      : rwh_(std::move(rwh)),
+        web_contents_(std::move(web_contents)),
+        target_(target),
+        no_click_(no_click),
+        visualize_(visualize),
+        callback_(std::move(callback)) {
+    // Start from a neutral cursor position. We don't know where the renderer
+    // thinks the cursor currently is, so start somewhere off the path and let
+    // the move sequence walk to target. Use the document origin as the start
+    // (gives a deterministic, non-suspicious entry).
+    const gfx::PointF start(0.f, 0.f);
+    const double dx = target.x() - start.x();
+    const double dy = target.y() - start.y();
+    const double dist = std::hypot(dx, dy);
+
+    const double duration = std::clamp(duration_seconds, 0.05, 10.0);
+    const int steps = std::max(8, static_cast<int>(duration * 120.0));
+    step_dt_ = base::Microseconds(static_cast<int64_t>(duration * 1e6 / steps));
+
+    // Bow the path perpendicular to the straight line by ±15% of distance.
+    const double px = dist > 0 ? -dy / dist : 0.0;
+    const double py = dist > 0 ? dx / dist : 0.0;
+    const double bow1 = (base::RandDouble() * 0.30 - 0.15) * dist;
+    const double bow2 = (base::RandDouble() * 0.30 - 0.15) * dist;
+    const gfx::PointF cp1(start.x() + dx * 0.33 + px * bow1,
+                          start.y() + dy * 0.33 + py * bow1);
+    const gfx::PointF cp2(start.x() + dx * 0.66 + px * bow2,
+                          start.y() + dy * 0.66 + py * bow2);
+
+    path_.reserve(steps + 1);
+    for (int i = 1; i <= steps; ++i) {
+      const double t = EaseInOut(static_cast<double>(i) / steps);
+      gfx::PointF p = CubicBezier(start, cp1, cp2, target, t);
+      p.set_x(static_cast<float>(p.x() + Gauss(0.4, 2.0)));
+      p.set_y(static_cast<float>(p.y() + Gauss(0.4, 2.0)));
+      path_.push_back(p);
+    }
+    // Exact landing (no jitter) so the click lands on target.
+    path_.push_back(target);
+
+    // Kick the first event immediately, then schedule the next.
+    Tick();
+  }
+
+  ~HumanizedClickRunner() = default;
+
+  void UpdateOverlay(gfx::PointF viewport_point) {
+    if (!visualize_) {
+      return;
+    }
+#if BUILDFLAG(IS_MAC)
+    if (!web_contents_) {
+      return;
+    }
+    RenderWidgetHostViewBase* view =
+        rwh_ && rwh_->GetView()
+            ? static_cast<RenderWidgetHostViewBase*>(rwh_->GetView())
+            : nullptr;
+    if (!view) {
+      return;
+    }
+    // The cursor overlay is a child view of the content view, positioned in the
+    // view's own coordinate space (CSS/DIP, top-left) — which is exactly the
+    // viewport point. No screen / primary-display conversion (that was wrong on
+    // secondary or fractionally-scaled displays).
+    const int vx = static_cast<int>(viewport_point.x());
+    const int vy = static_cast<int>(viewport_point.y());
+    if (!overlay_visible_) {
+      devtools::ShowCursorOverlay(view->GetNativeView(), vx, vy);
+      overlay_visible_ = true;
+    } else {
+      devtools::UpdateCursorOverlay(vx, vy);
+    }
+#endif
+  }
+
+  void Tick() {
+    if (!rwh_) {
+      Finish();
+      return;
+    }
+    if (index_ < path_.size()) {
+      Dispatch(blink::WebInputEvent::Type::kMouseMove, path_[index_]);
+      UpdateOverlay(path_[index_]);
+      ++index_;
+      // Schedule next with ±5% timing jitter.
+      const double jitter_factor =
+          1.0 + Gauss(0.05, 0.20);  // up to ±20% clamped
+      const base::TimeDelta next_dt =
+          base::Microseconds(static_cast<int64_t>(
+              step_dt_.InMicroseconds() * std::max(0.5, jitter_factor)));
+      timer_.Start(FROM_HERE, next_dt,
+                   base::BindOnce(&HumanizedClickRunner::Tick,
+                                  base::Unretained(this)));
+      return;
+    }
+    // Path exhausted. Maybe click, then finish.
+    if (!no_click_) {
+      Dispatch(blink::WebInputEvent::Type::kMouseDown, target_);
+      // Human dwell 40–110 ms.
+      const base::TimeDelta dwell =
+          base::Milliseconds(40 + static_cast<int>(base::RandDouble() * 70));
+      timer_.Start(FROM_HERE, dwell,
+                   base::BindOnce(&HumanizedClickRunner::Release,
+                                  base::Unretained(this)));
+      return;
+    }
+    Finish();
+  }
+
+  void Release() {
+    if (rwh_) {
+      Dispatch(blink::WebInputEvent::Type::kMouseUp, target_);
+    }
+    Finish();
+  }
+
+  void Dispatch(blink::WebInputEvent::Type type, gfx::PointF point) {
+    blink::WebMouseEvent event(type, blink::WebInputEvent::kNoModifiers,
+                               ui::EventTimeForNow());
+    event.SetPositionInWidget(point.x(), point.y());
+    event.SetPositionInScreen(point.x(), point.y());
+    event.button = blink::WebMouseEvent::Button::kLeft;
+    event.click_count = (type == blink::WebInputEvent::Type::kMouseDown ||
+                         type == blink::WebInputEvent::Type::kMouseUp)
+                            ? 1
+                            : 0;
+    // No kFromDebugger marker — we want this to look like real input.
+    //
+    // Route via the cross-process input event router so that points that
+    // hit-test into a cross-origin (OOPIF) iframe are forwarded to the
+    // iframe's own renderer. Without this, ForwardMouseEvent would post
+    // the event directly to the parent renderer, which would deliver it
+    // to the parent's <iframe> element node but never cross the process
+    // boundary into the embedded frame — so clicks on cross-origin
+    // iframes would silently do nothing. Falls back to the direct path
+    // if there's no router (e.g. embedded views without a delegate).
+    RenderWidgetHostViewBase* root_view =
+        rwh_->GetView() ? static_cast<RenderWidgetHostViewBase*>(rwh_->GetView())
+                        : nullptr;
+    input::RenderWidgetHostInputEventRouter* router =
+        rwh_->delegate() ? rwh_->delegate()->GetInputEventRouter() : nullptr;
+    if (root_view && router) {
+      ui::LatencyInfo latency_info;
+      latency_info.AddLatencyNumber(ui::INPUT_EVENT_LATENCY_UI_COMPONENT);
+      router->RouteMouseEvent(root_view, &event, latency_info);
+    } else {
+      rwh_->ForwardMouseEvent(event);
+    }
+  }
+
+  void Finish() {
+#if BUILDFLAG(IS_MAC)
+    if (overlay_visible_) {
+      // Let the ring sit at the target for ~1.5s so the user can actually
+      // see where the click landed. Without this delay, HideCursorOverlay
+      // would run as soon as the click sequence finishes (via Finish()), so
+      // the ring could vanish within a frame or two of the user noticing it.
+      // ScheduleFinishAfterLinger keeps `this` alive long enough for the
+      // linger then tears down.
+      ScheduleFinishAfterLinger();
+      return;
+    }
+#endif
+    DoFinish();
+  }
+
+  void ScheduleFinishAfterLinger() {
+    constexpr base::TimeDelta kLinger = base::Milliseconds(1500);
+    timer_.Start(FROM_HERE, kLinger,
+                 base::BindOnce(&HumanizedClickRunner::FinishAfterLinger,
+                                base::Unretained(this)));
+  }
+
+  void FinishAfterLinger() {
+#if BUILDFLAG(IS_MAC)
+    if (overlay_visible_) {
+      devtools::HideCursorOverlay();
+      overlay_visible_ = false;
+    }
+#endif
+    DoFinish();
+  }
+
+  void DoFinish() {
+    if (callback_) {
+      callback_->sendSuccess();
+    }
+    delete this;
+  }
+
+  base::WeakPtr<RenderWidgetHostImpl> rwh_;
+  base::WeakPtr<WebContents> web_contents_;
+  gfx::PointF target_;
+  bool no_click_;
+  bool visualize_;
+  std::vector<gfx::PointF> path_;
+  size_t index_ = 0;
+  base::TimeDelta step_dt_;
+  base::OneShotTimer timer_;
+  CallbackPtr callback_;
+  bool overlay_visible_ = false;
+};
+
+}  // namespace
+
+void BrowserHandler::HumanizedClick(
+    const std::string& in_target_id,
+    double in_x,
+    double in_y,
+    std::optional<double> in_duration,
+    std::optional<bool> in_no_click,
+    std::optional<bool> in_visualize,
+    std::unique_ptr<HumanizedClickCallback> callback) {
+  scoped_refptr<DevToolsAgentHost> host =
+      DevToolsAgentHost::GetForId(in_target_id);
+  if (!host) {
+    callback->sendFailure(
+        Response::InvalidParams("No target with given targetId"));
+    return;
+  }
+  WebContents* web_contents = host->GetWebContents();
+  if (!web_contents) {
+    callback->sendFailure(
+        Response::InvalidParams("Target has no WebContents"));
+    return;
+  }
+  RenderWidgetHost* rwh = web_contents->GetRenderWidgetHostView()
+                              ? web_contents->GetRenderWidgetHostView()
+                                    ->GetRenderWidgetHost()
+                              : nullptr;
+  if (!rwh) {
+    callback->sendFailure(Response::ServerError("No active RenderWidgetHost"));
+    return;
+  }
+  HumanizedClickRunner::Start(
+      static_cast<RenderWidgetHostImpl*>(rwh)->GetWeakPtr(),
+      web_contents->GetWeakPtr(),
+      gfx::PointF(static_cast<float>(in_x), static_cast<float>(in_y)),
+      in_duration.value_or(0.6), in_no_click.value_or(false),
+      in_visualize.value_or(false),
+      std::move(callback));
+}
+
+void BrowserHandler::AgentRunTask(
+    const std::string& in_target_id,
+    const std::string& in_goal,
+    std::optional<int> in_max_steps,
+    std::optional<std::string> in_model,
+    std::optional<std::string> in_plan_json,
+    std::unique_ptr<AgentRunTaskCallback> callback) {
+  scoped_refptr<DevToolsAgentHost> host =
+      DevToolsAgentHost::GetForId(in_target_id);
+  if (!host) {
+    callback->sendFailure(
+        Response::InvalidParams("No target with given targetId"));
+    return;
+  }
+  WebContents* web_contents = host->GetWebContents();
+  if (!web_contents) {
+    callback->sendFailure(
+        Response::InvalidParams("Target has no WebContents"));
+    return;
+  }
+  WebContentsDelegate* delegate = web_contents->GetDelegate();
+  if (!delegate) {
+    callback->sendFailure(Response::ServerError("Target has no delegate"));
+    return;
+  }
+  // The agent loop is owned by the chrome layer (Browser, via the delegate);
+  // content/ cannot depend on chrome/. Forward and answer the async callback
+  // when the task completes.
+  delegate->RunAgentTask(
+      web_contents, in_goal, in_max_steps.value_or(20),
+      in_model.value_or(std::string()), in_plan_json.value_or(std::string()),
+      base::BindOnce(
+          [](std::unique_ptr<AgentRunTaskCallback> cb, bool success,
+             const std::string& final_text, const std::string& steps_json) {
+            cb->sendSuccess(success, final_text, steps_json);
+          },
+          std::move(callback)));
+}
+
+namespace {
+
+// Build a JS expression that returns [x, y] of the element's center, or null
+// if the element doesn't exist. selector is interpolated as a JSON string
+// literal so quotes/backslashes in the user's input are properly escaped.
+std::u16string BuildResolveSelectorScript(const std::string& selector) {
+  // Crude JSON-escape — good enough since selectors are short and ASCII-ish.
+  std::string escaped;
+  escaped.reserve(selector.size() + 8);
+  for (char c : selector) {
+    switch (c) {
+      case '\\': escaped += "\\\\"; break;
+      case '"':  escaped += "\\\""; break;
+      case '\n': escaped += "\\n";  break;
+      case '\r': escaped += "\\r";  break;
+      case '\t': escaped += "\\t";  break;
+      default:
+        if (static_cast<unsigned char>(c) < 0x20) {
+          char buf[8];
+          snprintf(buf, sizeof(buf), "\\u%04x", c);
+          escaped += buf;
+        } else {
+          escaped += c;
+        }
+    }
+  }
+  std::string js =
+      "(()=>{try{const e=document.querySelector(\"" + escaped +
+      "\");if(!e)return null;const r=e.getBoundingClientRect();"
+      "return [r.left+r.width/2, r.top+r.height/2];}catch(e){return null;}})()";
+  return std::u16string(js.begin(), js.end());
+}
+
+}  // namespace
+
+void BrowserHandler::HumanizedClickSelector(
+    const std::string& in_target_id,
+    const std::string& in_selector,
+    std::optional<double> in_duration,
+    std::optional<bool> in_no_click,
+    std::optional<bool> in_visualize,
+    std::unique_ptr<HumanizedClickSelectorCallback> callback) {
+  scoped_refptr<DevToolsAgentHost> host =
+      DevToolsAgentHost::GetForId(in_target_id);
+  if (!host) {
+    callback->sendFailure(
+        Response::InvalidParams("No target with given targetId"));
+    return;
+  }
+  WebContents* web_contents = host->GetWebContents();
+  if (!web_contents) {
+    callback->sendFailure(
+        Response::InvalidParams("Target has no WebContents"));
+    return;
+  }
+  RenderFrameHost* rfh = web_contents->GetPrimaryMainFrame();
+  if (!rfh) {
+    callback->sendFailure(Response::ServerError("No primary main frame"));
+    return;
+  }
+
+  // Capture the bits the callback needs. WebContents pointer is captured raw
+  // and re-validated through DevToolsAgentHost in the callback.
+  std::string target_id = in_target_id;
+  double duration = in_duration.value_or(0.6);
+  bool no_click = in_no_click.value_or(false);
+  bool visualize = in_visualize.value_or(false);
+  auto cb_shared = std::make_shared<
+      std::unique_ptr<HumanizedClickSelectorCallback>>(std::move(callback));
+
+  rfh->ExecuteJavaScriptInIsolatedWorld(
+      BuildResolveSelectorScript(in_selector),
+      base::BindOnce(
+          [](std::string target_id, double duration, bool no_click,
+             bool visualize,
+             std::shared_ptr<std::unique_ptr<HumanizedClickSelectorCallback>>
+                 cb_shared,
+             base::Value result) {
+            auto& cb = *cb_shared;
+            if (!cb) return;
+            if (!result.is_list() || result.GetList().size() != 2) {
+              cb->sendFailure(Response::ServerError(
+                  "Selector did not match an element"));
+              return;
+            }
+            double x = result.GetList()[0].GetDouble();
+            double y = result.GetList()[1].GetDouble();
+
+            // Re-resolve the target — page may have navigated between calls.
+            scoped_refptr<DevToolsAgentHost> host =
+                DevToolsAgentHost::GetForId(target_id);
+            WebContents* wc = host ? host->GetWebContents() : nullptr;
+            RenderWidgetHost* rwh =
+                wc && wc->GetRenderWidgetHostView()
+                    ? wc->GetRenderWidgetHostView()->GetRenderWidgetHost()
+                    : nullptr;
+            if (!rwh) {
+              cb->sendFailure(
+                  Response::ServerError("Target disappeared during resolve"));
+              return;
+            }
+
+            // Bridge: when the runner finishes its HumanizedClickCallback,
+            // surface the result as the Selector-specific callback with x/y.
+            class BridgeCallback
+                : public BrowserHandler::HumanizedClickCallback {
+             public:
+              BridgeCallback(
+                  std::unique_ptr<HumanizedClickSelectorCallback> sel_cb,
+                  double x, double y)
+                  : sel_cb_(std::move(sel_cb)), x_(x), y_(y) {}
+              void sendSuccess() override {
+                sel_cb_->sendSuccess(x_, y_);
+              }
+              void sendFailure(const ::content::protocol::DispatchResponse& r)
+                  override {
+                sel_cb_->sendFailure(r);
+              }
+              void fallThrough() override { sel_cb_->fallThrough(); }
+             private:
+              std::unique_ptr<HumanizedClickSelectorCallback> sel_cb_;
+              double x_, y_;
+            };
+            auto bridge =
+                std::make_unique<BridgeCallback>(std::move(cb), x, y);
+            HumanizedClickRunner::Start(
+                static_cast<RenderWidgetHostImpl*>(rwh)->GetWeakPtr(),
+                wc->GetWeakPtr(),
+                gfx::PointF(static_cast<float>(x), static_cast<float>(y)),
+                duration, no_click, visualize, std::move(bridge));
+          },
+          std::move(target_id), duration, no_click, visualize, cb_shared),
+      // Pick a world ID within the valid range (CONTENT_END..MAX = 1..11).
+      // 10 is high enough to avoid Chrome's internal worlds 2-5.
+      10);
+}
