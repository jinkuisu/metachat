+namespace {
+
+base::DictValue MakeResponse(const std::string& channel,
+                               const std::string& action_or_event,
+                               base::DictValue payload,
+                               const std::string& request_id,
+                               bool is_event) {
+  base::DictValue resp;
+  resp.Set("channel", channel);
+  if (is_event) {
+    resp.Set("event", action_or_event);
+  } else {
+    resp.Set("action", action_or_event);
+  }
+  resp.Set("payload", std::move(payload));
+  if (!request_id.empty()) {
+    resp.Set("requestId", request_id);
+  }
+  resp.Set("_serverTs", static_cast<double>(
+      base::Time::Now().InMillisecondsSinceUnixEpoch()));
+  return resp;
+}
+
+void LogMetaIfPresent(const base::DictValue* meta,
+                      const std::string& channel,
+                      const std::string& action,
+                      const std::string& request_id) {
+  if (!meta) return;
+  const std::string* trace_id = meta->FindString("traceId");
+  const std::string* source = meta->FindString("source");
+  double ts = meta->FindDouble("timestamp").value_or(0);
+  if (trace_id || source || ts > 0) {
+    DVLOG(1) << "MetaChat [" << channel << "." << action
+             << "] traceId=" << (trace_id ? *trace_id : "none")
+             << " source=" << (source ? *source : "unknown")
+             << " clientTs=" << base::NumberToString(static_cast<int64_t>(ts));
+  }
+}
+
+}  // namespace
+
+MetaChatMessageBus::MetaChatMessageBus() = default;
+MetaChatMessageBus::~MetaChatMessageBus() = default;
+
+void MetaChatMessageBus::RegisterMessages() {
+  profile_ = Profile::FromWebUI(web_ui());
+  account_store_ = std::make_unique<metachat::AccountStore>(profile_);
+  content::WebContents* wc = web_ui()->GetWebContents();
+Browser* browser = chrome::FindBrowserWithTab(wc);
+window_manager_ = std::make_unique<metachat::WindowManager>(browser);
+  base::FilePath log_dir = profile_->GetPath()
+      .Append(FILE_PATH_LITERAL("metachat"))
+      .Append(FILE_PATH_LITERAL("events"));
+  event_logger_ = std::make_unique<metachat::EventLogger>(log_dir);
+
+  web_ui()->RegisterMessageCallback(
+      "metachat.dispatch",
+      base::BindRepeating(&MetaChatMessageBus::HandleDispatch,
+                          base::Unretained(this)));
+}
+
+void MetaChatMessageBus::HandleDispatch(const base::ListValue& args) {
+  TRACE_EVENT0("browser", "MetaChatMessageBus::HandleDispatch");
+  if (args.size() < 4) {
+    LOG(WARNING) << "MetaChatMessageBus: too few args (" << args.size() << ")";
+    return;
+  }
+  const std::string* channel = args[0].GetIfString();
+  const std::string* action = args[1].GetIfString();
+  const base::DictValue* payload = args[2].GetIfDict();
+  const std::string* request_id = args[3].GetIfString();
+  const base::DictValue* meta = nullptr;
+  if (args.size() >= 5) meta = args[4].GetIfDict();
+
+  if (!channel || !action || !request_id) {
+    LOG(WARNING) << "MetaChatMessageBus: invalid dispatch args";
+    return;
+  }
+
+  DVLOG(1) << "MetaChat: " << *channel << "." << *action
+           << " req=" << *request_id;
+  LogMetaIfPresent(meta, *channel, *action, *request_id);
+
+  // Log event for debugging
+  metachat::EventLog log_entry;
+  log_entry.timestamp = base::Time::Now().InMillisecondsSinceUnixEpoch();
+  log_entry.account_id = *channel;
+  log_entry.category = "dispatch";
+  log_entry.event = *channel + "." + *action;
+  log_entry.level = "info";
+  const std::string* trace_id = meta ? meta->FindString("traceId") : nullptr;
+  log_entry.trace_id = trace_id ? *trace_id : "";
+  event_logger_->Log(log_entry);
+
+  if (*channel == "accounts")
+    HandleAccounts(*action, payload, *request_id);
+  else if (*channel == "webs")
+    HandleWebs(*action, payload, *request_id);
+  else if (*channel == "cdp")
+    HandleCdp(*action, payload, *request_id);
+  else if (*channel == "config")
+    HandleConfig(*action, payload, *request_id);
+  else if (*channel == "notification")
+    HandleNotification(*action, payload, *request_id);
+  else if (*channel == "events")
+    HandleEvents(*action, payload, *request_id);
+  else
+    SendResponse(*channel, *action,
+                 MakeError("unknown_channel", "Unknown: " + *channel),
+                 *request_id);
+}
+
+void MetaChatMessageBus::SendResponse(const std::string& channel,
+                                      const std::string& action,
+                                      base::DictValue payload,
+                                      const std::string& request_id) {
+  std::string json;
+  base::JSONWriter::Write(
+      MakeResponse(channel, action, std::move(payload), request_id, false),
+      &json);
+  web_ui()->CallJavascriptFunctionUnsafe("__metachat.onMessage",
+                                         base::Value(json));
+}
+
+void MetaChatMessageBus::SendEvent(const std::string& channel,
+                                   const std::string& event_name,
+                                   base::DictValue payload) {
+  std::string json;
+  base::JSONWriter::Write(
+      MakeResponse(channel, event_name, std::move(payload), "", true),
+      &json);
+  web_ui()->CallJavascriptFunctionUnsafe("__metachat.onMessage",
+                                         base::Value(json));
+}
+
+base::DictValue MetaChatMessageBus::MakeError(
+    const std::string& code, const std::string& message) {
+  base::DictValue err;
+  err.Set("_metachat_error_", code);
+  err.Set("message", message);
+  return err;
+}
+
+// ─── Accounts ──────────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleAccounts(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  if (action == "list") {
+    auto accounts = account_store_->LoadAll();
+    base::DictValue result;
+    result.Set("accounts", metachat::AccountListToValue(accounts));
+    SendResponse("accounts", action, std::move(result), request_id);
+  } else if (action == "create") {
+    if (!payload) {
+      SendResponse("accounts", action, MakeError("invalid_payload", ""), request_id);
+      return;
+    }
+    metachat::Account a = metachat::Account::FromDict(*payload);
+    if (a.id.empty()) a.id = metachat::GenerateId();
+    a.created_at = base::Time::Now().InMillisecondsSinceUnixEpoch();
+    a.updated_at = a.created_at;
+    auto accounts = account_store_->LoadAll();
+    // Check duplicate id
+    for (const auto& existing : accounts) {
+      if (existing.id == a.id) {
+        SendResponse("accounts", action,
+                     MakeError("duplicate_id", "Account ID already exists"),
+                     request_id);
+        return;
+      }
+    }
+    accounts.push_back(a);
+    account_store_->SaveAll(accounts);
+    base::DictValue result;
+    result.Set("account", a.ToDict());
+    SendResponse("accounts", action, std::move(result), request_id);
+  } else if (action == "update") {
+    if (!payload) {
+      SendResponse("accounts", action, MakeError("invalid_payload", ""), request_id);
+      return;
+    }
+    metachat::Account a = metachat::Account::FromDict(*payload);
+    auto accounts = account_store_->LoadAll();
+    bool found = false;
+    for (auto& existing : accounts) {
+      if (existing.id == a.id) {
+        existing = a;
+        existing.updated_at = base::Time::Now().InMillisecondsSinceUnixEpoch();
+        found = true;
+        break;
+      }
+    }
+    if (!found) {
+      SendResponse("accounts", action,
+                   MakeError("not_found", "Account not found: " + a.id),
+                   request_id);
+      return;
+    }
+    account_store_->SaveAll(accounts);
+    base::DictValue result;
+    result.Set("account", a.ToDict());
+    SendResponse("accounts", action, std::move(result), request_id);
+  } else if (action == "delete") {
+    if (!payload) {
+      SendResponse("accounts", action, MakeError("invalid_payload", ""), request_id);
+      return;
+    }
+    const std::string* id = payload->FindString("id");
+    if (!id) {
+      SendResponse("accounts", action, MakeError("missing_id", ""), request_id);
+      return;
+    }
+    auto accounts = account_store_->LoadAll();
+    std::erase_if(accounts, [&](const metachat::Account& a) { return a.id == *id; });
+    account_store_->SaveAll(accounts);
+    SendResponse("accounts", action, base::DictValue(), request_id);
+  } else {
+    SendResponse("accounts", action,
+        MakeError("unknown_action", "accounts: " + action + " unknown"),
+        request_id);
+  }
+}
+
+// ─── Webs ─────────────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleWebs(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  if (action == "open" && payload) {
+    const std::string* account_id = payload->FindString("account_id");
+    const std::string* url_str = payload->FindString("url");
+    if (!account_id || !url_str) {
+      SendResponse("webs", action, MakeError("missing_fields", ""), request_id);
+      return;
+    }
+    auto acc_list2 = account_store_->LoadAll();
+auto it2 = std::find_if(acc_list2.begin(), acc_list2.end(),
+[&](const metachat::Account& a) { return a.id == *account_id; });
+if (it2 == acc_list2.end()) {
+SendResponse("webs", action, MakeError("not_found", ""), request_id);
+return;
+}
+base::FilePath acc_dir2 = profile_->GetPath()
+.Append(FILE_PATH_LITERAL("metachat_accounts"))
+.AppendASCII(*account_id);
+window_manager_->SwitchTo(*account_id, GURL(*url_str), acc_dir2);
+    base::DictValue result;
+    result.Set("status", "opened");
+    result.Set("account_id", *account_id);
+    SendResponse("webs", action, std::move(result), request_id);
+  } else if (action == "close" && payload) {
+    const std::string* account_id = payload->FindString("account_id");
+    if (!account_id) {
+      SendResponse("webs", action, MakeError("missing_id", ""), request_id);
+      return;
+    }
+    window_manager_->Close(*account_id);
+    base::DictValue result;
+    result.Set("status", "closed");
+    SendResponse("webs", action, std::move(result), request_id);
+  } else if (action == "hide" && payload) {
+    const std::string* account_id = payload->FindString("account_id");
+    if (!account_id) {
+      SendResponse("webs", action, MakeError("missing_id", ""), request_id);
+      return;
+    }
+    window_manager_->ShowDashboard();
+    base::DictValue result;
+    result.Set("status", "hidden");
+    SendResponse("webs", action, std::move(result), request_id);
+  } else if (action == "focus" && payload) {
+    const std::string* account_id = payload->FindString("account_id");
+    if (!account_id) {
+      SendResponse("webs", action, MakeError("missing_id", ""), request_id);
+      return;
+    }
+    auto acc_list4 = account_store_->LoadAll();
+auto it4 = std::find_if(acc_list4.begin(), acc_list4.end(),
+[&](const metachat::Account& a) { return a.id == *account_id; });
+if (it4 == acc_list4.end()) {
+SendResponse("webs", action, MakeError("not_found", ""), request_id);
+return;
+}
+base::FilePath acc_dir4 = profile_->GetPath()
+.Append(FILE_PATH_LITERAL("metachat_accounts"))
+.AppendASCII(*account_id);
+window_manager_->SwitchTo(*account_id, GURL(), acc_dir4);
+    base::DictValue result;
+    result.Set("status", "focused");
+    SendResponse("webs", action, std::move(result), request_id);
+  } else if (action == "switch") {
+    const std::string* account_id = payload->FindString("account_id");
+    const std::string* url_str = payload->FindString("url");
+    if (!account_id || !url_str) {
+      SendResponse("webs", action, MakeError("missing_fields", ""), request_id);
+      return;
+    }
+    auto acc_list = account_store_->LoadAll();
+    auto it = std::find_if(acc_list.begin(), acc_list.end(),
+        [&](const metachat::Account& a) { return a.id == *account_id; });
+    if (it == acc_list.end()) {
+      SendResponse("webs", action, MakeError("not_found", ""), request_id);
+      return;
+    }
+    base::FilePath acc_dir = profile_->GetPath()
+        .Append(FILE_PATH_LITERAL("metachat_accounts"))
+        .AppendASCII(*account_id);
+    window_manager_->SwitchTo(*account_id, GURL(*url_str), acc_dir);
+    base::DictValue result;
+    result.Set("status", "switched");
+    SendResponse("webs", action, std::move(result), request_id);
+  } else if (action == "show_dashboard") {
+    window_manager_->ShowDashboard();
+    base::DictValue result;
+    result.Set("status", "dashboard");
+    SendResponse("webs", action, std::move(result), request_id);
+  } else {
+    SendResponse("webs", action,
+        MakeError("unknown_action", "webs: " + action + " unknown"),
+        request_id);
+  }
+}
+
+// ─── CDP ──────────────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleCdp(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  if (action == "send" && payload) {
+    const std::string* account_id = payload->FindString("account_id");
+    const std::string* method = payload->FindString("method");
+    const base::DictValue* params = payload->FindDict("params");
+    if (!account_id || !method) {
+      SendResponse("cdp", action, MakeError("missing_fields", ""), request_id);
+      return;
+    }
+    content::WebContents* wc = window_manager_->GetWebContents(*account_id);
+    if (!wc) {
+      SendResponse("cdp", action, MakeError("no_window", ""), request_id);
+      return;
+    }
+    metachat::CdpBridge bridge;
+    bridge.Attach(wc);
+    base::DictValue result = bridge.SendCommand(
+        *method, params ? params->Clone() : base::DictValue());
+    SendResponse("cdp", action, std::move(result), request_id);
+  } else {
+    SendResponse("cdp", action,
+        MakeError("unknown_action", "cdp: " + action + " unknown"),
+        request_id);
+  }
+}
+
+// ─── Config ───────────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleConfig(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  base::FilePath config_path = profile_->GetPath()
+      .Append(FILE_PATH_LITERAL("metachat"))
+      .Append(FILE_PATH_LITERAL("config.json"));
+
+  if (action == "get") {
+    std::string json;
+    base::DictValue config;
+    if (base::ReadFileToString(config_path, &json)) {
+      auto parsed = base::JSONReader::Read(json, base::JSON_PARSE_RFC);
+      if (parsed && parsed->is_dict()) {
+        config = std::move(parsed->GetDict());
+      }
+    }
+    base::DictValue result;
+    result.Set("config", std::move(config));
+    SendResponse("config", action, std::move(result), request_id);
+  } else if (action == "set" && payload) {
+    const base::DictValue* config_dict = payload->FindDict("config");
+    if (!config_dict) {
+      SendResponse("config", action, MakeError("missing_config", ""), request_id);
+      return;
+    }
+    base::CreateDirectory(config_path.DirName());
+    std::string json;
+    base::JSONWriter::WriteWithOptions(
+        *config_dict, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json);
+    base::WriteFile(config_path, json);
+    SendResponse("config", action, base::DictValue(), request_id);
+  } else {
+    SendResponse("config", action,
+        MakeError("unknown_action", "config: " + action + " unknown"),
+        request_id);
+  }
+}
+
+// ─── Notification ─────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleNotification(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  // Notifications are push (server -> client) via SendEvent.
+  // For MVP, just acknowledge.
+  base::DictValue result;
+  result.Set("status", "ok");
+  result.Set("note", "notification pushes configured server-side");
+  SendResponse("notification", action, std::move(result), request_id);
+}
+
+// ─── Events ───────────────────────────────────────────────────────
+
+void MetaChatMessageBus::HandleEvents(
+    const std::string& action, const base::DictValue* payload,
+    const std::string& request_id) {
+  if (action == "query") {
+    int64_t since = static_cast<int64_t>(
+        payload ? payload->FindDouble("since").value_or(0) : 0);
+    size_t limit = static_cast<size_t>(
+        payload ? payload->FindInt("limit").value_or(0) : 0);
+    auto entries = event_logger_->Query(since, limit);
+    base::ListValue list;
+    for (const auto& e : entries) list.Append(e.ToDict());
+    base::DictValue result;
+    result.Set("events", std::move(list));
+    SendResponse("events", action, std::move(result), request_id);
+  } else {
+    SendResponse("events", action,
+        MakeError("unknown_action", "events: " + action + " unknown"),
+        request_id);
+  }
+}
