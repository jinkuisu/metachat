@@ -0,0 +1,36 @@
+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/account_store.h"
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "chrome/browser/profiles/profile.h"
+namespace metachat {
+AccountStore::AccountStore(Profile* profile) : profile_(profile) {}
+base::FilePath AccountStore::GetPath() const {
+  return profile_->GetPath().Append(FILE_PATH_LITERAL("metachat")).Append(FILE_PATH_LITERAL("accounts.json"));
+}
+std::vector<Account> AccountStore::LoadFromFile(const base::FilePath& path) {
+  std::string json;
+  if (!base::ReadFileToString(path, &json)) return {};
+  auto parsed = base::JSONReader::Read(json, base::JSON_PARSE_RFC);
+  if (!parsed || !parsed->is_list()) {
+    LOG(WARNING) << "AccountStore: invalid accounts.json";
+    return {};
+  }
+  return AccountListFromValue(parsed->GetList());
+}
+bool AccountStore::SaveToFile(const base::FilePath& path, const std::vector<Account>& accounts) {
+  base::CreateDirectory(path.DirName());
+  base::ListValue list = AccountListToValue(accounts);
+  std::string json;
+  base::JSONWriter::WriteWithOptions(list, base::JSONWriter::OPTIONS_PRETTY_PRINT, &json);
+  if (!base::WriteFile(path, json)) {
+    LOG(ERROR) << "AccountStore: failed to write " << path;
+    return false;
+  }
+  return true;
+}
+std::vector<Account> AccountStore::LoadAll() { return LoadFromFile(GetPath()); }
+bool AccountStore::SaveAll(const std::vector<Account>& accounts) { return SaveToFile(GetPath(), accounts); }
+}  // namespace metachat
