@@ -0,0 +1,43 @@
+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/cdp_bridge.h"
+#include "base/logging.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/strings/string_number_conversions.h"
+#include "content/public/browser/devtools_agent_host.h"
+#include "content/public/browser/web_contents.h"
+namespace metachat {
+CdpBridge::CdpBridge() = default;
+int CdpBridge::Attach(content::WebContents* web_contents) {
+  if (!web_contents) return -1;
+  attached_web_contents_ = web_contents;
+  // For MVP, we use an internal DevToolsAgentHost without starting a server.
+  // This allows SendCommand to work without exposing a TCP port.
+  port_ = 0;  // Attached internally
+  DVLOG(1) << "CdpBridge: attached to WebContents";
+  return port_;
+}
+void CdpBridge::Detach() {
+  attached_web_contents_ = nullptr;
+  port_ = -1;
+}
+base::Value::Dict CdpBridge::SendCommand(const std::string& method,
+                                          base::Value::Dict params) {
+  if (!attached_web_contents_) {
+    base::Value::Dict err;
+    err.Set("error", "not_attached");
+    return err;
+  }
+  auto host = content::DevToolsAgentHost::GetOrCreateFor(attached_web_contents_);
+  if (!host) {
+    base::Value::Dict err;
+    err.Set("error", "no_agent_host");
+    return err;
+  }
+  // DevToolsAgentHost::SendProtocolCommand dispatches to the page.
+  host->SendProtocolCommand(method, /*message_id=*/std::nullopt, std::move(params));
+  base::Value::Dict ok;
+  ok.Set("status", "sent");
+  return ok;
+}
+}  // namespace metachat
