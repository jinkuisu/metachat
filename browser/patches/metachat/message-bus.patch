@@ -0,0 +1,108 @@
+// Copyright 2025 The MetaChat Authors.
+#include "chrome/browser/ui/webui/metachat/window_manager.h"
+
+#include "base/files/file_path.h"
+#include "base/logging.h"
+#include "chrome/browser/profiles/profile_manager.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_finder.h"
+#include "chrome/browser/ui/browser_window.h"
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "chrome/browser/ui/views/frame/contents_container_view.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/views/controls/webview/webview.h"
+
+namespace metachat {
+
+WindowManager::WindowManager(Browser* browser)
+    : browser_(browser) {}
+
+WindowManager::~WindowManager() {
+  accounts_.clear();
+}
+
+void WindowManager::SwitchTo(const std::string& account_id,
+                              const GURL& url,
+                              const base::FilePath& profile_dir) {
+  if (!active_account_id_.empty() && accounts_.count(active_account_id_)) {
+    accounts_[active_account_id_].web_contents->WasHidden();
+  }
+  if (!accounts_.count(account_id)) {
+    ProfileManager* pm = g_browser_process->profile_manager();
+    Profile* profile = pm->GetProfile(profile_dir);
+    if (!profile) {
+      LOG(ERROR) << "WM: failed to create profile for " << account_id;
+      return;
+    }
+    content::WebContents::CreateParams params(profile);
+    auto wc = content::WebContents::Create(params);
+    content::NavigationController::LoadURLParams load_params(url);
+    load_params.transition_type = ui::PAGE_TRANSITION_TYPED;
+    wc->GetController().LoadURLWithParams(load_params);
+    accounts_[account_id] = {std::move(wc)};
+  }
+  BrowserView* bv = BrowserView::GetBrowserViewForBrowser(browser_);
+  views::WebView* overlay = bv->contents_container()->metachat_overlay_web_view();
+  if (!overlay) {
+    LOG(ERROR) << "WM: overlay not available";
+    return;
+  }
+  auto& entry = accounts_[account_id];
+  overlay->SetWebContents(entry.web_contents.get());
+  overlay->SetVisible(true);
+  entry.web_contents->WasShown();
+  entry.web_contents->Focus();
+  active_account_id_ = account_id;
+  DVLOG(1) << "WM: switched to " << account_id;
+}
+
+void WindowManager::Navigate(const std::string& account_id,
+                              const GURL& url) {
+  auto it = accounts_.find(account_id);
+  if (it == accounts_.end()) return;
+  content::NavigationController::LoadURLParams load_params(url);
+  it->second.web_contents->GetController().LoadURLWithParams(load_params);
+}
+
+void WindowManager::Close(const std::string& account_id) {
+  auto it = accounts_.find(account_id);
+  if (it == accounts_.end()) return;
+  if (it->second.web_contents && account_id == active_account_id_) {
+    BrowserView* bv = BrowserView::GetBrowserViewForBrowser(browser_);
+    views::WebView* overlay = bv->contents_container()->metachat_overlay_web_view();
+    if (overlay) {
+      overlay->SetWebContents(nullptr);
+      overlay->SetVisible(false);
+    }
+    it->second.web_contents->WasHidden();
+  }
+  accounts_.erase(it);
+  if (account_id == active_account_id_) active_account_id_.clear();
+  DVLOG(1) << "WM: closed " << account_id;
+}
+
+void WindowManager::ShowDashboard() {
+  BrowserView* bv = BrowserView::GetBrowserViewForBrowser(browser_);
+  views::WebView* overlay = bv->contents_container()->metachat_overlay_web_view();
+  if (overlay) {
+    if (!active_account_id_.empty() && accounts_.count(active_account_id_)) {
+      accounts_[active_account_id_].web_contents->WasHidden();
+    }
+    overlay->SetWebContents(nullptr);
+    overlay->SetVisible(false);
+  }
+  active_account_id_.clear();
+  DVLOG(1) << "WM: dashboard";
+}
+
+void WindowManager::OnResize() {}
+
+content::WebContents* WindowManager::GetWebContents(
+    const std::string& account_id) const {
+  auto it = accounts_.find(account_id);
+  return it != accounts_.end() ? it->second.web_contents.get() : nullptr;
+}
+
+}  // namespace metachat
+
