@@ -191,16 +199,38 @@ void OfflineAudioDestinationHandler::DoOfflineRendering() {
     uint32_t frames_available_to_copy = std::min(
         frames_to_process_, GetDeferredTaskHandler().RenderQuantumFrames());
 
+    // Per-seed audio fingerprint isolation, applied on EVERY platform
+    // including Mac. 2026-06-16: the previous `#if !BUILDFLAG(IS_MAC)`
+    // carve-out existed because AudioChannel::MutableSpan() SIGSEGV'd
+    // (NULL+0x60) during Apple-Silicon offline render — MutableSpan()
+    // calls ClearSilentFlag() and can hand back a span backed by the
+    // shared/never-materialized silent buffer. We now read through the
+    // const Span() into a reusable local scratch buffer, isolate THAT,
+    // and write to the shared target. That is exactly the set of
+    // operations the old Mac fallback already ran without crashing
+    // (Span() + copy_from), so audio isolation is finally live on Mac
+    // too — closing the Windows-persona-on-Mac audio fingerprint leak.
+    const uint64_t persona_seed =
+        blink::fingerprinting::Current().persona_seed;
     for (unsigned channel_index = 0; channel_index < number_of_channels;
          ++channel_index) {
+      auto channel_src = render_bus_->Channel(channel_index)
+                             ->Span()
+                             .first(frames_available_to_copy);
+      isolation_scratch.assign(channel_src.begin(), channel_src.end());
+      // Thread frames_processed_ as the global sample offset so the
+      // noise key never resets between render quanta — otherwise the
+      // per-quantum pattern repeats and the integrated the fingerprinter sum cancels.
+      blink::fingerprinting::IsolateAudioSamples(
+          base::span<float>(isolation_scratch), frames_processed_,
+          persona_seed);
       shared_render_target_->channels()[channel_index]
           .ByteSpan()
           .subspan(frames_processed_ * sizeof(float),
                    frames_available_to_copy * sizeof(float))
-          .copy_from(base::as_bytes(base::allow_nonunique_obj,
-                                    render_bus_->Channel(channel_index)
-                                        ->Span()
-                                        .first(frames_available_to_copy)));
+          .copy_from(
+              base::as_bytes(base::allow_nonunique_obj,
+                             base::span<const float>(isolation_scratch)));
     }
 
     frames_processed_ += frames_available_to_copy;
