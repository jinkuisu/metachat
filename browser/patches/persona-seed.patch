diff --git a/chrome/browser/chrome_content_browser_client.cc b/chrome/browser/chrome_content_browser_client.cc
index f3b2100ae4387..e97aa1176dc43 100644
--- a/chrome/browser/chrome_content_browser_client.cc
+++ b/chrome/browser/chrome_content_browser_client.cc
@@ -16,6 +16,7 @@
 #include <vector>
 
 #include "base/base_switches.h"
+#include "base/hash/hash.h"
 #include "base/byte_count.h"
 #include "base/check_deref.h"
 #include "base/check_op.h"
@@ -3156,6 +3157,26 @@ void ChromeContentBrowserClient::AppendExtraCommandLineSwitches(
                                     switches::kChangeStackGuardOnForkEnabled);
   }
 #endif  // BUILDFLAG(IS_LINUX) || BUILDFLAG(IS_CHROMEOS)
+
+  // MetaChat: per-profile fingerprint persona seed.
+  // Each profile derives a unique seed from its directory path.
+  // Same profile path -> same seed -> same fingerprint.
+  // Different profile -> different seed -> different fingerprint.
+  if (process_type == switches::kRendererProcess) {
+    content::RenderProcessHost* process =
+        content::RenderProcessHost::FromID(child_process_id);
+    if (process) {
+      Profile* profile =
+          Profile::FromBrowserContext(process->GetBrowserContext());
+      if (profile) {
+        command_line->AppendSwitchASCII(
+            switches::kPersonaSeed,
+            base::NumberToString(
+                base::PersistentHash(
+                    profile->GetPath().BaseName().AsUTF8Unsafe())));
+      }
+    }
+  }
 }
 
