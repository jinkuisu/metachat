+// Copyright (c) 2026 Arman Hossain <arman@bytetunnels.com>. ChromiumFish authors. All rights reserved.
+//
+// msgpack codec for the canvas-bridge wire protocol. Mirrors
+// `canvas-bridge/proto/src/lib.rs` so the server can decode what
+// we send.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
+#define THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
+
+#include <cstdint>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/containers/span.h"
+#include "third_party/blink/renderer/platform/allow_discouraged_type.h"
+#include "third_party/blink/renderer/platform/platform_export.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+
+namespace blink::canvas_bridge {
+
+constexpr uint32_t kProtocolVersion = 1;
+
+// Builder for outgoing ClientMsg frames. Each method allocates a new
+// msgpack-encoded buffer; callers ship the result over the WebSocket
+// binary channel.
+class PLATFORM_EXPORT MsgBuilder {
+ public:
+  static std::vector<uint8_t> Hello(const std::string& client_version,
+                                    uint64_t persona_seed);
+
+  static std::vector<uint8_t> CreateCanvas2D(uint32_t id,
+                                             uint32_t width,
+                                             uint32_t height,
+                                             bool opaque);
+
+  // Op-stream messages
+  static std::vector<uint8_t> SetFillStyleColor(uint32_t id, const String& css);
+  static std::vector<uint8_t> SetStrokeStyleColor(uint32_t id,
+                                                  const String& css);
+  static std::vector<uint8_t> SetFont(uint32_t id, const String& font);
+  static std::vector<uint8_t> SetTextAlign(uint32_t id, const String& align);
+  static std::vector<uint8_t> SetTextBaseline(uint32_t id,
+                                              const String& baseline);
+  static std::vector<uint8_t> FillRect(uint32_t id,
+                                       float x,
+                                       float y,
+                                       float w,
+                                       float h);
+  static std::vector<uint8_t> StrokeRect(uint32_t id,
+                                         float x,
+                                         float y,
+                                         float w,
+                                         float h);
+  static std::vector<uint8_t> FillText(uint32_t id,
+                                       const String& text,
+                                       float x,
+                                       float y,
+                                       std::optional<float> max_width);
+  static std::vector<uint8_t> StrokeText(uint32_t id,
+                                         const String& text,
+                                         float x,
+                                         float y,
+                                         std::optional<float> max_width);
+
+  // No-arg ops
+  static std::vector<uint8_t> Save(uint32_t id);
+  static std::vector<uint8_t> Restore(uint32_t id);
+  static std::vector<uint8_t> BeginPath(uint32_t id);
+  static std::vector<uint8_t> ClosePath(uint32_t id);
+  static std::vector<uint8_t> Fill(uint32_t id);
+  static std::vector<uint8_t> Stroke(uint32_t id);
+
+  // Geometry
+  static std::vector<uint8_t> ClearRect(uint32_t id, float x, float y,
+                                         float w, float h);
+  static std::vector<uint8_t> MoveTo(uint32_t id, float x, float y);
+  static std::vector<uint8_t> LineTo(uint32_t id, float x, float y);
+  static std::vector<uint8_t> Rect(uint32_t id, float x, float y,
+                                    float w, float h);
+  static std::vector<uint8_t> Arc(uint32_t id, float x, float y, float r,
+                                   float start, float end,
+                                   bool counter_clockwise);
+  static std::vector<uint8_t> QuadraticCurveTo(uint32_t id,
+                                                float cpx, float cpy,
+                                                float x, float y);
+  static std::vector<uint8_t> BezierCurveTo(uint32_t id,
+                                             float cp1x, float cp1y,
+                                             float cp2x, float cp2y,
+                                             float x, float y);
+
+  // Transform
+  static std::vector<uint8_t> SetTransform(uint32_t id,
+                                            float a, float b, float c,
+                                            float d, float e, float f);
+  static std::vector<uint8_t> Translate(uint32_t id, float x, float y);
+  static std::vector<uint8_t> Rotate(uint32_t id, float angle);
+  static std::vector<uint8_t> Scale(uint32_t id, float x, float y);
+
+  // Misc state
+  static std::vector<uint8_t> SetGlobalAlpha(uint32_t id, float alpha);
+  static std::vector<uint8_t> SetGlobalCompositeOperation(uint32_t id,
+                                                          const String& op);
+  static std::vector<uint8_t> SetLineWidth(uint32_t id, float width);
+  static std::vector<uint8_t> SetDirection(uint32_t id, const String& dir);
+
+  // Readback
+  static std::vector<uint8_t> GetCanvas2DImageData(uint32_t id,
+                                                   int32_t x,
+                                                   int32_t y,
+                                                   uint32_t w,
+                                                   uint32_t h);
+  static std::vector<uint8_t> DestroyCanvas(uint32_t id);
+
+  // Font metrics. Standalone request (no canvas id) — server picks the
+  // first family from `families` that resolves and returns metrics for
+  // every (family, size) pair. We pass a 1-element families/sizes vector
+  // so the reply is a single TextMetric.
+  static std::vector<uint8_t> MeasureText(const String& text,
+                                          const String& family,
+                                          float size_px);
+
+  /* =========================================================================
+   * WebGL bridge ops. Mirrors WebGLOp in canvas-bridge/proto/src/lib.rs.
+   * Subset chosen to cover what fpjs Pro / CF Turnstile probe: state
+   * setup, shader compile + program link, attribute + uniform binding,
+   * draw, readPixels. Each op refers to a CanvasId created via CreateWebGL
+   * (vs CreateCanvas2D for 2D contexts). The client draws both kinds from a
+   * single global AllocateCanvasId() pool, so the ids are unique across the
+   * two; CreateWebGL just tells the server which surface kind to instantiate.
+   * ========================================================================= */
+  static std::vector<uint8_t> CreateWebGL(uint32_t id,
+                                          uint32_t width,
+                                          uint32_t height,
+                                          bool alpha,
+                                          bool depth,
+                                          bool stencil,
+                                          bool antialias,
+                                          bool premultiplied_alpha,
+                                          bool preserve_drawing_buffer,
+                                          bool fail_if_major_performance_caveat,
+                                          uint8_t version);
+
+  // State / clear / viewport
+  static std::vector<uint8_t> WebGLClearColor(uint32_t id,
+                                              float r, float g, float b, float a);
+  static std::vector<uint8_t> WebGLClear(uint32_t id, uint32_t mask);
+  static std::vector<uint8_t> WebGLEnable(uint32_t id, uint32_t cap);
+  static std::vector<uint8_t> WebGLDisable(uint32_t id, uint32_t cap);
+  static std::vector<uint8_t> WebGLViewport(uint32_t id,
+                                            int32_t x, int32_t y,
+                                            int32_t w, int32_t h);
+
+  // Programs + shaders
+  static std::vector<uint8_t> WebGLCreateProgram(uint32_t id, uint32_t handle);
+  static std::vector<uint8_t> WebGLCreateShader(uint32_t id,
+                                                uint32_t handle, uint32_t type);
+  static std::vector<uint8_t> WebGLShaderSource(uint32_t id,
+                                                uint32_t shader,
+                                                const std::string& source);
+  static std::vector<uint8_t> WebGLCompileShader(uint32_t id, uint32_t shader);
+  static std::vector<uint8_t> WebGLAttachShader(uint32_t id,
+                                                uint32_t program, uint32_t shader);
+  static std::vector<uint8_t> WebGLLinkProgram(uint32_t id, uint32_t program);
+  static std::vector<uint8_t> WebGLUseProgram(uint32_t id, uint32_t program);
+
+  // Buffers
+  static std::vector<uint8_t> WebGLCreateBuffer(uint32_t id, uint32_t handle);
+  static std::vector<uint8_t> WebGLBindBuffer(uint32_t id,
+                                              uint32_t target, uint32_t buffer);
+  static std::vector<uint8_t> WebGLBufferData(uint32_t id,
+                                              uint32_t target,
+                                              base::span<const uint8_t> data,
+                                              uint32_t usage);
+
+  // Attribs
+  static std::vector<uint8_t> WebGLGetAttribLocation(uint32_t id,
+                                                     uint32_t program,
+                                                     const std::string& name,
+                                                     uint32_t slot);
+  static std::vector<uint8_t> WebGLEnableVertexAttribArray(uint32_t id,
+                                                           uint32_t index);
+  static std::vector<uint8_t> WebGLVertexAttribPointer(uint32_t id,
+                                                       uint32_t index,
+                                                       int32_t size,
+                                                       uint32_t type,
+                                                       bool normalized,
+                                                       int32_t stride,
+                                                       int32_t offset);
+
+  // Draw
+  static std::vector<uint8_t> WebGLDrawArrays(uint32_t id,
+                                              uint32_t mode,
+                                              int32_t first, int32_t count);
+  static std::vector<uint8_t> WebGLDrawElements(uint32_t id,
+                                                uint32_t mode,
+                                                int32_t count,
+                                                uint32_t type,
+                                                int32_t offset);
+
+  // Readback (returns ImageData reply; caller blocks via existing pattern).
+  static std::vector<uint8_t> WebGLReadPixels(uint32_t id,
+                                              int32_t x, int32_t y,
+                                              uint32_t w, uint32_t h,
+                                              uint32_t format, uint32_t type);
+};
+
+// Parsed result of a `TextMetrics` server reply.
+struct PLATFORM_EXPORT TextMetricReply {
+  float width;
+  float actual_bounding_box_ascent;
+  float actual_bounding_box_descent;
+  float font_bounding_box_ascent;
+  float font_bounding_box_descent;
+};
+
+// Parsed result of an `ImageData` server reply.
+struct PLATFORM_EXPORT ImageDataReply {
+  uint32_t canvas_id;
+  uint32_t width;
+  uint32_t height;
+  // RGBA8, premultiplied per canvas spec. std::vector instead of
+  // blink::Vector because the same struct round-trips through the
+  // platform/network layer which uses std-only containers.
+  std::vector<uint8_t> pixels
+      ALLOW_DISCOURAGED_TYPE("interop with canvas-bridge wire codec");
+};
+
+// Parsed result of a `Welcome` server reply.
+struct PLATFORM_EXPORT WelcomeReply {
+  uint32_t protocol_version;
+  std::string server_version;
+  std::string os;
+  std::string gpu_renderer;
+  std::string gpu_vendor;
+};
+
+class PLATFORM_EXPORT MsgParser {
+ public:
+  // Returns `std::nullopt` if `frame` is not a Welcome message or is
+  // malformed.
+  static std::optional<WelcomeReply> ParseWelcome(
+      base::span<const uint8_t> frame);
+
+  // Returns nullopt if `frame` is not an ImageData reply.
+  static std::optional<ImageDataReply> ParseImageData(
+      base::span<const uint8_t> frame);
+
+  // Returns nullopt if `frame` is not a TextMetrics reply or is
+  // malformed. The bridge issues a 1-family × 1-size request so the
+  // reply contains exactly one metric.
+  static std::optional<TextMetricReply> ParseTextMetrics(
+      base::span<const uint8_t> frame);
+};
+
+}  // namespace blink::canvas_bridge
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CODEC_H_
