+}
+
+std::vector<uint8_t> MsgBuilder::ClearRect(uint32_t id,
+                                            float x,
+                                            float y,
+                                            float w_,
+                                            float h_) {
+  Writer w;
+  WriteCanvas2DOpHeader(w, id, "ClearRect");
+  w.BeginMap(4);
+  w.Str("x"); w.Float32(x);
+  w.Str("y"); w.Float32(y);
+  w.Str("w"); w.Float32(w_);
+  w.Str("h"); w.Float32(h_);
