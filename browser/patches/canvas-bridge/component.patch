+std::vector<uint8_t> MsgBuilder::SetTextBaseline(uint32_t id,
+                                                  const String& baseline) {
+  Writer w;
+  WriteCanvas2DOpHeader(w, id, "SetTextBaseline");
+  w.StrUtf8(baseline);
+  return std::move(w).Take();
+}
