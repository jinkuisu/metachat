+namespace {
+// Mirrors WriteCanvas2DOpHeader but with a WebGLOp envelope.
+void WriteWebGLOpHeader(Writer& w, uint32_t id, const char* op_name) {
+  w.StartEnvelope("WebGLOp");
+  w.BeginMap(2);
+  w.Str("id");
+  w.Uint(id);
+  w.Str("op");
+  w.BeginMap(2);
+  w.Str("op");
+  w.Str(op_name);
+  w.Str("args");
+}
+}  // namespace
+
+std::vector<uint8_t> MsgBuilder::CreateWebGL(
+    uint32_t id, uint32_t width, uint32_t height,
+    bool alpha, bool depth, bool stencil, bool antialias,
+    bool premultiplied_alpha, bool preserve_drawing_buffer,
+    bool fail_if_major_performance_caveat, uint8_t version) {
+  Writer w;
+  w.StartEnvelope("CreateWebGL");
+  w.BeginMap(5);
+  w.Str("id");                w.Uint(id);
+  w.Str("width");             w.Uint(width);
+  w.Str("height");            w.Uint(height);
+  w.Str("attrs");
+  w.BeginMap(7);
+  w.Str("alpha");                            w.Bool(alpha);
+  w.Str("depth");                            w.Bool(depth);
+  w.Str("stencil");                          w.Bool(stencil);
+  w.Str("antialias");                        w.Bool(antialias);
+  w.Str("premultiplied_alpha");              w.Bool(premultiplied_alpha);
+  w.Str("preserve_drawing_buffer");          w.Bool(preserve_drawing_buffer);
+  w.Str("fail_if_major_performance_caveat"); w.Bool(fail_if_major_performance_caveat);
+  w.Str("version");           w.Uint(version);
+  return std::move(w).Take();
+}
