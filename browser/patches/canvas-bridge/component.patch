+}
+std::vector<uint8_t> MsgBuilder::Fill(uint32_t id) {
+  Writer w; WriteCanvas2DOpHeader(w, id, "Fill"); w.Null();
+  return std::move(w).Take();
+}
+std::vector<uint8_t> MsgBuilder::Stroke(uint32_t id) {
