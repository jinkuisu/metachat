+std::vector<uint8_t> MsgBuilder::StrokeRect(uint32_t id,
+                                             float x,
+                                             float y,
+                                             float w_,
+                                             float h_) {
+  Writer w;
+  WriteCanvas2DOpHeader(w, id, "StrokeRect");
+  w.BeginMap(4);
+  w.Str("x");
+  w.Float32(x);
+  w.Str("y");
+  w.Float32(y);
+  w.Str("w");
+  w.Float32(w_);
