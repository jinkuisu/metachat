+std::vector<uint8_t> MsgBuilder::WebGLCreateProgram(uint32_t id, uint32_t handle) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "CreateProgram");
+  w.BeginMap(1);
+  w.Str("handle"); w.Uint(handle);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLCreateShader(
+    uint32_t id, uint32_t handle, uint32_t type) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "CreateShader");
+  w.BeginMap(2);
+  w.Str("handle"); w.Uint(handle);
+  w.Str("ty"); w.Uint(type);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLShaderSource(
+    uint32_t id, uint32_t shader, const std::string& source) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "ShaderSource");
+  w.BeginMap(2);
+  w.Str("shader"); w.Uint(shader);
+  w.Str("source"); w.Str(source);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLCompileShader(uint32_t id, uint32_t shader) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "CompileShader");
+  w.BeginMap(1);
+  w.Str("shader"); w.Uint(shader);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLAttachShader(
+    uint32_t id, uint32_t program, uint32_t shader) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "AttachShader");
+  w.BeginMap(2);
+  w.Str("program"); w.Uint(program);
+  w.Str("shader");  w.Uint(shader);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLLinkProgram(uint32_t id, uint32_t program) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "LinkProgram");
+  w.BeginMap(1);
+  w.Str("program"); w.Uint(program);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLUseProgram(uint32_t id, uint32_t program) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "UseProgram");
+  w.BeginMap(1);
+  w.Str("program"); w.Uint(program);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLCreateBuffer(uint32_t id, uint32_t handle) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "CreateBuffer");
+  w.BeginMap(1);
+  w.Str("handle"); w.Uint(handle);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLBindBuffer(
+    uint32_t id, uint32_t target, uint32_t buffer) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "BindBuffer");
+  w.BeginMap(2);
+  w.Str("target"); w.Uint(target);
+  w.Str("buffer"); w.Uint(buffer);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLBufferData(
+    uint32_t id, uint32_t target, base::span<const uint8_t> data, uint32_t usage) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "BufferData");
+  w.BeginMap(3);
+  w.Str("target"); w.Uint(target);
+  w.Str("data");   w.Bin(data.data(), data.size());
+  w.Str("usage");  w.Uint(usage);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLGetAttribLocation(
+    uint32_t id, uint32_t program, const std::string& name, uint32_t slot) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "GetAttribLocation");
+  w.BeginMap(3);
+  w.Str("program"); w.Uint(program);
+  w.Str("name");    w.Str(name);
+  w.Str("slot");    w.Uint(slot);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLEnableVertexAttribArray(
+    uint32_t id, uint32_t index) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "EnableVertexAttribArray");
+  w.Uint(index);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLVertexAttribPointer(
+    uint32_t id, uint32_t index, int32_t size, uint32_t type,
+    bool normalized, int32_t stride, int32_t offset) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "VertexAttribPointer");
+  w.BeginMap(6);
+  w.Str("index");      w.Uint(index);
+  w.Str("size");       w.Int32(size);
+  w.Str("ty");         w.Uint(type);
+  w.Str("normalized"); w.Bool(normalized);
+  w.Str("stride");     w.Int32(stride);
+  w.Str("offset");     w.Int32(offset);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLDrawArrays(
+    uint32_t id, uint32_t mode, int32_t first, int32_t count) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "DrawArrays");
+  w.BeginMap(3);
+  w.Str("mode");  w.Uint(mode);
+  w.Str("first"); w.Int32(first);
+  w.Str("count"); w.Int32(count);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLDrawElements(
+    uint32_t id, uint32_t mode, int32_t count, uint32_t type, int32_t offset) {
+  Writer w;
+  WriteWebGLOpHeader(w, id, "DrawElements");
+  w.BeginMap(4);
+  w.Str("mode");   w.Uint(mode);
+  w.Str("count");  w.Int32(count);
+  w.Str("ty");     w.Uint(type);
+  w.Str("offset"); w.Int32(offset);
+  return std::move(w).Take();
+}
+
+std::vector<uint8_t> MsgBuilder::WebGLReadPixels(
+    uint32_t id, int32_t x, int32_t y, uint32_t w_, uint32_t h_,
+    uint32_t format, uint32_t type) {
+  Writer w;
+  w.StartEnvelope("WebGLReadPixels");
+  w.BeginMap(7);
+  w.Str("id");     w.Uint(id);
+  w.Str("x");      w.Int32(x);
+  w.Str("y");      w.Int32(y);
+  w.Str("w");      w.Uint(w_);
+  w.Str("h");      w.Uint(h_);
+  w.Str("format"); w.Uint(format);
+  w.Str("ty");     w.Uint(type);
+  return std::move(w).Take();
+}
+
+}  // namespace blink::canvas_bridge
