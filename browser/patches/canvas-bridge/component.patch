+std::vector<uint8_t> MsgBuilder::FillRect(uint32_t id,
+                                           float x,
+                                           float y,
+                                           float w_,
+                                           float h_) {
+  Writer w;
+  WriteCanvas2DOpHeader(w, id, "FillRect");
