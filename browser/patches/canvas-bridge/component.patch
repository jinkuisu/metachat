@@ -0,0 +1,550 @@
+// Copyright (c) 2026 Arman Hossain <arman@bytetunnels.com>. ChromiumFish authors. All rights reserved.
+
+#ifdef UNSAFE_BUFFERS_BUILD
+// TODO(chromiumfish): self-contained WebSocket framing uses raw byte buffers.
+#pragma allow_unsafe_buffers
+#endif
+
+#include "third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_client.h"
+
+#include <fcntl.h>
+#include <netdb.h>
+#include <netinet/in.h>
+#include <netinet/tcp.h>
+#include <sys/socket.h>
+#include <unistd.h>
+
+#include <cstring>
+
+#include "base/base64.h"
+#include "base/command_line.h"
+#include "third_party/blink/public/common/fingerprinting/fingerprint_profile.h"
+#include "base/functional/bind.h"
+#include "base/hash/sha1.h"
+#include "base/logging.h"
+#include "base/rand_util.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "base/strings/stringprintf.h"
+#include "components/canvas_bridge/public/canvas_bridge_switches.h"
+
+// Self-contained raw TCP + WebSocket framing. POSIX sockets only —
+// this is renderer-process I/O on its own thread, so we don't go
+// through the network service.  No TLS yet (use ws://, run over
+// Tailscale / SSH tunnel / private network).
+
+namespace blink::canvas_bridge {
+
+namespace {
+
+bool ReadSwitches(std::string* url, std::string* auth) {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd->HasSwitch(::canvas_bridge::switches::kCanvasBridgeUrl)) {
+    return false;
+  }
+  *url = cmd->GetSwitchValueASCII(::canvas_bridge::switches::kCanvasBridgeUrl);
+  if (cmd->HasSwitch(::canvas_bridge::switches::kCanvasBridgeAuth)) {
+    *auth =
+        cmd->GetSwitchValueASCII(::canvas_bridge::switches::kCanvasBridgeAuth);
+  }
+  return !url->empty() && !auth->empty();
+}
+
+// Parse ws://host[:port][/path]. Returns false on malformed input.
+bool ParseWsUrl(const std::string& url,
+                std::string* host,
+                int* port,
+                std::string* path) {
+  std::string remainder;
+  if (url.rfind("ws://", 0) == 0) {
+    remainder = url.substr(5);
+    *port = 80;
+  } else if (url.rfind("wss://", 0) == 0) {
+    // TLS not supported in this minimal impl. Caller should be aware
+    // and use ws:// over a Tailscale/SSH-encrypted underlying path.
+    LOG(WARNING) << "[canvas-bridge] wss:// requested but not implemented; "
+                 << "falling back to plaintext ws://";
+    remainder = url.substr(6);
+    *port = 443;
+  } else {
+    return false;
+  }
+  size_t slash = remainder.find('/');
+  std::string host_port =
+      (slash == std::string::npos) ? remainder : remainder.substr(0, slash);
+  *path = (slash == std::string::npos) ? "/" : remainder.substr(slash);
+  size_t colon = host_port.find(':');
+  if (colon == std::string::npos) {
+    *host = host_port;
+  } else {
+    *host = host_port.substr(0, colon);
+    *port = std::atoi(host_port.substr(colon + 1).c_str());
+  }
+  return !host->empty() && *port > 0 && *port < 65536;
+}
+
+// Resolve + TCP connect. Returns fd on success, -1 on failure.
+int TcpConnect(const std::string& host, int port) {
+  struct addrinfo hints {};
+  hints.ai_family = AF_UNSPEC;
+  hints.ai_socktype = SOCK_STREAM;
+  struct addrinfo* res = nullptr;
+  std::string port_str = base::NumberToString(port);
+  if (getaddrinfo(host.c_str(), port_str.c_str(), &hints, &res) != 0) {
+    return -1;
+  }
+  int fd = -1;
+  for (struct addrinfo* p = res; p; p = p->ai_next) {
+    fd = socket(p->ai_family, p->ai_socktype, p->ai_protocol);
+    if (fd < 0) continue;
+    if (connect(fd, p->ai_addr, p->ai_addrlen) == 0) {
+      // Disable Nagle for the small ops we send.
+      int flag = 1;
+      setsockopt(fd, IPPROTO_TCP, TCP_NODELAY, &flag, sizeof(flag));
+      break;
+    }
+    close(fd);
+    fd = -1;
+  }
+  freeaddrinfo(res);
+  return fd;
+}
+
+bool WriteAll(int fd, const uint8_t* data, size_t len) {
+  size_t off = 0;
+  while (off < len) {
+    ssize_t n = send(fd, data + off, len - off, 0);
+    if (n <= 0) {
+      if (errno == EINTR) continue;
+      return false;
+    }
+    off += static_cast<size_t>(n);
+  }
+  return true;
+}
+
+bool ReadAll(int fd, uint8_t* buf, size_t len) {
+  size_t off = 0;
+  while (off < len) {
+    ssize_t n = recv(fd, buf + off, len - off, 0);
+    if (n == 0) return false;  // EOF
+    if (n < 0) {
+      if (errno == EINTR) continue;
+      return false;
+    }
+    off += static_cast<size_t>(n);
+  }
+  return true;
+}
+
+// Read until \r\n\r\n (HTTP response head). Returns the full text or
+// empty on failure.
+std::string ReadHttpHead(int fd) {
+  std::string buf;
+  uint8_t b;
+  while (true) {
+    ssize_t n = recv(fd, &b, 1, 0);
+    if (n <= 0) {
+      if (n < 0 && errno == EINTR) continue;
+      return {};
+    }
+    buf.push_back(static_cast<char>(b));
+    if (buf.size() >= 4 && buf.substr(buf.size() - 4) == "\r\n\r\n") {
+      return buf;
+    }
+    if (buf.size() > 16 * 1024) {
+      return {};  // sanity cap
+    }
+  }
+}
+
+// RFC 6455 frame writer (client→server, always masked).
+bool WriteWsBinaryFrame(int fd, const uint8_t* payload, size_t len) {
+  uint8_t hdr[14];
+  size_t hdr_len = 0;
+  hdr[hdr_len++] = 0x82;  // FIN + binary
+  uint8_t mask_bit = 0x80;
+  if (len < 126) {
+    hdr[hdr_len++] = mask_bit | static_cast<uint8_t>(len);
+  } else if (len <= 0xFFFF) {
+    hdr[hdr_len++] = mask_bit | 126;
+    hdr[hdr_len++] = (len >> 8) & 0xFF;
+    hdr[hdr_len++] = len & 0xFF;
+  } else {
+    hdr[hdr_len++] = mask_bit | 127;
+    for (int i = 7; i >= 0; --i) {
+      hdr[hdr_len++] = (len >> (i * 8)) & 0xFF;
+    }
+  }
+  uint8_t mask[4];
+  base::RandBytes(mask);
+  std::memcpy(hdr + hdr_len, mask, 4);
+  hdr_len += 4;
+  if (!WriteAll(fd, hdr, hdr_len)) return false;
+
+  // Mask + send payload in 4 KB chunks.
+  std::vector<uint8_t> chunk(4096);
+  size_t off = 0;
+  while (off < len) {
+    size_t n = std::min(chunk.size(), len - off);
+    for (size_t i = 0; i < n; ++i) {
+      chunk[i] = payload[off + i] ^ mask[(off + i) & 3];
+    }
+    if (!WriteAll(fd, chunk.data(), n)) return false;
+    off += n;
+  }
+  return true;
+}
+
+// Read one full WebSocket frame; returns the payload. opcode is set
+// on success. Returns false on EOF / error.
+bool ReadWsFrame(int fd, std::vector<uint8_t>* payload, uint8_t* opcode) {
+  uint8_t h[2];
+  if (!ReadAll(fd, h, 2)) return false;
+  bool fin = h[0] & 0x80;
+  *opcode = h[0] & 0x0F;
+  bool masked = h[1] & 0x80;
+  uint64_t plen = h[1] & 0x7F;
+  if (plen == 126) {
+    uint8_t b[2];
+    if (!ReadAll(fd, b, 2)) return false;
+    plen = (static_cast<uint64_t>(b[0]) << 8) | b[1];
+  } else if (plen == 127) {
+    uint8_t b[8];
+    if (!ReadAll(fd, b, 8)) return false;
+    plen = 0;
+    for (int i = 0; i < 8; ++i) {
+      plen = (plen << 8) | b[i];
+    }
+  }
+  uint8_t mask[4] = {0};
+  if (masked && !ReadAll(fd, mask, 4)) return false;
+  payload->resize(static_cast<size_t>(plen));
+  if (plen > 0 && !ReadAll(fd, payload->data(), payload->size())) return false;
+  if (masked) {
+    for (size_t i = 0; i < payload->size(); ++i) {
+      (*payload)[i] ^= mask[i & 3];
+    }
+  }
+  if (!fin) {
+    // Read continuation frames (rare; servers usually don't fragment)
+    while (true) {
+      uint8_t cont_op = 0;
+      std::vector<uint8_t> next;
+      if (!ReadWsFrame(fd, &next, &cont_op)) return false;
+      payload->insert(payload->end(), next.begin(), next.end());
+      if (cont_op == 0x80) break;  // FIN set on next (cont_op was masked)
+      // For simplicity: any subsequent frame ends the message in our case.
+      break;
+    }
+  }
+  return true;
+}
+
+}  // namespace
+
+CanvasBridgeClient* CanvasBridgeClient::Get() {
+  static base::NoDestructor<CanvasBridgeClient> kSingleton;
+  return kSingleton.get();
+}
+
+CanvasBridgeClient::CanvasBridgeClient() {
+  StartUp();
+}
+
+CanvasBridgeClient::~CanvasBridgeClient() = default;
+
+void CanvasBridgeClient::StartUp() {
+  State expected = State::kUninitialized;
+  if (!state_.compare_exchange_strong(expected, State::kConnecting)) {
+    return;
+  }
+  if (!ReadSwitches(&url_, &auth_)) {
+    Disable("--canvas-bridge-url / --canvas-bridge-auth not set");
+    return;
+  }
+  // Lightweight-fork: pull the persona seed from the fingerprinting profile
+  // so the server sees a non-zero seed and can isolate per-persona render
+  // state (different seeds get different per-pixel noise, font hint
+  // variants, etc.). Without this the server was getting persona_seed=0
+  // for every session, making all fork instances render identically.
+  persona_seed_ = fingerprinting::Current().persona_seed;
+  io_thread_ = std::make_unique<base::Thread>("canvas-bridge-io");
+  base::Thread::Options opts;
+  opts.message_pump_type = base::MessagePumpType::IO;
+  if (!io_thread_->StartWithOptions(std::move(opts))) {
+    Disable("failed to start canvas-bridge I/O thread");
+    return;
+  }
+  io_thread_->task_runner()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&CanvasBridgeClient::IoThreadLoop, base::Unretained(this)));
+}
+
+void CanvasBridgeClient::IoThreadLoop() {
+  if (!DoConnect(url_, auth_)) {
+    Disable("canvas-bridge server unreachable / handshake failed");
+    return;
+  }
+  state_.store(State::kReady);
+  LOG(INFO) << "[canvas-bridge] connected to " << url_;
+  // Sends an Hello, waits for Welcome, then loops reading frames
+  // forever. Currently Hello is sent inside DoConnect.
+  ReadLoop();
+}
+
+bool CanvasBridgeClient::DoConnect(const std::string& url,
+                                   const std::string& auth) {
+  std::string host, path;
+  int port = 80;
+  if (!ParseWsUrl(url, &host, &port, &path)) {
+    LOG(WARNING) << "[canvas-bridge] bad URL: " << url;
+    return false;
+  }
+  int fd = TcpConnect(host, port);
+  if (fd < 0) {
+    LOG(WARNING) << "[canvas-bridge] TCP connect to " << host << ":" << port
+                 << " failed: " << std::strerror(errno);
+    return false;
+  }
+
+  // Build HTTP/1.1 Upgrade request.
+  uint8_t key_raw[16];
+  base::RandBytes(key_raw);
+  std::string key_b64 =
+      base::Base64Encode(std::string(reinterpret_cast<char*>(key_raw), 16));
+  std::string auth_b64 = base::Base64Encode(auth);
+  std::string req = base::StringPrintf(
+      "GET %s HTTP/1.1\r\n"
+      "Host: %s:%d\r\n"
+      "Upgrade: websocket\r\n"
+      "Connection: Upgrade\r\n"
+      "Sec-WebSocket-Key: %s\r\n"
+      "Sec-WebSocket-Version: 13\r\n"
+      "Authorization: Basic %s\r\n"
+      "\r\n",
+      path.c_str(), host.c_str(), port, key_b64.c_str(), auth_b64.c_str());
+  if (!WriteAll(fd, reinterpret_cast<const uint8_t*>(req.data()), req.size())) {
+    close(fd);
+    return false;
+  }
+
+  std::string resp = ReadHttpHead(fd);
+  if (resp.empty() || resp.find("101") == std::string::npos) {
+    LOG(WARNING) << "[canvas-bridge] handshake rejected: "
+                 << resp.substr(0, 120);
+    close(fd);
+    return false;
+  }
+  // Verify Sec-WebSocket-Accept (best-effort; server already validated).
+  std::string magic = key_b64 + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11";
+  auto digest = base::SHA1Hash(base::as_byte_span(magic));
+  std::string expected = base::Base64Encode(digest);
+  if (resp.find(expected) == std::string::npos) {
+    LOG(WARNING) << "[canvas-bridge] Sec-WebSocket-Accept mismatch";
+    close(fd);
+    return false;
+  }
+
+  socket_fd_ = fd;
+
+  // Send Hello frame, expect a Welcome reply (logged for diagnostics).
+  auto hello = MsgBuilder::Hello("chromiumfish/0.1", persona_seed_);
+  if (!WriteWsBinaryFrame(socket_fd_, hello.data(), hello.size())) {
+    LOG(WARNING) << "[canvas-bridge] Hello send failed";
+    close(socket_fd_);
+    socket_fd_ = -1;
+    return false;
+  }
+  std::vector<uint8_t> welcome_buf;
+  uint8_t opcode = 0;
+  if (!ReadWsFrame(socket_fd_, &welcome_buf, &opcode) || opcode != 0x2) {
+    LOG(WARNING) << "[canvas-bridge] no Welcome reply";
+    close(socket_fd_);
+    socket_fd_ = -1;
+    return false;
+  }
+  auto welcome = MsgParser::ParseWelcome(welcome_buf);
+  if (welcome.has_value()) {
+    LOG(INFO) << "[canvas-bridge] server " << welcome->server_version
+              << " os=" << welcome->os
+              << " gpu=" << welcome->gpu_vendor << "/" << welcome->gpu_renderer
+              << " proto=" << welcome->protocol_version;
+  }
+  return true;
+}
+
+void CanvasBridgeClient::SendOnIoThread(std::vector<uint8_t> frame) {
+  // Called inline from the renderer thread (not posted) because the I/O
+  // thread is blocked in ReadLoop. write_lock_ serializes concurrent
+  // writers.
+  base::AutoLock lock(write_lock_);
+  int fd = socket_fd_;
+  if (fd < 0) return;
+  if (!WriteWsBinaryFrame(fd, frame.data(), frame.size())) {
+    LOG(WARNING) << "[canvas-bridge] send failed; disabling";
+    Disable("socket write failed");
+    close(fd);
+    socket_fd_ = -1;
+  }
+}
+
+void CanvasBridgeClient::ReadLoop() {
+  while (state_.load() == State::kReady && socket_fd_ >= 0) {
+    std::vector<uint8_t> payload;
+    uint8_t opcode = 0;
+    if (!ReadWsFrame(socket_fd_, &payload, &opcode)) {
+      LOG(INFO) << "[canvas-bridge] socket closed by server";
+      Disable("server closed connection");
+      close(socket_fd_);
+      socket_fd_ = -1;
+      break;
+    }
+    if (opcode == 0x8) {  // close
+      Disable("server sent close");
+      close(socket_fd_);
+      socket_fd_ = -1;
+      break;
+    }
+    if (opcode == 0x9 || opcode == 0xA) {
+      // ping/pong — handled silently for our use case
+      continue;
+    }
+    HandleIncoming(payload);
+  }
+}
+
+void CanvasBridgeClient::HandleIncoming(const std::vector<uint8_t>& frame) {
+  if (auto img = MsgParser::ParseImageData(frame); img.has_value()) {
+    base::AutoLock lock(pending_lock_);
+    auto it = pending_replies_.find(img->canvas_id);
+    if (it == pending_replies_.end()) return;
+    it->second->reply = std::move(*img);
+    it->second->fulfilled = true;
+    it->second->done.Signal();
+    return;
+  }
+  if (auto tm = MsgParser::ParseTextMetrics(frame); tm.has_value()) {
+    base::AutoLock lock(pending_lock_);
+    if (!pending_text_metric_) return;
+    pending_text_metric_->reply = *tm;
+    pending_text_metric_->fulfilled = true;
+    pending_text_metric_->done.Signal();
+    return;
+  }
+  // Unknown / error messages are dropped silently.
+}
+
+uint32_t CanvasBridgeClient::AllocateCanvasId() {
+  if (!IsEnabled()) {
+    return 0;
+  }
+  return next_canvas_id_.fetch_add(1);
+}
+
+void CanvasBridgeClient::Send(std::vector<uint8_t> frame) {
+  if (!IsEnabled()) return;
+  // Write inline; ReadLoop owns the I/O thread, so posting there would
+  // deadlock until a server frame arrives.
+  SendOnIoThread(std::move(frame));
+}
+
+std::optional<ImageDataReply> CanvasBridgeClient::RequestImageData(
+    uint32_t canvas_id,
+    int32_t x,
+    int32_t y,
+    uint32_t w,
+    uint32_t h,
+    int timeout_ms) {
+  if (!IsEnabled()) {
+    return std::nullopt;
+  }
+  PendingReadback pending;
+  pending.canvas_id = canvas_id;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_replies_[canvas_id] = &pending;
+  }
+  // Send the request through the I/O thread queue.
+  Send(MsgBuilder::GetCanvas2DImageData(canvas_id, x, y, w, h));
+  bool ok = pending.done.TimedWait(base::Milliseconds(timeout_ms));
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_replies_.erase(canvas_id);
+  }
+  if (!ok || !pending.fulfilled) {
+    return std::nullopt;
+  }
+  return pending.reply;
+}
+
+std::optional<ImageDataReply> CanvasBridgeClient::RequestWebGLPixels(
+    uint32_t webgl_id,
+    int32_t x,
+    int32_t y,
+    uint32_t w,
+    uint32_t h,
+    uint32_t format,
+    uint32_t type,
+    int timeout_ms) {
+  // Reuses the same pending_replies_ machinery as RequestImageData. The
+  // server returns an `ImageData` reply tagged with the canvas id, so as
+  // long as WebGL ids and Canvas2D ids are drawn from the same
+  // AllocateCanvasId() pool (they are), the dispatch routes correctly.
+  if (!IsEnabled()) {
+    return std::nullopt;
+  }
+  PendingReadback pending;
+  pending.canvas_id = webgl_id;
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_replies_[webgl_id] = &pending;
+  }
+  Send(MsgBuilder::WebGLReadPixels(webgl_id, x, y, w, h, format, type));
+  bool ok = pending.done.TimedWait(base::Milliseconds(timeout_ms));
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_replies_.erase(webgl_id);
+  }
+  if (!ok || !pending.fulfilled) {
+    return std::nullopt;
+  }
+  return pending.reply;
+}
+
+std::optional<TextMetricReply> CanvasBridgeClient::RequestTextMetrics(
+    const String& text,
+    const String& family,
+    float size_px,
+    int timeout_ms) {
+  if (!IsEnabled()) {
+    return std::nullopt;
+  }
+  PendingTextMetric pending;
+  {
+    base::AutoLock lock(pending_lock_);
+    if (pending_text_metric_) {
+      // Another renderer thread is already mid-request. Skip the bridge
+      // and fall back to local for this call rather than serializing.
+      return std::nullopt;
+    }
+    pending_text_metric_ = &pending;
+  }
+  Send(MsgBuilder::MeasureText(text, family, size_px));
+  bool ok = pending.done.TimedWait(base::Milliseconds(timeout_ms));
+  {
+    base::AutoLock lock(pending_lock_);
+    pending_text_metric_ = nullptr;
+  }
+  if (!ok || !pending.fulfilled) {
+    return std::nullopt;
+  }
+  return pending.reply;
+}
+
+void CanvasBridgeClient::Disable(const std::string& reason) {
+  state_.store(State::kDisabled);
+  LOG(INFO) << "[canvas-bridge] disabled: " << reason;
+}
+
+}  // namespace blink::canvas_bridge
diff --git a/third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_client.h b/third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_client.h
new file mode 100644
index 0000000000000..6bd366f5d481a
--- /dev/null
+++ b/third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_client.h
@@ -0,0 +1,165 @@
+// Copyright (c) 2026 Arman Hossain <arman@bytetunnels.com>. ChromiumFish authors. All rights reserved.
+//
+// CanvasBridgeClient — per-renderer-process singleton that owns the
+// WebSocket connection to the remote render server. Blink call sites
+// (html_canvas_element.cc, base_rendering_context_2d.cc) call into
+// this from the renderer main thread; the client thunks the request
+// to its dedicated I/O thread, which speaks the protocol.
+//
+// Lifetime: a process-wide singleton created on the first Get() call,
+// which the renderer makes eagerly at startup (from blink_initializer).
+// IsEnabled() returns false if the --canvas-bridge-url switch wasn't
+// supplied or the initial Hello/Welcome handshake failed. Once disabled,
+// stays disabled for the rest of the process.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
+#define THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
+
+#include <atomic>
+#include <cstdint>
+#include <memory>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include <map>
+
+#include "base/memory/raw_ptr.h"
+#include "base/no_destructor.h"
+#include "base/synchronization/lock.h"
+#include "base/synchronization/waitable_event.h"
+#include "base/threading/thread.h"
+#include "base/time/time.h"
+#include "third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_codec.h"
+#include "third_party/blink/renderer/platform/platform_export.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+
+namespace blink::canvas_bridge {
+
+class PLATFORM_EXPORT CanvasBridgeClient {
+ public:
+  // Returns the process-wide singleton. Always non-null; check
+  // IsEnabled() before issuing ops.
+  static CanvasBridgeClient* Get();
+
+  // True iff the --canvas-bridge-url switch is set and the server
+  // handshook successfully. Cheap to call from the renderer main
+  // thread.
+  bool IsEnabled() const { return state_.load() == State::kReady; }
+
+  // Allocate a unique CanvasId for a new HTMLCanvasElement. Returns 0
+  // if the bridge is disabled.
+  uint32_t AllocateCanvasId();
+
+  // Async fire-and-forget op send. The op is queued for the I/O thread.
+  // No-op if disabled. Caller-owned buffer is copied.
+  void Send(std::vector<uint8_t> frame);
+
+  // Synchronous readback. Sends a GetCanvas2DImageData and blocks the
+  // calling thread up to `timeout_ms` for the reply. Returns nullopt
+  // on timeout / network error / disabled bridge.
+  std::optional<ImageDataReply> RequestImageData(uint32_t canvas_id,
+                                                  int32_t x,
+                                                  int32_t y,
+                                                  uint32_t w,
+                                                  uint32_t h,
+                                                  int timeout_ms = 5000);
+
+  // Synchronous text metrics query. Resolves `family` against the
+  // server's font catalog (Win DirectWrite when the server runs on
+  // Windows) and returns the box for `text` at `size_px`. Returns
+  // nullopt on timeout / network error / disabled bridge.
+  std::optional<TextMetricReply> RequestTextMetrics(const String& text,
+                                                     const String& family,
+                                                     float size_px,
+                                                     int timeout_ms = 5000);
+
+  // WebGL readback. Sends a WebGLReadPixels and blocks the calling
+  // thread up to `timeout_ms` for the ImageData reply. Returns nullopt
+  // on timeout / network error / disabled bridge. The server replays
+  // the per-context op stream before reading back, so the returned
+  // pixels reflect the full set of WebGL ops issued so far on this id.
+  std::optional<ImageDataReply> RequestWebGLPixels(uint32_t webgl_id,
+                                                    int32_t x,
+                                                    int32_t y,
+                                                    uint32_t w,
+                                                    uint32_t h,
+                                                    uint32_t format,
+                                                    uint32_t type,
+                                                    int timeout_ms = 5000);
+
+  // Disable the bridge permanently. Called when an unrecoverable
+  // protocol or network error occurs.
+  void Disable(const std::string& reason);
+
+ private:
+  friend class base::NoDestructor<CanvasBridgeClient>;
+
+  enum class State : uint8_t { kUninitialized, kConnecting, kReady, kDisabled };
+
+  CanvasBridgeClient();
+  ~CanvasBridgeClient();
+
+  void StartUp();         // called on main thread
+  void IoThreadLoop();    // I/O thread entry: connect + read loop
+
+  // I/O thread methods.
+  bool DoConnect(const std::string& url, const std::string& auth);
+  void SendOnIoThread(std::vector<uint8_t> frame);
+  void ReadLoop();
+  void HandleIncoming(const std::vector<uint8_t>& frame);
+
+  std::atomic<State> state_{State::kUninitialized};
+  std::atomic<uint32_t> next_canvas_id_{1};
+
+  std::unique_ptr<base::Thread> io_thread_;
+
+  // The open TCP socket fd; -1 when not connected. Read/written by the I/O
+  // thread, but also touched by renderer threads during sends — accesses are
+  // guarded by `write_lock_` (see SendOnIoThread).
+  int socket_fd_ = -1;
+
+  // Sync wait machinery for RequestImageData. Renderer thread creates
+  // a PendingReadback, registers it in pending_replies_, posts the
+  // request to the I/O thread, then blocks on `done`. I/O thread
+  // reads ImageData replies and signals matching PendingReadbacks.
+  struct PendingReadback {
+    uint32_t canvas_id;
+    ImageDataReply reply;
+    bool fulfilled = false;
+    base::WaitableEvent done{
+        base::WaitableEvent::ResetPolicy::MANUAL,
+        base::WaitableEvent::InitialState::NOT_SIGNALED};
+  };
+  base::Lock pending_lock_;
+  std::map<uint32_t, PendingReadback*> pending_replies_
+      ALLOW_DISCOURAGED_TYPE("interop with sync canvas-bridge readbacks");
+
+  // MeasureText replies don't carry a canvas id. There's at most one
+  // measureText call in flight per renderer thread because the API is
+  // synchronous, but multiple renderer threads can race — so guard with
+  // pending_lock_ and use a single pending slot, rejecting a second
+  // concurrent caller (RequestTextMetrics returns nullopt when busy and
+  // the caller falls back to local).
+  struct PendingTextMetric {
+    TextMetricReply reply;
+    bool fulfilled = false;
+    base::WaitableEvent done{
+        base::WaitableEvent::ResetPolicy::MANUAL,
+        base::WaitableEvent::InitialState::NOT_SIGNALED};
+  };
+  raw_ptr<PendingTextMetric> pending_text_metric_ = nullptr;
+
+  // Serializes writes to socket_fd_ across renderer threads. TCP send +
+  // recv can run concurrently on the same fd, so the I/O thread can be
+  // blocked in read while callers write.
+  base::Lock write_lock_;
+
+  std::string url_;
+  std::string auth_;
+  uint64_t persona_seed_ = 0;
+};
+
+}  // namespace blink::canvas_bridge
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_PLATFORM_CANVAS_BRIDGE_CANVAS_BRIDGE_CLIENT_H_
diff --git a/third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_codec.cc b/third_party/blink/renderer/platform/canvas_bridge/canvas_bridge_codec.cc
