+uint32_t BaseRenderingContext2D::EnsureBridgeCanvas() {
+  auto* bridge = blink::canvas_bridge::CanvasBridgeClient::Get();
+  if (!bridge) {
+    LOG(WARNING) << "[bridge-debug] EnsureBridgeCanvas: bridge null";
+    return 0;
+  }
+  if (!bridge->IsEnabled()) {
+    LOG(WARNING) << "[bridge-debug] EnsureBridgeCanvas: bridge not enabled";
+    return 0;
+  }
+  CanvasRenderingContextHost* host = GetCanvasRenderingContextHost();
+  if (!host) {
+    LOG(WARNING) << "[bridge-debug] EnsureBridgeCanvas: host null";
+    return 0;
+  }
+  if (host->IsOffscreenCanvas()) {
+    LOG(WARNING) << "[bridge-debug] EnsureBridgeCanvas: host is OffscreenCanvas";
+    return 0;
+  }
+  auto* el = static_cast<HTMLCanvasElement*>(host);
+  if (el->bridge_canvas_id_) {
+    return el->bridge_canvas_id_;
+  }
+  uint32_t id = bridge->AllocateCanvasId();
+  if (!id) {
+    LOG(WARNING) << "[bridge-debug] EnsureBridgeCanvas: AllocateCanvasId returned 0";
+    return 0;
+  }
+  el->bridge_canvas_id_ = id;
+  LOG(INFO) << "[bridge-debug] CreateCanvas2D id=" << id
+            << " w=" << el->width() << " h=" << el->height();
+  bridge->Send(blink::canvas_bridge::MsgBuilder::CreateCanvas2D(
+      id, el->width(), el->height(),
+      /*opaque=*/!CreationAttributes().alpha));
+  return id;
+}
