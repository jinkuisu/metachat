+}
+
+// Lightweight-fork: hide History, Bookmarks, and Help top-level menus.
+// Items inside these would already be greyed out by
+// IsLightweightForkBlockedCommand, but the menus themselves remain visible
+// in the Cocoa menu bar until hidden here. We HIDE rather than remove
+// because BookmarkMenuBridge / HistoryMenuBridge construct themselves
+// against the NSMenu instance on every profile load and CHECK that the
+// menu exists (see bookmark_menu_bridge.mm CHECK(menu_root_)). Hiding
+// preserves the menu instance while removing it from the visible menu bar.
+// Called from -mainMenuCreated, after the standard menu bar is constructed.
+- (void)lightweightForkPruneMenuBar {
+  NSMenu* mainMenu = [NSApp mainMenu];
+  for (NSInteger tag : (NSInteger[]){
+           IDC_HISTORY_MENU,
+           IDC_BOOKMARKS_MENU,
+           IDC_HELP_MENU,
+       }) {
+    NSMenuItem* item = [mainMenu itemWithTag:tag];
+    if (item) {
+      [item setHidden:YES];
+    }
+  }
+  // macOS injects a top-bar Help menu via NSApplication.helpMenu — not
+  // tagged with IDC_HELP_MENU (that's the in-window submenu). Clear it
+  // and hide any remaining "Help" item by title.
+  NSApp.helpMenu = nil;
+  for (NSMenuItem* item in mainMenu.itemArray) {
+    if ([item.title isEqualToString:@"Help"]) {
+      [item setHidden:YES];
+    }
+  }
 }
 
