+
+#ifndef CONTENT_PUBLIC_BROWSER_HUMANIZED_CLICK_H_
+#define CONTENT_PUBLIC_BROWSER_HUMANIZED_CLICK_H_
+
+#include "base/functional/callback_forward.h"
+#include "base/time/time.h"
+#include "content/common/content_export.h"
+
+namespace gfx {
+class PointF;
+class Rect;
+}
+
+namespace content {
+class WebContents;
+
+// Dispatches a humanized mouse move (Bézier path + jitter, no kFromDebugger
+// marker) from `start_css` to `target_css` -- CSS/DIP viewport coordinates in
+// the main-frame widget of `web_contents` -- then, unless `move_only`, a left
+// mouse down/up at the target. Events are routed through the cross-process
+// input event router (RenderWidgetHostInputEventRouter), so they hit-test
+// correctly (including into OOPIFs) and are delivered to the DOM as real
+// user-like input. Self-owned: runs `on_done` exactly once when finished (or
+// when the tab/widget goes away).
+//
+// This is the browser-process entry point used by the native AI agent layer so
+// its clicks are indistinguishable from genuine user input. It lives in the
+// content layer because routed input requires content-internal plumbing that
+// chrome/ cannot reach.
+CONTENT_EXPORT void PerformHumanizedClick(WebContents* web_contents,
+                                          const gfx::PointF& start_css,
+                                          const gfx::PointF& target_css,
+                                          base::TimeDelta duration,
+                                          bool move_only,
+                                          base::OnceClosure on_done);
+
+// Draws a highlight box around `css_rect` (CSS/DIP viewport rect) of
+// `web_contents` for `duration`, then removes it. Lets a human watching see
+// which element the agent is acting on. macOS only; a no-op elsewhere.
+CONTENT_EXPORT void HighlightElement(WebContents* web_contents,
+                                     const gfx::Rect& css_rect,
+                                     base::TimeDelta duration);
+
+}  // namespace content
+
+#endif  // CONTENT_PUBLIC_BROWSER_HUMANIZED_CLICK_H_
