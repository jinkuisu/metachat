+// Extracts the first balanced JSON object from a model response (tolerates
+// ```json fences and surrounding prose).
+std::optional<base::DictValue> ParseActionJson(const std::string& content) {
+  size_t start = content.find('{');
+  size_t end = content.rfind('}');
+  if (start == std::string::npos || end == std::string::npos || end <= start) {
+    return std::nullopt;
+  }
+  std::optional<base::Value> v = base::JSONReader::Read(
+      content.substr(start, end - start + 1), base::JSON_PARSE_RFC);
+  if (!v || !v->is_dict()) {
+    return std::nullopt;
+  }
+  return std::move(*v).TakeDict();
+}
+
+std::string GetString(const base::DictValue& d, const char* key) {
+  const std::string* s = d.FindString(key);
+  return s ? *s : std::string();
+}
+
+actor::ScrollToolRequest::Direction ParseDirection(const std::string& dir) {
+  if (dir == "up") {
+    return actor::ScrollToolRequest::Direction::kUp;
+  }
+  if (dir == "left") {
+    return actor::ScrollToolRequest::Direction::kLeft;
+  }
+  if (dir == "right") {
+    return actor::ScrollToolRequest::Direction::kRight;
+  }
+  return actor::ScrollToolRequest::Direction::kDown;
+}
+
+// How many recent action/result lines to feed back to the model each step.
+constexpr size_t kMaxHistoryLines = 10;
+
+// Compact one-line description of the action the model chose (for history).
+std::string DescribeAction(const base::DictValue& action) {
+  const std::string verb = GetString(action, "action");
+  std::string out = verb;
+  if (std::optional<int> idx = action.FindInt("index")) {
+    out += base::StrCat({" [", base::NumberToString(*idx), "]"});
+  }
+  if (verb == "type" && !GetString(action, "text").empty()) {
+    out += base::StrCat({" '", GetString(action, "text"), "'"});
+  } else if (verb == "navigate") {
+    out += base::StrCat({" ", GetString(action, "url")});
+  } else if (verb == "select") {
+    out += base::StrCat({" =", GetString(action, "value")});
+  } else if (verb == "scroll") {
+    out += base::StrCat({" ", GetString(action, "direction")});
+  }
+  return out;
+}
+
+// Summarizes an actor action-result vector into a short note for the model.
+std::string SummarizeResults(
+    const std::vector<actor::ActionResultWithLatencyInfo>& results) {
+  for (const auto& r : results) {
+    if (r.result && !actor::IsOk(r.result->code)) {
+      return base::StrCat({"action failed: ", r.result->message});
+    }
+  }
+  return "ok";
+}
+
+// ---- Flow replay: durable {role, name, ordinal} descriptor matching ----
+
+// Normalizes a semantic name for matching: collapsed whitespace + lowercase.
+std::string NormalizeName(const std::string& s) {
+  return base::ToLowerASCII(base::CollapseWhitespaceASCII(s, true));
+}
+
+// 0-based count of earlier elements sharing (role, normalized name) with the
+// element at `index`. Disambiguates repeated controls (e.g. two "Remove" links).
+int OrdinalOf(const SerializedPage& page, int index) {
+  const InteractiveElement* target = page.ElementByIndex(index);
+  if (!target) {
+    return 0;
+  }
+  const std::string n = NormalizeName(target->name);
+  int ord = 0;
+  for (const InteractiveElement& el : page.elements) {
+    if (el.index >= index) {
+      break;
+    }
+    if (el.role == target->role && NormalizeName(el.name) == n) {
+      ++ord;
+    }
+  }
+  return ord;
+}
+
+// Re-resolves a {role, name, ordinal} descriptor against `page`. Returns the
+// matching element, or nullptr if none (caller heals via the LLM). Prefers the
+// element at the recorded ordinal; falls back to the first same-role/name one.
+const InteractiveElement* MatchDescriptor(const SerializedPage& page,
+                                          const std::string& role,
+                                          const std::string& name,
+                                          int ordinal) {
+  const std::string n = NormalizeName(name);
+  std::vector<const InteractiveElement*> cands;
+  for (const InteractiveElement& el : page.elements) {
+    if (el.role == role && NormalizeName(el.name) == n) {
+      cands.push_back(&el);
+    }
+  }
+  if (cands.empty()) {
+    return nullptr;
+  }
+  if (ordinal >= 0 && ordinal < static_cast<int>(cands.size())) {
+    return cands[ordinal];
+  }
+  return cands.front();
+}
+
+// ---- In-page visual overlay (target highlight box) -----------------------
+//
+// Rendered INSIDE the page via an isolated-world script, not as an AppKit
+// window/subview over the screen: it composites with the page, is positioned in
+// exact CSS-viewport pixels (correct on any display / scale factor — no native
+// coordinate math), clips to the viewport, and is captured by
+// Page.captureScreenshot (so it is verifiable). pointer-events:none, no shadow.
+//
+// Agent visualization = the magic cursor (mouse effect) + a one-shot red click
+// ripple (click effect). A cyan target-outline box used to be drawn too, but it
+// read as unnatural (a real user gets no box around the field they type into),
+// so it was removed — the cursor + ripple are enough. The ripple fires AT click
+// time where the cursor lands: on the batch/Actor path via the magic cursor's
+// own click animation (actor_overlay/app.css), and on the humanized single-click
+// path via ShowClickRipple() in OnHumanizedClickDone().
+//
+// world_id must be in (ISOLATED_WORLD_ID_GLOBAL, ISOLATED_WORLD_ID_MAX] or
+// ExecuteJavaScriptInIsolatedWorld CHECK-fails. ISOLATED_WORLD_ID_MAX is the
+// top embedder slot; chrome's own worlds occupy CONTENT_END+1..+5, so it's free.
+constexpr int kOverlayWorldId = content::ISOLATED_WORLD_ID_MAX;
+
+bool OverlayFrameReady(content::WebContents* wc) {
+  return wc && wc->GetPrimaryMainFrame() &&
+         wc->GetPrimaryMainFrame()->IsRenderFrameLive();
+}
+
+// Fires a one-shot red "click ripple" at (cx,cy) CSS-viewport px: an isolated-
+// world div that expands and fades, then removes itself. Used on the humanized
+// single-click path (which has no Actor magic cursor); the batch/Actor path gets
+// its red ripple from the magic cursor's own click animation instead.
+void ShowClickRipple(content::WebContents* wc, int cx, int cy) {
+  if (!OverlayFrameReady(wc)) {
+    return;
+  }
+  // %% -> literal % (border-radius:50%, keyframe percents). All coords CSS px.
+  std::string js = base::StringPrintf(
+      "(function(){"
+      "if(!document.getElementById('__cf_rip_kf')){"
+      "var s=document.createElement('style');s.id='__cf_rip_kf';"
+      "s.textContent='@keyframes __cf_rip{0%%{opacity:.9;transform:scale(.35)}"
+      "100%%{opacity:0;transform:scale(2.6)}}';"
+      "(document.head||document.documentElement).appendChild(s);}"
+      "var r=document.createElement('div');"
+      "r.style.cssText='position:fixed;left:%dpx;top:%dpx;width:20px;"
+      "height:20px;margin:-10px 0 0 -10px;border-radius:50%%;"
+      "background:rgba(255,40,40,.82);border:1.5px solid #fff;"
+      "z-index:2147483647;pointer-events:none;"
+      "animation:__cf_rip .4s ease-out forwards';"
+      "(document.body||document.documentElement).appendChild(r);"
+      "setTimeout(function(){r.remove();},450);})()",
+      cx, cy);
+  wc->GetPrimaryMainFrame()->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(js), base::DoNothing(), kOverlayWorldId);
+}
+
+// No-op: the cyan target-outline box was removed (it looked unnatural, esp.
+// around input fields a user just types into). The agent's visualization is now
+// just the magic cursor + the click ripple. Kept as a no-op so the act-site call
+// contract doesn't change at every call site.
+void MaybeShowOverlay(content::WebContents* /*wc*/,
+                      const SerializedPage& /*page*/,
+                      const InteractiveElement& /*el*/,
+                      const gfx::Rect& /*css_rect*/) {}
+
+void HideInPageOverlay(content::WebContents* wc) {
+  if (!OverlayFrameReady(wc)) {
+    return;
+  }
+  wc->GetPrimaryMainFrame()->ExecuteJavaScriptInIsolatedWorld(
+      u"(function(){var o=document.getElementById('__cf_agent_overlay');"
+      u"if(o)o.remove();})()",
+      base::DoNothing(), kOverlayWorldId);
+}
