@@ -0,0 +1,237 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+
+#include "content/public/browser/humanized_click.h"
+
+#include <algorithm>
+#include <cmath>
+#include <utility>
+#include <vector>
+
+#include "base/functional/bind.h"
+#include "base/functional/callback.h"
+#include "base/memory/weak_ptr.h"
+#include "base/rand_util.h"
+#include "base/task/single_thread_task_runner.h"
+#include "base/timer/timer.h"
+#include "build/build_config.h"
+#include "components/input/render_widget_host_input_event_router.h"
+#include "content/browser/renderer_host/render_widget_host_delegate.h"
+#include "content/browser/renderer_host/render_widget_host_impl.h"
+#include "content/browser/renderer_host/render_widget_host_view_base.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#include "third_party/blink/public/common/input/web_mouse_event.h"
+#include "ui/events/base_event_utils.h"
+#include "ui/gfx/geometry/point_f.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/latency/latency_info.h"
+
+#if BUILDFLAG(IS_MAC)
+#include "content/browser/devtools/protocol/humanized_cursor_overlay_mac.h"
+#endif
+
+namespace content {
+
+namespace {
+
+constexpr int kSamplesPerSecond = 120;
+constexpr double kMinDurationSeconds = 0.05;
+constexpr double kMaxDurationSeconds = 10.0;
+
+double Ease(double t) {
+  return t * t * (3.0 - 2.0 * t);
+}
+
+gfx::PointF Bezier(const gfx::PointF& p0,
+                   const gfx::PointF& p1,
+                   const gfx::PointF& p2,
+                   const gfx::PointF& p3,
+                   double t) {
+  const double u = 1.0 - t;
+  const double w0 = u * u * u;
+  const double w1 = 3.0 * u * u * t;
+  const double w2 = 3.0 * u * t * t;
+  const double w3 = t * t * t;
+  return gfx::PointF(
+      static_cast<float>(w0 * p0.x() + w1 * p1.x() + w2 * p2.x() + w3 * p3.x()),
+      static_cast<float>(w0 * p0.y() + w1 * p1.y() + w2 * p2.y() + w3 * p3.y()));
+}
+
+// Self-owned humanized mouse runner. Routes events through the cross-process
+// input router (same path as the fork's CDP humanizedClick), which is what
+// actually delivers a real click to the DOM -- a plain ForwardMouseEvent does
+// not hit-test/target correctly.
+class HumanizedClickRunner {
+ public:
+  static void Start(base::WeakPtr<WebContents> web_contents,
+                    gfx::PointF start,
+                    gfx::PointF target,
+                    base::TimeDelta duration,
+                    bool move_only,
+                    base::OnceClosure on_done) {
+    new HumanizedClickRunner(std::move(web_contents), start, target, duration,
+                             move_only, std::move(on_done));
+  }
+
+ private:
+  HumanizedClickRunner(base::WeakPtr<WebContents> web_contents,
+                       gfx::PointF start,
+                       gfx::PointF target,
+                       base::TimeDelta duration,
+                       bool move_only,
+                       base::OnceClosure on_done)
+      : web_contents_(std::move(web_contents)),
+        target_(target),
+        move_only_(move_only),
+        on_done_(std::move(on_done)) {
+    double seconds = std::clamp(duration.InSecondsF(), kMinDurationSeconds,
+                                kMaxDurationSeconds);
+    const int samples =
+        std::max(2, static_cast<int>(seconds * kSamplesPerSecond));
+    step_dt_ = base::Seconds(seconds / samples);
+
+    const gfx::PointF p0 = start;
+    const gfx::PointF p3 = target;
+    const double dx = p3.x() - p0.x();
+    const double dy = p3.y() - p0.y();
+    const double dist = std::hypot(dx, dy);
+    const double px = dist > 0 ? -dy / dist : 0.0;
+    const double py = dist > 0 ? dx / dist : 0.0;
+    const double bow = (base::RandDouble() - 0.5) * 0.30 * dist;
+    const gfx::PointF p1(static_cast<float>(p0.x() + dx * 0.33 + px * bow),
+                         static_cast<float>(p0.y() + dy * 0.33 + py * bow));
+    const gfx::PointF p2(static_cast<float>(p0.x() + dx * 0.66 + px * bow),
+                         static_cast<float>(p0.y() + dy * 0.66 + py * bow));
+
+    path_.reserve(samples + 1);
+    for (int i = 0; i <= samples; ++i) {
+      const double t = Ease(static_cast<double>(i) / samples);
+      gfx::PointF pt = Bezier(p0, p1, p2, p3, t);
+      if (i != samples) {
+        double jx = std::clamp(base::RandDouble() * 0.8 - 0.4, -2.0, 2.0);
+        double jy = std::clamp(base::RandDouble() * 0.8 - 0.4, -2.0, 2.0);
+        pt.Offset(static_cast<float>(jx), static_cast<float>(jy));
+      }
+      path_.push_back(pt);
+    }
+    path_.back() = target_;
+    Tick();
+  }
+
+  ~HumanizedClickRunner() = default;
+
+  RenderWidgetHostImpl* GetWidget() const {
+    if (!web_contents_ || !web_contents_->GetRenderWidgetHostView()) {
+      return nullptr;
+    }
+    return RenderWidgetHostImpl::From(
+        web_contents_->GetRenderWidgetHostView()->GetRenderWidgetHost());
+  }
+
+  void Tick() {
+    if (!GetWidget()) {
+      Finish();
+      return;
+    }
+    if (index_ < path_.size()) {
+      Dispatch(blink::WebInputEvent::Type::kMouseMove, path_[index_++]);
+      timer_.Start(
+          FROM_HERE, step_dt_,
+          base::BindOnce(&HumanizedClickRunner::Tick, base::Unretained(this)));
+      return;
+    }
+    if (move_only_) {
+      Finish();
+      return;
+    }
+    Dispatch(blink::WebInputEvent::Type::kMouseDown, target_);
+    Dispatch(blink::WebInputEvent::Type::kMouseUp, target_);
+    Finish();
+  }
+
+  void Dispatch(blink::WebInputEvent::Type type, gfx::PointF point) {
+    RenderWidgetHostImpl* rwh = GetWidget();
+    if (!rwh) {
+      return;
+    }
+    blink::WebMouseEvent event(type, blink::WebInputEvent::kNoModifiers,
+                               ui::EventTimeForNow());
+    event.SetPositionInWidget(point.x(), point.y());
+    event.SetPositionInScreen(point.x(), point.y());
+    event.button = blink::WebMouseEvent::Button::kLeft;
+    event.click_count = (type == blink::WebInputEvent::Type::kMouseDown ||
+                         type == blink::WebInputEvent::Type::kMouseUp)
+                            ? 1
+                            : 0;
+    // No kFromDebugger marker -- this should look like real input. Route via
+    // the cross-process input router so the point hit-tests to the correct
+    // (possibly OOPIF) renderer; fall back to direct forwarding if absent.
+    RenderWidgetHostViewBase* root_view =
+        rwh->GetView() ? static_cast<RenderWidgetHostViewBase*>(rwh->GetView())
+                       : nullptr;
+    input::RenderWidgetHostInputEventRouter* router =
+        rwh->delegate() ? rwh->delegate()->GetInputEventRouter() : nullptr;
+    if (root_view && router) {
+      ui::LatencyInfo latency_info;
+      latency_info.AddLatencyNumber(ui::INPUT_EVENT_LATENCY_UI_COMPONENT);
+      router->RouteMouseEvent(root_view, &event, latency_info);
+    } else {
+      rwh->ForwardMouseEvent(event);
+    }
+  }
+
+  void Finish() {
+    if (on_done_) {
+      std::move(on_done_).Run();
+    }
+    delete this;
+  }
+
+  base::WeakPtr<WebContents> web_contents_;
+  const gfx::PointF target_;
+  const bool move_only_;
+  std::vector<gfx::PointF> path_;
+  size_t index_ = 0;
+  base::TimeDelta step_dt_;
+  base::OneShotTimer timer_;
+  base::OnceClosure on_done_;
+};
+
+}  // namespace
+
+void PerformHumanizedClick(WebContents* web_contents,
+                           const gfx::PointF& start_css,
+                           const gfx::PointF& target_css,
+                           base::TimeDelta duration,
+                           bool move_only,
+                           base::OnceClosure on_done) {
+  if (!web_contents) {
+    if (on_done) {
+      std::move(on_done).Run();
+    }
+    return;
+  }
+  HumanizedClickRunner::Start(web_contents->GetWeakPtr(), start_css, target_css,
+                              duration, move_only, std::move(on_done));
+}
+
+void HighlightElement(WebContents* web_contents,
+                      const gfx::Rect& css_rect,
+                      base::TimeDelta duration) {
+#if BUILDFLAG(IS_MAC)
+  if (!web_contents || !web_contents->GetRenderWidgetHostView()) {
+    return;
+  }
+  RenderWidgetHostViewBase* view = static_cast<RenderWidgetHostViewBase*>(
+      web_contents->GetRenderWidgetHostView());
+  // Pass the element rect in the view's own (CSS/DIP, top-left) coordinate
+  // space; ShowRectOverlay converts to screen via AppKit (display/DPI aware).
+  devtools::ShowRectOverlay(view->GetNativeView(), css_rect.x(), css_rect.y(),
+                            css_rect.width(), css_rect.height());
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE, base::BindOnce(&devtools::HideRectOverlay), duration);
+#endif
+}
+
+}  // namespace content
