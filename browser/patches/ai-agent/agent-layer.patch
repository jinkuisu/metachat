+// A permissive enterprise policy checker. ActorTask stores the checker as a
+// raw_ref and requires it to outlive the task, so this is a process singleton.
+class PermissivePolicyChecker : public actor::EnterprisePolicyChecker {
+ public:
+  UrlBlockReason Evaluate(const GURL& url) const override {
+    return UrlBlockReason::kNotBlocked;
+  }
+  void ValidateContentSentToRenderer(
+      content::RenderFrameHost* frame,
+      const std::string& content,
+      ContentValidationCallback callback) const override {
+    std::move(callback).Run(ContentValidationReason::kAllowed);
+  }
+};
+
+PermissivePolicyChecker* PolicyChecker() {
+  static base::NoDestructor<PermissivePolicyChecker> instance;
+  return instance.get();
+}
