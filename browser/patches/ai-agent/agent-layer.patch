@@ -0,0 +1,58 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+//
+// Command-line switches that configure the native in-browser AI agent layer.
+// These mirror the OpenAI-compatible environment contract (OPENAI_API_BASE /
+// OPENAI_API_KEY / OPENAI_API_MODEL) and are supplied to the browser process at
+// launch (e.g. by a launcher that reads .env). The agent layer reads them in
+// the browser process only; they are NOT forwarded to renderers.
+
+#ifndef CHROME_BROWSER_AI_AGENT_AGENT_SWITCHES_H_
+#define CHROME_BROWSER_AI_AGENT_AGENT_SWITCHES_H_
+
+#include <string>
+
+namespace ai_agent {
+namespace switches {
+
+// Base URL of an OpenAI-compatible chat-completions endpoint, e.g.
+// "https://openrouter.ai/api/v1/". Maps to OPENAI_API_BASE. A trailing
+// "/chat/completions" is appended by LlmClient if not already present.
+inline constexpr char kAgentLlmUrl[] = "agent-llm-url";
+
+// Bearer API key for the endpoint. Maps to OPENAI_API_KEY. Never logged.
+inline constexpr char kAgentLlmKey[] = "agent-llm-key";
+
+// Default model id (provider/model slug for OpenRouter), e.g.
+// "qwen/qwen3.7-plus". Maps to OPENAI_API_MODEL. Overridable per task via the
+// Browser.agentRunTask `model` parameter.
+inline constexpr char kAgentModel[] = "agent-model";
+
+// Optional: force tool-calling mode. One of "auto" (default), "on", "off".
+// "off" uses the JSON-in-content fallback for endpoints with weak tool-calling.
+inline constexpr char kAgentToolMode[] = "agent-tool-mode";
+
+// Optional: path to append a human-readable transcript of every LLM request
+// (SENT) and response (RECV) per step. Lets you tail what the agent sends/gets.
+inline constexpr char kAgentLogFile[] = "agent-log-file";
+
+}  // namespace switches
+
+// Resolved configuration for the agent's LLM client, read once from the
+// command line. Empty fields mean "unset".
+struct LlmConfig {
+  std::string base_url;
+  std::string api_key;
+  std::string model;
+  std::string tool_mode;  // "auto" | "on" | "off"
+
+  // Returns a config populated from the current process command line.
+  static LlmConfig FromCommandLine();
+
+  // True if base_url + api_key + model are all present.
+  bool IsComplete() const;
+};
+
+}  // namespace ai_agent
+
+#endif  // CHROME_BROWSER_AI_AGENT_AGENT_SWITCHES_H_
