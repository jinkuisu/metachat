index 0000000000000..f7c5205187f6f
--- /dev/null
+++ b/chrome/browser/ai_agent/llm_client.cc
@@ -0,0 +1,193 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+
+#include "chrome/browser/ai_agent/llm_client.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/strings/strcat.h"
+#include "base/strings/string_number_conversions.h"
+#include "net/base/load_flags.h"
+#include "net/http/http_request_headers.h"
+#include "net/traffic_annotation/network_traffic_annotation.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "services/network/public/cpp/shared_url_loader_factory.h"
+#include "services/network/public/cpp/simple_url_loader.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+#include "url/gurl.h"
+
+namespace ai_agent {
+
+namespace {
+
+// Bounded cap for an LLM response body (5 MiB == kMaxBoundedStringDownloadSize).
+constexpr size_t kMaxResponseBytes = 5 * 1024 * 1024;
+
+constexpr net::NetworkTrafficAnnotationTag kAgentLlmAnnotation =
+    net::DefineNetworkTrafficAnnotation("chromiumfish_agent_llm", R"(
+      semantics {
+        sender: "ChromiumFish AI Agent"
+        description:
+          "Sends the current page observation and task goal to a "
+          "user-configured OpenAI-compatible chat-completions endpoint and "
+          "receives the next browser action to perform."
+        trigger:
+          "An in-browser agent task (Browser.agentRunTask) needs the model to "
+          "decide its next action."
+        data:
+          "A natural-language task goal, a serialized summary of the active "
+          "page's interactive elements, prior action results, and a bearer "
+          "API key in the Authorization header."
+        destination: OTHER
+        internal { contacts { email: "arman@bytetunnels.com" } }
+        user_data { type: USER_CONTENT }
+        last_reviewed: "2026-06-13"
+      }
+      policy {
+        cookies_allowed: NO
+        setting:
+          "Configured by the operator via the --agent-llm-url/--agent-llm-key/"
+          "--agent-model switches. No request is sent unless an agent task is "
+          "started and these are set."
+        policy_exception_justification:
+          "Not implemented; this is an operator-controlled developer feature."
+      })");
+
+// Appends "chat/completions" to a base URL like "https://host/api/v1/".
+GURL BuildEndpoint(const std::string& base_url) {
+  std::string url = base_url;
+  if (url.empty()) {
+    return GURL();
+  }
+  if (url.back() != '/') {
+    url.push_back('/');
+  }
+  url += "chat/completions";
+  return GURL(url);
+}
+
+}  // namespace
+
+LlmResponse::LlmResponse() = default;
+LlmResponse::LlmResponse(LlmResponse&&) = default;
+LlmResponse& LlmResponse::operator=(LlmResponse&&) = default;
+LlmResponse::~LlmResponse() = default;
+
+LlmClient::LlmClient(
+    scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory,
+    LlmConfig config)
+    : url_loader_factory_(std::move(url_loader_factory)),
+      config_(std::move(config)) {}
+
+LlmClient::~LlmClient() = default;
+
+void LlmClient::CreateCompletion(base::ListValue messages,
+                                 base::ListValue tools,
+                                 const std::string& model_override,
+                                 CompletionCallback callback) {
+  GURL endpoint = BuildEndpoint(config_.base_url);
+  if (!endpoint.is_valid()) {
+    LlmResponse response;
+    response.error = "agent: invalid or missing --agent-llm-url";
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+
+  base::DictValue body;
+  body.Set("model", model_override.empty() ? config_.model : model_override);
+  body.Set("messages", base::Value(std::move(messages)));
+  body.Set("temperature", 0.0);
+  if (!tools.empty() && config_.tool_mode != "off") {
+    body.Set("tools", base::Value(std::move(tools)));
+    body.Set("tool_choice", "auto");
+  }
+
+  std::string json_body;
+  base::JSONWriter::Write(body, &json_body);
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = endpoint;
+  request->method = "POST";
+  request->load_flags = net::LOAD_DISABLE_CACHE;
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  request->headers.SetHeader(net::HttpRequestHeaders::kAuthorization,
+                             base::StrCat({"Bearer ", config_.api_key}));
+  // OpenRouter attribution headers (ignored by other providers).
+  request->headers.SetHeader("HTTP-Referer", "https://chromiumfish.com");
+  request->headers.SetHeader("X-Title", "ChromiumFish Agent");
+
+  loader_ = network::SimpleURLLoader::Create(std::move(request),
+                                             kAgentLlmAnnotation);
+  loader_->SetAllowHttpErrorResults(true);  // read provider error JSON on 4xx/5xx
+  loader_->AttachStringForUpload(json_body, "application/json");
+  loader_->DownloadToString(
+      url_loader_factory_.get(),
+      base::BindOnce(&LlmClient::OnResponse, weak_factory_.GetWeakPtr(),
+                     std::move(callback)),
+      kMaxResponseBytes);
+}
+
+void LlmClient::OnResponse(CompletionCallback callback,
+                           std::optional<std::string> response_body) {
+  LlmResponse response;
+
+  int http_code = 0;
+  if (loader_ && loader_->ResponseInfo() && loader_->ResponseInfo()->headers) {
+    http_code = loader_->ResponseInfo()->headers->response_code();
+  }
+  const int net_error = loader_ ? loader_->NetError() : net::ERR_FAILED;
+  loader_.reset();  // single-use; release before invoking the callback.
+
+  if (net_error != net::OK || !response_body) {
+    response.error = base::StrCat({"agent: network error (net=",
+                                   base::NumberToString(net_error), ")"});
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(*response_body, base::JSON_PARSE_RFC);
+  if (!parsed || !parsed->is_dict()) {
+    response.error = "agent: non-JSON response from LLM endpoint";
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+  const base::DictValue& root = parsed->GetDict();
+
+  // Provider-level error object?
+  if (const base::DictValue* err = root.FindDict("error")) {
+    const std::string* msg = err->FindString("message");
+    response.error = base::StrCat(
+        {"agent: LLM error: ", msg ? *msg : "unknown",
+         http_code != 200 ? base::StrCat({" (http ",
+                                          base::NumberToString(http_code), ")"})
+                          : ""});
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+
+  const base::ListValue* choices = root.FindList("choices");
+  if (!choices || choices->empty() || !(*choices)[0].is_dict()) {
+    response.error = "agent: LLM response had no choices";
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+  const base::DictValue* message = (*choices)[0].GetDict().FindDict("message");
+  if (!message) {
+    response.error = "agent: LLM choice had no message";
+    std::move(callback).Run(std::move(response));
+    return;
+  }
+  if (const std::string* content = message->FindString("content")) {
+    response.content = *content;
+  }
+  if (const base::ListValue* tool_calls = message->FindList("tool_calls")) {
+    response.tool_calls = tool_calls->Clone();
+  }
+  std::move(callback).Run(std::move(response));
+}
+
+}  // namespace ai_agent
diff --git a/chrome/browser/ai_agent/llm_client.h b/chrome/browser/ai_agent/llm_client.h
new file mode 100644
index 0000000000000..0368146caab3b
--- /dev/null
+++ b/chrome/browser/ai_agent/llm_client.h
@@ -0,0 +1,83 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+//
+// LlmClient: a browser-process client for an OpenAI-compatible
+// /chat/completions endpoint (OpenAI, OpenRouter, Together, Groq, vLLM, Ollama,
+// ...). It POSTs a JSON body via network::SimpleURLLoader and returns the
+// assistant message plus any tool_calls. One request in flight at a time.
+
+#ifndef CHROME_BROWSER_AI_AGENT_LLM_CLIENT_H_
+#define CHROME_BROWSER_AI_AGENT_LLM_CLIENT_H_
+
+#include <memory>
+#include <optional>
+#include <string>
+
+#include "base/functional/callback.h"
+#include "base/memory/scoped_refptr.h"
+#include "base/memory/weak_ptr.h"
+#include "base/values.h"
+#include "chrome/browser/ai_agent/agent_switches.h"
+
+namespace network {
+class SharedURLLoaderFactory;
+class SimpleURLLoader;
+}  // namespace network
+
+namespace ai_agent {
+
+// Parsed result of one chat-completion turn.
+struct LlmResponse {
+  LlmResponse();
+  LlmResponse(LlmResponse&&);
+  LlmResponse& operator=(LlmResponse&&);
+  ~LlmResponse();
+
+  // Assistant free-text content (may be empty when the model only emits
+  // tool_calls).
+  std::string content;
+  // OpenAI-style tool_calls array: list of dicts with id/type/function{name,
+  // arguments(JSON string)}. Empty when the model answered in content only.
+  base::ListValue tool_calls;
+  // Raw provider error message when the request failed (content/tool_calls
+  // empty in that case).
+  std::string error;
+
+  bool ok() const { return error.empty(); }
+};
+
+class LlmClient {
+ public:
+  using CompletionCallback = base::OnceCallback<void(LlmResponse)>;
+
+  LlmClient(scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory,
+            LlmConfig config);
+  LlmClient(const LlmClient&) = delete;
+  LlmClient& operator=(const LlmClient&) = delete;
+  ~LlmClient();
+
+  // Sends a chat-completions request. `messages` is a list of {role, content}
+  // dicts (system/user/assistant/tool). `tools` is the OpenAI tools spec list
+  // (may be empty to disable tool-calling). `model_override`, when non-empty,
+  // replaces the configured default model for this request. Invokes `callback`
+  // on the UI thread with the parsed result. Cancels any in-flight request.
+  void CreateCompletion(base::ListValue messages,
+                        base::ListValue tools,
+                        const std::string& model_override,
+                        CompletionCallback callback);
+
+  const LlmConfig& config() const { return config_; }
+
+ private:
+  void OnResponse(CompletionCallback callback,
+                  std::optional<std::string> response_body);
+
+  scoped_refptr<network::SharedURLLoaderFactory> url_loader_factory_;
+  const LlmConfig config_;
+  std::unique_ptr<network::SimpleURLLoader> loader_;  // single in-flight request
+  base::WeakPtrFactory<LlmClient> weak_factory_{this};
+};
+
+}  // namespace ai_agent
+
+#endif  // CHROME_BROWSER_AI_AGENT_LLM_CLIENT_H_
diff --git a/chrome/browser/ai_agent/page_serializer.cc b/chrome/browser/ai_agent/page_serializer.cc
new file mode 100644
index 0000000000000..61de34865cb19
--- /dev/null
+++ b/chrome/browser/ai_agent/page_serializer.cc
@@ -0,0 +1,380 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+
+#include "chrome/browser/ai_agent/page_serializer.h"
+
+#include <utility>
+
+#include "base/strings/strcat.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_util.h"
+#include "components/optimization_guide/proto/features/common_quality_data.pb.h"
+
+namespace ai_agent {
+
+namespace proto = optimization_guide::proto;
+
+namespace {
+
+constexpr size_t kMaxLabelChars = 100;
+
+// Collapses whitespace and truncates a label for compact display.
+std::string CleanLabel(const std::string& raw) {
+  std::string s = base::CollapseWhitespaceASCII(raw, /*trim_sequences=*/true);
+  if (s.size() > kMaxLabelChars) {
+    s = s.substr(0, kMaxLabelChars) + "…";
+  }
+  return s;
+}
+
+// Maps a form control type to a short, specific tag (so the input's TYPE is
+// passed explicitly, e.g. input:email vs input:password).
+std::string FormControlTag(proto::FormControlType type) {
+  switch (type) {
+    case proto::FORM_CONTROL_TYPE_TEXT_AREA:
+      return "textarea";
+    case proto::FORM_CONTROL_TYPE_SELECT_ONE:
+      return "select";
+    case proto::FORM_CONTROL_TYPE_SELECT_MULTIPLE:
+      return "select-multiple";
+    case proto::FORM_CONTROL_TYPE_INPUT_CHECKBOX:
+      return "checkbox";
+    case proto::FORM_CONTROL_TYPE_INPUT_RADIO:
+      return "radio";
+    case proto::FORM_CONTROL_TYPE_BUTTON_SUBMIT:
+    case proto::FORM_CONTROL_TYPE_BUTTON_BUTTON:
+    case proto::FORM_CONTROL_TYPE_INPUT_BUTTON:
+      return "button";
+    case proto::FORM_CONTROL_TYPE_INPUT_EMAIL:
+      return "input:email";
+    case proto::FORM_CONTROL_TYPE_INPUT_PASSWORD:
+      return "input:password";
+    case proto::FORM_CONTROL_TYPE_INPUT_TELEPHONE:
+      return "input:tel";
+    case proto::FORM_CONTROL_TYPE_INPUT_NUMBER:
+      return "input:number";
+    case proto::FORM_CONTROL_TYPE_INPUT_SEARCH:
+      return "input:search";
+    case proto::FORM_CONTROL_TYPE_INPUT_URL:
+      return "input:url";
+    case proto::FORM_CONTROL_TYPE_INPUT_TEXT:
+    case proto::FORM_CONTROL_TYPE_CONTENT_EDITABLE:
+      return "input:text";
+    default:
+      return "input";
+  }
+}
+
+// Short tag/role for a node, from its attribute_type (+ form control type).
+std::string RoleForNode(const proto::ContentAttributes& attrs) {
+  switch (attrs.attribute_type()) {
+    case proto::CONTENT_ATTRIBUTE_ANCHOR:
+      return "a";
+    case proto::CONTENT_ATTRIBUTE_HEADING:
+      return "heading";
+    case proto::CONTENT_ATTRIBUTE_FORM_CONTROL:
+      return attrs.has_form_control_data()
+                 ? FormControlTag(attrs.form_control_data().form_control_type())
+                 : "input";
+    default:
+      // Fall back to the aria role / a generic clickable label.
+      return "button";
+  }
+}
+
+// True if the node is something the agent can usefully act on.
+bool IsInteractive(const proto::ContentAttributes& attrs) {
+  if (!attrs.has_common_ancestor_dom_node_id() || !attrs.has_geometry()) {
+    return false;
+  }
+  const proto::BoundingRect& vbb = attrs.geometry().visible_bounding_box();
+  if (vbb.width() <= 0 || vbb.height() <= 0) {
+    return false;  // offscreen / not immediately hit-testable.
+  }
+  if (attrs.attribute_type() == proto::CONTENT_ATTRIBUTE_FORM_CONTROL ||
+      attrs.attribute_type() == proto::CONTENT_ATTRIBUTE_ANCHOR) {
+    return true;
+  }
+  if (attrs.has_interaction_info()) {
+    const proto::InteractionInfo& ii = attrs.interaction_info();
+    if (ii.clickability_reasons_size() > 0 || ii.is_focusable() ||
+        ii.is_tabbable()) {
+      return true;
+    }
+  }
+  return false;
+}
+
+// Best descriptive label for a node.
+std::string LabelForNode(const proto::ContentAttributes& attrs) {
+  if (attrs.has_label() && !attrs.label().empty()) {
+    return CleanLabel(attrs.label());
+  }
+  // Form controls are rendered separately (see FormControlName/State) so an
+  // empty field showing only a placeholder hint is never confused for a value.
+  if (attrs.has_text_data() && !attrs.text_data().text_content().empty()) {
+    return CleanLabel(attrs.text_data().text_content());
+  }
+  if (attrs.has_anchor_data() && !attrs.anchor_data().url().empty()) {
+    return CleanLabel(attrs.anchor_data().url());
+  }
+  return std::string();
+}
+
+// Concatenates visible text from a node's descendants. Used to label clickable
+// containers (e.g. <button>Sign in</button>) whose text lives in child text
+// nodes rather than the node's own `label`/text.
+std::string CollectDescendantText(const proto::ContentNode& node, int budget) {
+  std::string out;
+  if (node.has_content_attributes()) {
+    const proto::ContentAttributes& a = node.content_attributes();
+    if (a.has_text_data() && !a.text_data().text_content().empty()) {
+      out = a.text_data().text_content();
+    }
+  }
+  for (const proto::ContentNode& child : node.children_nodes()) {
+    if (static_cast<int>(out.size()) >= budget) {
+      break;
+    }
+    std::string ct = CollectDescendantText(child, budget);
+    if (!ct.empty()) {
+      if (!out.empty()) {
+        out += " ";
+      }
+      out += ct;
+    }
+  }
+  return out;
+}
+
+// The control's purpose/name (label or field name) — never the value/placeholder.
+std::string FormControlName(const proto::ContentAttributes& attrs) {
+  if (attrs.has_label() && !attrs.label().empty()) {
+    return CleanLabel(attrs.label());
+  }
+  if (attrs.has_form_control_data() &&
+      !attrs.form_control_data().field_name().empty()) {
+    return CleanLabel(attrs.form_control_data().field_name());
+  }
+  return std::string();
+}
+
+// Explicit, unambiguous state so the model can tell an EMPTY field (showing only
+// a placeholder hint) from a FILLED one — the key fix for it skipping fills.
+std::string FormControlState(const proto::ContentAttributes& attrs) {
+  if (!attrs.has_form_control_data()) {
+    return "[empty]";
+  }
+  const proto::FormControlData& f = attrs.form_control_data();
+  const proto::FormControlType t = f.form_control_type();
+  const std::string req = f.is_required() ? " (required)" : "";
+
+  std::string core;
+  if (t == proto::FORM_CONTROL_TYPE_INPUT_CHECKBOX ||
+      t == proto::FORM_CONTROL_TYPE_INPUT_RADIO) {
+    core = f.is_checked() ? "[checked]" : "[unchecked]";
+  } else if (t == proto::FORM_CONTROL_TYPE_SELECT_ONE ||
+             t == proto::FORM_CONTROL_TYPE_SELECT_MULTIPLE) {
+    core = f.field_value().empty()
+               ? "[no selection]"
+               : base::StrCat({"[selected: \"", CleanLabel(f.field_value()),
+                               "\"]"});
+  } else if (t == proto::FORM_CONTROL_TYPE_INPUT_PASSWORD) {
+    // Password values are redacted (field_value is empty even when filled), so
+    // use the redaction decision: REDACTED_HAS_BEEN_PASSWORD => has content.
+    core = attrs.redaction_decision() ==
+                   proto::REDACTION_DECISION_REDACTED_HAS_BEEN_PASSWORD
+               ? "[filled]"
+               : (f.placeholder().empty()
+                      ? "[EMPTY]"
+                      : base::StrCat({"[EMPTY; placeholder hint \"",
+                                      CleanLabel(f.placeholder()), "\"]"}));
+  } else if (!f.field_value().empty()) {
+    core = t == proto::FORM_CONTROL_TYPE_INPUT_PASSWORD
+               ? "[filled]"
+               : base::StrCat({"[value: \"", CleanLabel(f.field_value()),
+                               "\"]"});
+  } else if (!f.placeholder().empty()) {
+    // Empty: say so explicitly; keep the placeholder as a labeled hint (useful
+    // context for what to type), never as a value.
+    core = base::StrCat(
+        {"[EMPTY; placeholder hint \"", CleanLabel(f.placeholder()), "\"]"});
+  } else {
+    core = "[EMPTY]";
+  }
+  return base::StrCat({core, req});
+}
+
+// Recursively walk the tree, collecting interactive elements in document order.
+// `in_modal` is true once an ancestor is a dialog/alertdialog: its descendants
+// belong to a modal overlay that visually covers the rest of the page.
+void Walk(const proto::ContentNode& node,
+          const std::string& doc_id,
+          bool in_modal,
+          bool in_frame,
+          SerializedPage* out) {
+  // Frame context propagated to this node's CHILDREN. An <iframe> subtree is a
+  // different document: its descendants must be node-targeted via THAT frame's
+  // identifier (DOM node ids are per-document). Same-origin frames expose
+  // frame_data.document_identifier; cross-origin frames are redacted (no id) ->
+  // empty, which signals the dispatcher to fall back to coordinate input, the
+  // only click path that reaches an out-of-process iframe.
+  std::string child_doc_id = doc_id;
+  bool child_in_frame = in_frame;
+  if (node.has_content_attributes()) {
+    const proto::ContentAttributes& attrs = node.content_attributes();
+    // A dialog/alertdialog subtree is a modal overlay. Elements behind it are
+    // still serialized (they have a viewport bbox) but are visually covered and
+    // not usable until it is dismissed, which the model can't tell from a flat
+    // list. Flag the modal's elements + the page so it dismisses it first (see
+    // kSystemPrompt). aria_role is populated in ACTIONABLE_ELEMENTS mode.
+    if (attrs.aria_role() == proto::AX_ROLE_DIALOG ||
+        attrs.aria_role() == proto::AX_ROLE_ALERTDIALOG) {
+      in_modal = true;
+      out->has_modal = true;
+    }
+    if (attrs.has_iframe_data()) {
+      child_in_frame = true;
+      child_doc_id =
+          (attrs.iframe_data().has_frame_data() &&
+           attrs.iframe_data().frame_data().has_document_identifier())
+              ? attrs.iframe_data()
+                    .frame_data()
+                    .document_identifier()
+                    .serialized_token()
+              : std::string();
+    }
+    if (IsInteractive(attrs)) {
+      InteractiveElement el;
+      el.index = static_cast<int>(out->elements.size()) + 1;
+      el.dom_node_id = attrs.common_ancestor_dom_node_id();
+      el.document_identifier = doc_id;
+      const proto::BoundingRect& vbb = attrs.geometry().visible_bounding_box();
+      el.bbox_device_px =
+          gfx::Rect(vbb.x(), vbb.y(), vbb.width(), vbb.height());
+      el.role = RoleForNode(attrs);
+      el.in_modal = in_modal;
+      el.in_frame = in_frame;
+
+      std::string label;
+      if (attrs.attribute_type() == proto::CONTENT_ATTRIBUTE_FORM_CONTROL &&
+          el.role != "button") {
+        // Real inputs/selects/checkboxes: name + explicit [state]. (Buttons are
+        // also FORM_CONTROL but must keep their TEXT label, not a fill state.)
+        const std::string name = FormControlName(attrs);
+        const std::string state = FormControlState(attrs);
+        label = name.empty() ? state : base::StrCat({name, " ", state});
+        // Replay locator: the field name only (state like [value:…] is volatile
+        // and must not be part of the durable descriptor).
+        el.name = name;
+      } else {
+        label = LabelForNode(attrs);
+        if (label.empty()) {
+          // Buttons/links/clickables carry their text in child text nodes;
+          // pull it up so the model can identify them.
+          label = CleanLabel(CollectDescendantText(node, /*budget=*/200));
+        }
+        el.name = label;
+      }
+      std::string line = base::StrCat({"[", base::NumberToString(el.index),
+                                       "]<", el.role, ">", label});
+      // For links, also surface the destination URL so the model can READ a
+      // result's URL straight from the list instead of clicking/navigating to
+      // it (and so it can report several links' URLs at once). Skip when the
+      // label already IS the URL (LabelForNode's no-text fallback).
+      if (el.role == "a" && attrs.has_anchor_data() &&
+          !attrs.anchor_data().url().empty()) {
+        std::string url = CleanLabel(attrs.anchor_data().url());
+        if (url.size() > 120) {
+          url = url.substr(0, 117) + "...";
+        }
+        if (!url.empty() && url != label) {
+          line += base::StrCat({" -> ", url});
+        }
+      }
+      // For <select>, list the option values so the model picks an exact one.
+      if (attrs.has_form_control_data() &&
+          attrs.form_control_data().select_options_size() > 0) {
+        line += " opts:[";
+        int shown = 0;
+        for (const proto::SelectOption& opt :
+             attrs.form_control_data().select_options()) {
+          if (shown >= 8) {
+            line += ", …";
+            break;
+          }
+          if (shown > 0) {
+            line += ", ";
+          }
+          line += opt.value();
+          if (!opt.text().empty() && opt.text() != opt.value()) {
+            line += base::StrCat({"=", CleanLabel(opt.text())});
+          }
+          ++shown;
+        }
+        line += "]";
+      }
+      // Annotate disabled controls so the model doesn't target them.
+      if (attrs.has_interaction_info() &&
+          attrs.interaction_info().is_disabled()) {
+        line += " (disabled)";
+      }
+      if (in_modal) {
+        line += " (modal)";
+      }
+      out->text += line;
+      out->text += "\n";
+      out->elements.push_back(std::move(el));
+    }
+  }
+  for (const proto::ContentNode& child : node.children_nodes()) {
+    Walk(child, child_doc_id, in_modal, child_in_frame, out);
+  }
+}
+
+}  // namespace
+
+SerializedPage::SerializedPage() = default;
+SerializedPage::SerializedPage(SerializedPage&&) = default;
+SerializedPage& SerializedPage::operator=(SerializedPage&&) = default;
+SerializedPage::~SerializedPage() = default;
+
+const InteractiveElement* SerializedPage::ElementByIndex(int index) const {
+  if (index < 1 || index > static_cast<int>(elements.size())) {
+    return nullptr;
+  }
+  return &elements[index - 1];
+}
+
+// static
+SerializedPage PageSerializer::Serialize(
+    const proto::AnnotatedPageContent& apc,
+    const std::string& default_document_identifier,
+    size_t max_chars) {
+  SerializedPage out;
+  if (apc.has_viewport_geometry()) {
+    const proto::BoundingRect& v = apc.viewport_geometry();
+    out.viewport_dip = gfx::Rect(v.x(), v.y(), v.width(), v.height());
+  }
+  if (apc.has_root_node()) {
+    Walk(apc.root_node(), default_document_identifier, /*in_modal=*/false,
+         /*in_frame=*/false, &out);
+  }
+  if (out.has_modal) {
+    // Prepend (so it survives the max_chars cap): the model must clear the
+    // modal before the elements behind it become usable.
+    out.text = base::StrCat(
+        {"NOTE: a modal dialog is open — handle it FIRST. Its elements are "
+         "marked (modal); click its accept/agree/continue button before "
+         "anything else. Items without (modal) are behind it and not usable "
+         "yet.\n",
+         out.text});
+  }
+  if (out.text.size() > max_chars) {
+    out.text = out.text.substr(0, max_chars) +
+               "\n…(truncated; consider scrolling or refining the task)";
+  }
+  return out;
+}
+
+}  // namespace ai_agent
diff --git a/chrome/browser/ai_agent/page_serializer.h b/chrome/browser/ai_agent/page_serializer.h
new file mode 100644
index 0000000000000..0c7393899da57
--- /dev/null
+++ b/chrome/browser/ai_agent/page_serializer.h
@@ -0,0 +1,72 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+//
+// PageSerializer turns an optimization_guide AnnotatedPageContent proto (from
+// optimization_guide::GetAIPageContent in ACTIONABLE_ELEMENTS mode) into a
+// compact, LLM-readable list of interactive elements with stable 1-based
+// indices, plus a parallel table mapping each index back to the DOM node id,
+// document identifier, and on-screen geometry needed to act on it.
+//
+// This is the native equivalent of browser-use's DOM serializer + selector
+// map, but sourced from the in-process APC tree instead of CDP.
+
+#ifndef CHROME_BROWSER_AI_AGENT_PAGE_SERIALIZER_H_
+#define CHROME_BROWSER_AI_AGENT_PAGE_SERIALIZER_H_
+
+#include <string>
+#include <vector>
+
+#include "ui/gfx/geometry/rect.h"
+
+namespace optimization_guide::proto {
+class AnnotatedPageContent;
+class ContentNode;
+}  // namespace optimization_guide::proto
+
+namespace ai_agent {
+
+// One actionable element the model may reference by `index`.
+struct InteractiveElement {
+  int index = 0;             // 1-based; what the LLM sees and returns.
+  int dom_node_id = 0;       // ContentAttributes.common_ancestor_dom_node_id.
+  std::string document_identifier;  // Owning frame's token; for ActionTarget/
+                             // DomNode. EMPTY for a cross-origin (out-of-process)
+                             // iframe element — APC redacts the child frame's id,
+                             // so it can't be node-targeted; click via coordinates.
+  gfx::Rect bbox_device_px;  // visible_bounding_box (visual-viewport device px).
+  std::string role;          // short tag/role label, e.g. "button", "a".
+  std::string name;          // stable semantic name (field name / label / text),
+                             // WITHOUT volatile state; used as a replay locator.
+  bool in_modal = false;     // inside a dialog/alertdialog subtree (see has_modal).
+  bool in_frame = false;     // inside an <iframe> subtree (same- or cross-origin).
+};
+
+// Result of serializing one observation.
+struct SerializedPage {
+  SerializedPage();
+  SerializedPage(SerializedPage&&);
+  SerializedPage& operator=(SerializedPage&&);
+  ~SerializedPage();
+
+  std::string text;  // "[i]<role> label" lines, one per interactive element.
+  std::vector<InteractiveElement> elements;  // elements[k].index == k+1.
+  gfx::Rect viewport_dip;  // AnnotatedPageContent.viewport_geometry (DIP).
+  bool has_modal = false;  // a role=dialog/alertdialog subtree is present.
+
+  // Returns the element with the given 1-based index, or nullptr.
+  const InteractiveElement* ElementByIndex(int index) const;
+};
+
+class PageSerializer {
+ public:
+  // `default_document_identifier` is applied to nodes whose frame isn't
+  // independently tracked (v1: main frame). `max_chars` caps the emitted text.
+  static SerializedPage Serialize(
+      const optimization_guide::proto::AnnotatedPageContent& apc,
+      const std::string& default_document_identifier,
+      size_t max_chars);
+};
+
+}  // namespace ai_agent
+
+#endif  // CHROME_BROWSER_AI_AGENT_PAGE_SERIALIZER_H_
