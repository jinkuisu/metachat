+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+
+#include "chrome/browser/ai_agent/agent_switches.h"
+
+#include "base/command_line.h"
+
+namespace ai_agent {
+
+// static
+LlmConfig LlmConfig::FromCommandLine() {
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  LlmConfig config;
+  config.base_url = cmd->GetSwitchValueASCII(switches::kAgentLlmUrl);
+  config.api_key = cmd->GetSwitchValueASCII(switches::kAgentLlmKey);
+  config.model = cmd->GetSwitchValueASCII(switches::kAgentModel);
+  config.tool_mode = cmd->GetSwitchValueASCII(switches::kAgentToolMode);
+  if (config.tool_mode.empty()) {
+    config.tool_mode = "auto";
+  }
+  return config;
+}
+
+bool LlmConfig::IsComplete() const {
+  return !base_url.empty() && !api_key.empty() && !model.empty();
+}
+
+}  // namespace ai_agent
