+// A batched click is dispatched through the Actor ClickTool, which resolves the
+// target DomNode to a widget point at time-of-use. If that point is below the
+// fold the renderer can't produce it and the browser process CHECK-crashes deep
+// in the Actor framework (page_tool's is_success_point assertion). Returns a
+// scroll that brings such a target on screen, or nullptr if it's already fully
+// visible (in which case behavior is byte-for-byte unchanged). Single clicks
+// take the humanized coordinate path and never reach this.
+//
+// Detection note (verified at runtime): AnnotatedPageContent clips
+// visible_bounding_box to the viewport, so a PARTIALLY visible element (top on
+// screen, body below the fold -- the only off-screen element the model can see
+// to click) reports a box whose BOTTOM sits exactly on the fold, while its true
+// click point is below it. The visible box's own center is therefore always on
+// screen and useless here; the reliable signal is "box bottom reaches the fold".
+// Units differ: el.bbox_device_px is DEVICE px, page.viewport_dip is DIP. We
+// test the clip in device px and emit the scroll in DIP (ScrollToolRequest
+// distance + coordinate target are DIP).
+// On return, *scrolled_css (when non-null) is set to the CSS-px distance the page
+// will scroll down, i.e. how far the target moves UP in the viewport — callers
+// use it to keep an element-anchored overlay aligned with the post-scroll click.
+std::unique_ptr<actor::ToolRequest> MaybeScrollToReveal(
+    const InteractiveElement& el,
+    const SerializedPage& page,
+    tabs::TabHandle tab_handle,
+    float dsf,
+    float* scrolled_css) {
+  const float vh_dip = page.viewport_dip.height();
+  if (vh_dip <= 0.0f || dsf <= 0.0f) {
+    return nullptr;  // No viewport info; don't risk an unwarranted scroll.
+  }
+  const int vh_dev = static_cast<int>(vh_dip * dsf);
+  // Not clipped at the fold -> the renderer can resolve the click point.
+  if (el.bbox_device_px.bottom() < vh_dev - 2) {
+    return nullptr;
+  }
+  // Pull the element's visible top up toward ~20% of the viewport (enough to
+  // bring a normal-height control fully on screen); never less than half a
+  // screen so tall controls are revealed too. ScrollToolRequest distance and
+  // the coordinate target are in DIP.
+  float dist_dip = el.bbox_device_px.y() / dsf - vh_dip * 0.2f;
+  if (dist_dip < vh_dip * 0.5f) {
+    dist_dip = vh_dip * 0.5f;
+  }
+  if (scrolled_css) {
+    *scrolled_css = dist_dip;
+  }
+  return std::make_unique<actor::ScrollToolRequest>(
+      tab_handle,
+      actor::PageTarget(gfx::Point(page.viewport_dip.width() / 2,
+                                   page.viewport_dip.height() / 2)),
+      actor::ScrollToolRequest::Direction::kDown, dist_dip);
+}
+
+// Builds one Actor ToolRequest from an action dict. Returns nullptr (+ *error)
+// on bad input. Used both for single Actor actions and for batched
+// PerformActions. Click here is the Actor click tool (for atomic batches);
+// a single click instead uses the humanized path (see DispatchAction).
+std::unique_ptr<actor::ToolRequest> BuildActorTool(
+    const base::DictValue& action,
+    const SerializedPage& page,
+    tabs::TabHandle tab_handle,
+    const std::string& doc_id,
+    std::string* error) {
+  const std::string verb = GetString(action, "action");
+  const InteractiveElement* el =
+      page.ElementByIndex(action.FindInt("index").value_or(0));
+  auto node_target = [&]() {
+    // Target the element's OWN frame document, not unconditionally the main
+    // frame: an element inside a same-origin iframe carries its child frame's
+    // identifier. (Fall back to the passed-in main-frame id when APC supplied
+    // no per-element id.) Cross-origin frame elements have an empty id and are
+    // routed to the coordinate click path before reaching here.
+    return actor::PageTarget(actor::DomNode{
+        .node_id = el->dom_node_id,
+        .document_identifier =
+            el->document_identifier.empty() ? doc_id : el->document_identifier});
+  };
+  if (verb == "navigate") {
+    GURL url(GetString(action, "url"));
+    if (!url.is_valid()) {
+      *error = "navigate requires a valid url";
+      return nullptr;
+    }
+    return std::make_unique<actor::NavigateToolRequest>(tab_handle, url);
+  }
+  if (verb == "type") {
+    if (!el) {
+      *error = "type requires a valid element index";
+      return nullptr;
+    }
+    const base::Value* enter = action.Find("enter");
+    return std::make_unique<actor::TypeToolRequest>(
+        tab_handle, node_target(), GetString(action, "text"),
+        enter && enter->is_bool() && enter->GetBool(),
+        actor::TypeToolRequest::Mode::kReplace);
+  }
+  if (verb == "select") {
+    if (!el) {
+      *error = "select requires a valid element index";
+      return nullptr;
+    }
+    return std::make_unique<actor::SelectToolRequest>(
+        tab_handle, node_target(), GetString(action, "value"));
+  }
+  if (verb == "click") {
+    if (!el) {
+      *error = "click requires a valid element index";
+      return nullptr;
+    }
+    return std::make_unique<actor::ClickToolRequest>(
+        tab_handle, node_target(), actor::mojom::ClickType::kLeft,
+        actor::mojom::ClickCount::kSingle);
+  }
+  if (verb == "scroll") {
+    actor::PageTarget target =
+        el ? node_target()
+           : actor::PageTarget(gfx::Point(
+                 page.viewport_dip.width() > 0 ? page.viewport_dip.width() / 2
+                                               : 400,
+                 page.viewport_dip.height() > 0 ? page.viewport_dip.height() / 2
+                                                : 400));
+    return std::make_unique<actor::ScrollToolRequest>(
+        tab_handle, target, ParseDirection(GetString(action, "direction")),
+        /*distance=*/600.0f);
+  }
+  if (verb == "wait") {
+    const int s = action.FindInt("seconds").value_or(1);
+    return std::make_unique<actor::WaitToolRequest>(
+        base::Seconds(s <= 0 ? 1 : s));
+  }
+  *error = base::StrCat({"unknown action: ", verb});
+  return nullptr;
+}
+
+}  // namespace
+
+// static
+void AgentController::Start(content::WebContents* web_contents,
+                            const std::string& goal,
+                            int max_steps,
+                            const std::string& model_override,
+                            const std::string& plan_json,
+                            ResultCallback callback) {
+  LlmConfig config = LlmConfig::FromCommandLine();
+  if (!config.IsComplete()) {
+    std::move(callback).Run(
+        false,
+        "agent LLM is not configured: pass --agent-llm-url/--agent-llm-key/"
+        "--agent-model",
+        "[]");
+    return;
+  }
+  if (!web_contents) {
+    std::move(callback).Run(false, "no target tab", "[]");
+    return;
+  }
+  // Self-owned.
+  auto* controller = new AgentController(web_contents, goal,
+                                         max_steps <= 0 ? 20 : max_steps,
+                                         model_override, plan_json,
+                                         std::move(callback));
+  controller->BeginTask();
+}
+
+AgentController::AgentController(content::WebContents* web_contents,
+                                 const std::string& goal,
+                                 int max_steps,
+                                 const std::string& model_override,
+                                 const std::string& plan_json,
+                                 ResultCallback callback)
+    : web_contents_(web_contents->GetWeakPtr()),
+      goal_(goal),
+      max_steps_(max_steps),
+      model_override_(model_override),
+      callback_(std::move(callback)) {
+  // A non-empty plan switches the loop into replay mode (see ReplayOrThink).
+  if (!plan_json.empty()) {
+    std::optional<base::Value> v =
+        base::JSONReader::Read(plan_json, base::JSON_PARSE_RFC);
+    if (v && v->is_list()) {
+      plan_ = std::move(*v).TakeList();
+      replaying_ = !plan_.empty();
+    }
+  }
+}
+
+AgentController::~AgentController() = default;
+
+void AgentController::BeginTask() {
+  content::BrowserContext* context = browser_context();
+  if (!context) {
+    Finish(false, "tab has no browser context");
+    return;
+  }
+  llm_ = std::make_unique<LlmClient>(
+      context->GetDefaultStoragePartition()
+          ->GetURLLoaderFactoryForBrowserProcess(),
+      LlmConfig::FromCommandLine());
+
+  actor::ActorKeyedService* aks = actor::ActorKeyedService::Get(context);
+  if (!aks) {
+    Finish(false, "Actor service unavailable (kGlicActor disabled?)");
+    return;
+  }
+  task_id_ = aks->CreateTask(
+      actor::TaskSourceInfo(actor::TaskSourceInfo::Client::kExperimentalActor,
+                            std::nullopt),
+      PolicyChecker());
+
+  transcript_path_ = base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+      switches::kAgentLogFile);
+
+  // Static preamble = system prompt only. The goal + a compact action history +
+  // the CURRENT observation are rebuilt into one user message each step (see
+  // Think), so the context stays small instead of accumulating page dumps.
+  base::DictValue system_msg;
+  system_msg.Set("role", "system");
+  system_msg.Set("content", kSystemPrompt);
+  messages_.Append(base::Value(std::move(system_msg)));
+
+  // Add the tab to the task so page-scoped Actor tools can operate, then loop.
+  tabs::TabInterface* tab =
+      tabs::TabInterface::MaybeGetFromContents(web_contents());
+  actor::ActorTask* task = aks->GetTask(task_id_);
+  if (!tab || !task) {
+    Finish(false, "could not bind task to tab");
+    return;
+  }
+  task->AddTab(tab->GetHandle(), /*stop_task_on_detach=*/false,
+               base::BindOnce(&AgentController::OnTabAdded,
+                              weak_factory_.GetWeakPtr()));
+}
+
+void AgentController::OnTabAdded(actor::mojom::ActionResultPtr result) {
+  if (result && !actor::IsOk(result->code)) {
+    Finish(false, base::StrCat({"could not attach tab to task: ",
+                                result->message}));
+    return;
+  }
+  Observe();
+}
+
+void AgentController::Observe() {
+  if (!web_contents()) {
+    Finish(false, "tab closed");
+    return;
+  }
+  LOG(ERROR) << "[ai_agent] observe_start step=" << (step_ + 1);
+  optimization_guide::GetAIPageContent(
+      web_contents(),
+      // on_critical_path=true: wait for fresh, post-action layout. false was
+      // faster but returned STALE content (a just-filled field still read as
+      // its placeholder), which misled the model. The real speed win is the
+      // model + trimmed waits, not this flag.
+      optimization_guide::ActionableAIPageContentOptions(
+          /*on_critical_path=*/true),
+      base::BindOnce(&AgentController::OnObserved, weak_factory_.GetWeakPtr()));
+}
+
+void AgentController::OnObserved(
+    base::expected<optimization_guide::AIPageContentResult, std::string>
+        result) {
+  LOG(ERROR) << "[ai_agent] observe_done step=" << (step_ + 1);
+  if (!result.has_value()) {
+    Finish(false, base::StrCat({"could not read page: ", result.error()}));
+    return;
+  }
+  auto page = std::make_unique<SerializedPage>(PageSerializer::Serialize(
+      result->proto, MainFrameDocumentIdentifier(), kMaxPageChars));
+  ReplayOrThink(std::move(page));
+}
+
+void AgentController::Think(std::unique_ptr<SerializedPage> page) {
+  if (!web_contents()) {
+    Finish(false, "tab closed");
+    return;
+  }
+  const std::string url = web_contents()->GetLastCommittedURL().spec();
+  const bool first = (step_ == 0);
+  std::string change_note;
+  if (!first) {
+    if (url != last_url_) {
+      change_note = base::StrCat({"(navigated to ", url, ")\n"});
+    } else if (page->text != last_page_text_) {
+      change_note = "(the visible elements changed since your last action)\n";
+    } else {
+      // Same serialized page. This does NOT mean nothing happened: input
+      // values aren't shown in the observation, so a prior type/autofill may
+      // have succeeded even though this looks identical. Don't nag the model
+      // to "do something different" — that caused it to redo working actions.
+      change_note =
+          "(same URL and elements as the previous step; note that filled "
+          "input values are not shown here, so a prior type/autofill may have "
+          "worked even if this looks unchanged)\n";
+    }
+  }
+  last_url_ = url;
+  last_page_text_ = page->text;
+
+  // Compact recent-action history (NOT full prior page dumps) keeps the context
+  // small and stable in size from step to step.
+  std::string history;
+  const size_t start = history_.size() > kMaxHistoryLines
+                           ? history_.size() - kMaxHistoryLines
+                           : 0;
+  for (size_t i = start; i < history_.size(); ++i) {
+    history += history_[i] + "\n";
+  }
+
+  std::string content = base::StrCat(
+      {"Goal: ", goal_, "\n\n",
+       history.empty() ? "" : base::StrCat({"Recent actions:\n", history, "\n"}),
+       "Step ", base::NumberToString(step_ + 1), "/",
+       base::NumberToString(max_steps_), " - URL: ", url, "\n",
+       change_note,
+       pending_observation_.empty()
+           ? ""
+           : base::StrCat({"Last result: ", pending_observation_, "\n"}),
+       pending_read_text_.empty()
+           ? ""
+           : base::StrCat({"PAGE TEXT (from your 'read' — use it to answer or "
+                           "summarize):\n", pending_read_text_, "\n\n"}),
+       "Interactive elements (", base::NumberToString(page->elements.size()),
+       "):\n", page->text,
+       "\nReply with JSON {\"thought\":..., \"actions\":[...]} — batch all "
+       "steps you can do now into the actions array."});
+  pending_observation_.clear();
+  pending_read_text_.clear();
+
+  // Request = system preamble + this one user message (no growing transcript).
+  base::ListValue request = messages_.Clone();
+  base::DictValue user_msg;
+  user_msg.Set("role", "user");
+  user_msg.Set("content", content);
+  request.Append(base::Value(std::move(user_msg)));
+
+  WriteTranscript("SENT", content);
+
+  llm_->CreateCompletion(
+      std::move(request), base::ListValue(), model_override_,
+      base::BindOnce(&AgentController::OnThought, weak_factory_.GetWeakPtr(),
+                     std::move(page)));
+}
+
+void AgentController::OnThought(std::unique_ptr<SerializedPage> page,
+                                LlmResponse resp) {
+  if (!resp.ok()) {
+    Finish(false, base::StrCat({"LLM error: ", resp.error}));
+    return;
+  }
+  WriteTranscript("RECV", resp.content);
+
+  std::optional<base::DictValue> action = ParseActionJson(resp.content);
+  if (!action) {
+    pending_action_desc_ = "(invalid JSON)";
+    StepDone("your last reply was not a single JSON object; reply with JSON "
+             "only");
+    return;
+  }
+  // A "read" action pulls the page's main text into the next observation so the
+  // model can summarize/extract body content (the element list is actionable
+  // only). Standalone + async — handle it before the normal dispatch.
+  {
+    auto is_read = [](const base::DictValue& a) {
+      return GetString(a, "action") == "read";
+    };
+    const base::ListValue* rb = action->FindList("actions");
+    const bool wants_read =
+        is_read(*action) ||
+        (rb && !rb->empty() && (*rb)[0].is_dict() && is_read((*rb)[0].GetDict()));
+    if (wants_read) {
+      if (!web_contents()) {
+        Finish(false, "tab closed");
+        return;
+      }
+      pending_action_desc_ = "read page text";
+      DoReadPageText();
+      return;
+    }
+  }
+  // One-shot batch: an "actions" array runs several steps as a single Actor
+  // PerformActions (e.g. fill a whole form + submit) -> far fewer LLM turns.
+  if (const base::ListValue* batch = action->FindList("actions")) {
+    if (!web_contents()) {
+      Finish(false, "tab closed");
+      return;
+    }
+    actor::ActorKeyedService* aks =
+        actor::ActorKeyedService::Get(browser_context());
+    tabs::TabInterface* tab =
+        tabs::TabInterface::MaybeGetFromContents(web_contents());
+    if (!aks || !tab) {
+      StepDone("agent batch: actor/tab unavailable");
+      return;
+    }
+    const tabs::TabHandle tab_handle = tab->GetHandle();
+    const std::string doc_id = MainFrameDocumentIdentifier();
+    std::vector<std::unique_ptr<actor::ToolRequest>> tools;
+    std::vector<std::string> descs;
+    bool done_seen = false;
+    bool done_ok = true;
+    std::string done_final;
+    for (size_t i = 0; i < batch->size(); ++i) {
+      if (!(*batch)[i].is_dict()) {
+        continue;
+      }
+      const base::DictValue& a = (*batch)[i].GetDict();
+      // A "done" step ends the task. We can't trust a done batched WITH actions
+      // (the model hasn't seen their effect yet), so record it but only honor
+      // it if it's the sole thing in the array.
+      if (GetString(a, "action") == "done") {
+        done_seen = true;
+        const base::Value* s = a.Find("success");
+        done_ok = s && s->is_bool() ? s->GetBool() : true;
+        done_final = GetString(a, "final");
+        continue;
+      }
+      const InteractiveElement* el =
+          page->ElementByIndex(a.FindInt("index").value_or(0));
+      // A click on a cross-origin (out-of-process) iframe element can't be
+      // node-targeted -- APC redacts the child frame's document id, and the
+      // Actor node click is renderer-scoped, so it would silently miss (the
+      // cause of the endless "click the same element" loop on e.g. an embedded
+      // CAPTCHA). Dispatch a browser-level humanized click at its viewport point
+      // instead: that path routes through the cross-process input router and so
+      // reaches OOPIFs. Any other actions queued this turn are re-proposed next.
+      if (el && GetString(a, "action") == "click" && el->in_frame &&
+          el->document_identifier.empty()) {
+        MaybeShowOverlay(web_contents(), *page, *el,
+                         gfx::ScaleToRoundedRect(
+                             el->bbox_device_px, 1.0f / device_scale_factor()));
+        pending_action_desc_ = DescribeAction(a);
+        RecordExecutedStep(a, *page, pending_status_);
+        std::string err;
+        if (!HumanizedClickElement(*el, &err)) {
+          StepDone(err.empty() ? "click could not be performed" : err);
+        }
+        return;
+      }
+      if (el) {
+        gfx::Rect css = gfx::ScaleToRoundedRect(
+            el->bbox_device_px, 1.0f / device_scale_factor());
+        // Reveal an off-screen click target before the Actor ClickTool runs,
+        // else the renderer can't resolve it to a point and the browser process
+        // crashes. Only batched clicks reach the Actor click tool (see above).
+        // The reveal scroll moves the target UP by `scrolled` CSS px, so shift
+        // the overlay the same amount: otherwise the box/dot stay where the
+        // element WAS while the Actor click lands where it now IS (a large,
+        // "very bad" dot-vs-click offset for every revealed target).
+        if (GetString(a, "action") == "click") {
+          float scrolled = 0.0f;
+          if (std::unique_ptr<actor::ToolRequest> reveal = MaybeScrollToReveal(
+                  *el, *page, tab_handle, device_scale_factor(), &scrolled)) {
+            css.Offset(0, -static_cast<int>(scrolled));
+            descs.push_back("scroll to reveal target");
+            tools.push_back(std::move(reveal));
+          }
+        }
+        MaybeShowOverlay(web_contents(), *page, *el, css);
+      }
+      std::string err;
+      std::unique_ptr<actor::ToolRequest> tool =
+          BuildActorTool(a, *page, tab_handle, doc_id, &err);
+      if (!tool) {
+        StepDone(base::StrCat({"batch action invalid: ", err}));
+        return;
+      }
+      descs.push_back(DescribeAction(a));
+      RecordExecutedStep(a, *page, pending_status_);
+      tools.push_back(std::move(tool));
+    }
+    if (tools.empty()) {
+      if (done_seen) {
+        base::DictValue d;
+        d.Set("action", "done");
+        d.Set("success", done_ok);
+        d.Set("final", done_final);
+        RecordExecutedStep(d, *page, pending_status_);
+        Finish(done_ok, done_final.empty() ? "task finished" : done_final);
+      } else {
+        StepDone("the actions array was empty");
+      }
+      return;
+    }
+    pending_action_desc_ =
+        base::StrCat({"batch[", base::JoinString(descs, ", "), "]"});
+    aks->PerformActions(
+        task_id_, std::move(tools), actor::ActorTaskMetadata(),
+        base::BindOnce(&AgentController::OnActorActed,
+                       weak_factory_.GetWeakPtr()));
+    return;
+  }
+
+  pending_action_desc_ = DescribeAction(*action);
+
+  const std::string verb = GetString(*action, "action");
+  if (verb == "done") {
+    const base::Value* success = action->Find("success");
+    const bool ok = success && success->is_bool() ? success->GetBool() : true;
+    std::string final = GetString(*action, "final");
+    if (final.empty()) {
+      final = GetString(*action, "thought");
+    }
+    RecordExecutedStep(*action, *page, pending_status_);
+    Finish(ok, final.empty() ? "task finished" : final);
+    return;
+  }
+
+  // Anti-loop guard: weaker/faster models tend to re-issue the exact same
+  // click/select they just did (e.g. clicking "Autofill" 5x). If the previous
+  // step was this identical action, refuse to repeat it and push the model to
+  // move on. (Scroll/type/wait are legitimately repeatable, so skip them.)
+  if ((verb == "click" || verb == "select") && !history_.empty() &&
+      history_.back().find(base::StrCat(
+          {": ", pending_action_desc_, " =>"})) != std::string::npos) {
+    StepDone(base::StrCat(
+        {"you already performed '", pending_action_desc_,
+         "' on the previous step; repeating the same click does not help - "
+         "pick a DIFFERENT element or a different action now"}));
+    return;
+  }
+
+  std::string error;
+  if (!DispatchAction(*action, *page, &error)) {
+    StepDone(error.empty() ? "action could not be performed" : error);
+  } else {
+    RecordExecutedStep(*action, *page, pending_status_);
+  }
+  // Successful dispatch reports back via OnHumanizedClickDone / OnActorActed.
+}
+
+void AgentController::ReplayOrThink(std::unique_ptr<SerializedPage> page) {
+  if (!web_contents()) {
+    Finish(false, "tab closed");
+    return;
+  }
+  // Drive with the LLM when there's no plan, it's exhausted, or the current
+  // entry is malformed -- and tag any steps the LLM produces as "recorded".
+  if (!replaying_ || plan_pos_ >= plan_.size() || !plan_[plan_pos_].is_dict()) {
+    consuming_plan_step_ = false;
+    pending_status_ = "recorded";
+    Think(std::move(page));
+    return;
+  }
+
+  const base::DictValue& step = plan_[plan_pos_].GetDict();
+  const std::string verb = GetString(step, "action");
+  if (verb == "done") {
+    const base::Value* s = step.Find("success");
+    const bool ok = s && s->is_bool() ? s->GetBool() : true;
+    RecordExecutedStep(step, *page, "replayed");
+    const std::string final = GetString(step, "final");
+    Finish(ok, final.empty() ? "task finished (replayed)" : final);
+    return;
+  }
+
+  bool matched = false;
+  base::DictValue act = SynthesizeFromPlan(step, *page, &matched);
+  if (matched) {
+    if (const InteractiveElement* hl =
+            page->ElementByIndex(act.FindInt("index").value_or(0))) {
+      MaybeShowOverlay(
+          web_contents(), *page, *hl,
+          gfx::ScaleToRoundedRect(hl->bbox_device_px,
+                                  1.0f / device_scale_factor()));
+    }
+    pending_action_desc_ = base::StrCat({DescribeAction(act), " (replay)"});
+    std::string err;
+    if (DispatchAction(act, *page, &err)) {
+      RecordExecutedStep(act, *page, "replayed");
+      consuming_plan_step_ = true;
+      return;
+    }
+    LOG(ERROR) << "[ai_agent] replay dispatch failed at plan step " << plan_pos_
+               << " (" << err << "); healing via LLM";
+  } else {
+    LOG(ERROR) << "[ai_agent] replay miss at plan step " << plan_pos_ << " ("
+               << verb << " '" << GetString(step, "name")
+               << "') not found on page; healing via LLM";
+  }
+  // Heal: spend one LLM turn on this plan slot, tag its output "healed", and
+  // continue replaying the remaining steps afterwards.
+  consuming_plan_step_ = true;
+  pending_status_ = "healed";
+  Think(std::move(page));
+}
+
+base::DictValue AgentController::SynthesizeFromPlan(const base::DictValue& step,
+                                                    const SerializedPage& page,
+                                                    bool* matched) {
+  base::DictValue act;
+  const std::string verb = GetString(step, "action");
+  act.Set("action", verb);
+  *matched = true;
+
+  if (verb == "navigate") {
+    const std::string url = GetString(step, "url");
+    act.Set("url", url);
+    *matched = GURL(url).is_valid();
+    return act;
+  }
+  if (verb == "wait") {
+    act.Set("seconds", step.FindInt("seconds").value_or(1));
+    return act;
+  }
+
+  const std::string role = GetString(step, "role");
+  const std::string name = GetString(step, "name");
+  const int ordinal = step.FindInt("ordinal").value_or(0);
+  const InteractiveElement* el =
+      role.empty() ? nullptr : MatchDescriptor(page, role, name, ordinal);
+
+  if (verb == "scroll") {
+    // Scroll can fall back to a viewport scroll, so it always "matches".
+    if (el) {
+      act.Set("index", el->index);
+    }
+    act.Set("direction", GetString(step, "direction"));
+    return act;
+  }
+  if (!el) {
+    *matched = false;
+    return act;
+  }
+  act.Set("index", el->index);
+  if (verb == "type") {
+    act.Set("text", GetString(step, "text"));
+    if (const base::Value* e = step.Find("enter"); e && e->is_bool()) {
+      act.Set("enter", e->GetBool());
+    }
+  } else if (verb == "select") {
+    act.Set("value", GetString(step, "value"));
+  }
+  return act;
+}
+
+void AgentController::RecordExecutedStep(const base::DictValue& action,
+                                         const SerializedPage& page,
+                                         const char* status) {
+  base::DictValue rec;
+  const std::string verb = GetString(action, "action");
+  rec.Set("action", verb);
+  // Durable target descriptor from the element the action referenced.
+  if (std::optional<int> idx = action.FindInt("index")) {
+    if (const InteractiveElement* el = page.ElementByIndex(*idx)) {
+      rec.Set("role", el->role);
+      rec.Set("name", el->name);
+      rec.Set("ordinal", OrdinalOf(page, *idx));
+    }
+  }
+  // Payload by verb.
+  if (verb == "type") {
+    rec.Set("text", GetString(action, "text"));
+    if (const base::Value* e = action.Find("enter"); e && e->is_bool()) {
+      rec.Set("enter", e->GetBool());
+    }
+  } else if (verb == "navigate") {
+    rec.Set("url", GetString(action, "url"));
+  } else if (verb == "select") {
+    rec.Set("value", GetString(action, "value"));
+  } else if (verb == "scroll") {
+    rec.Set("direction", GetString(action, "direction"));
+  } else if (verb == "wait") {
+    rec.Set("seconds", action.FindInt("seconds").value_or(1));
+  } else if (verb == "done") {
+    const base::Value* s = action.Find("success");
+    rec.Set("success", s && s->is_bool() ? s->GetBool() : true);
+    rec.Set("final", GetString(action, "final"));
+  }
+  rec.Set("status", status);
+  executed_steps_.Append(base::Value(std::move(rec)));
+}
+
+bool AgentController::DispatchAction(const base::DictValue& action,
+                                     const SerializedPage& page,
+                                     std::string* error_out) {
+  if (!web_contents()) {
+    *error_out = "tab closed";
+    return false;
+  }
+  // Visually highlight the element being acted on (in-page overlay box) so a
+  // human watching can see exactly what the agent is working on.
+  if (const InteractiveElement* hl =
+          page.ElementByIndex(action.FindInt("index").value_or(0))) {
+    MaybeShowOverlay(
+        web_contents(), page, *hl,
+        gfx::ScaleToRoundedRect(hl->bbox_device_px,
+                                1.0f / device_scale_factor()));
+  }
+  const std::string verb = GetString(action, "action");
+  const int index = action.FindInt("index").value_or(0);
+
+  // ---- Humanized click (the fork's signature input path) ----
+  if (verb == "click") {
+    const InteractiveElement* el = page.ElementByIndex(index);
+    if (!el) {
+      *error_out = base::StrCat({"no element with index ",
+                                 base::NumberToString(index)});
+      return false;
+    }
+    return HumanizedClickElement(*el, error_out);
+  }
+
+  // ---- Actor-framework tools ----
+  actor::ActorKeyedService* aks =
+      actor::ActorKeyedService::Get(browser_context());
+  if (!aks) {
+    *error_out = "Actor service unavailable";
+    return false;
+  }
+  tabs::TabInterface* tab =
+      tabs::TabInterface::MaybeGetFromContents(web_contents());
+  if (!tab) {
+    *error_out = "tab not available";
+    return false;
+  }
+  const tabs::TabHandle tab_handle = tab->GetHandle();
+  const std::string doc_id = MainFrameDocumentIdentifier();
+
+  std::unique_ptr<actor::ToolRequest> tool =
+      BuildActorTool(action, page, tab_handle, doc_id, error_out);
+  if (!tool) {
+    return false;  // *error_out set by BuildActorTool.
+  }
+  std::vector<std::unique_ptr<actor::ToolRequest>> actions;
+  actions.push_back(std::move(tool));
+  aks->PerformActions(
+      task_id_, std::move(actions), actor::ActorTaskMetadata(),
+      base::BindOnce(&AgentController::OnActorActed,
+                     weak_factory_.GetWeakPtr()));
+  return true;
+}
+
+bool AgentController::HumanizedClickElement(const InteractiveElement& el,
+                                            std::string* error_out) {
+  content::RenderWidgetHost* rwh = render_widget_host();
+  if (!rwh) {
+    *error_out = "no render widget host";
+    return false;
+  }
+  const float dsf = device_scale_factor();
+  // APC geometry is visual-viewport device pixels; humanized input wants DIP.
+  const gfx::PointF target(
+      (el.bbox_device_px.x() + el.bbox_device_px.width() / 2.0f) / dsf,
+      (el.bbox_device_px.y() + el.bbox_device_px.height() / 2.0f) / dsf);
+  LOG(ERROR) << "[ai_agent] CLICK <" << el.role
+             << "> bbox_devpx=" << el.bbox_device_px.ToString() << " dsf=" << dsf
+             << " in_frame=" << el.in_frame << " -> dip=" << target.ToString();
+  content::PerformHumanizedClick(
+      web_contents(), last_cursor_dip_, target,
+      base::Seconds(kClickDurationSeconds), /*move_only=*/false,
+      base::BindOnce(&AgentController::OnHumanizedClickDone,
+                     weak_factory_.GetWeakPtr()));
+  last_cursor_dip_ = target;
+  return true;
+}
+
+void AgentController::DoReadPageText() {
+  content::WebContents* wc = web_contents();
+  if (!wc || !wc->GetPrimaryMainFrame()) {
+    StepDone("read failed: no page");
+    return;
+  }
+  // Prefer a main article/content region; fall back to the whole body. Clip to
+  // keep the prompt bounded.
+  const std::u16string js = base::UTF8ToUTF16(std::string(
+      "(function(){var n=document.querySelector('article,main,[role=main]')"
+      "||document.body;var t=n?n.innerText:'';return t.slice(0,8000);})()"));
+  wc->GetPrimaryMainFrame()->ExecuteJavaScriptInIsolatedWorld(
+      js,
+      base::BindOnce(&AgentController::OnReadPageText,
+                     weak_factory_.GetWeakPtr()),
+      kOverlayWorldId);
+}
+
+void AgentController::OnReadPageText(base::Value result) {
+  const std::string text = result.is_string() ? result.GetString() : std::string();
+  pending_read_text_ = text;
+  StepDone(text.empty()
+               ? "read: no readable text found on the page"
+               : base::StrCat({"read page text (",
+                               base::NumberToString(text.size()),
+                               " chars) — shown below as PAGE TEXT"}));
+}
+
+void AgentController::OnHumanizedClickDone() {
+  // The humanized click has just landed (cursor arrived). Flash the red ripple
+  // where it landed -- last_cursor_dip_ is the click target in DIP == CSS px.
+  // (The batch/Actor path instead gets its ripple from the magic cursor's own
+  // click animation, so it is not rippled here.)
+  ShowClickRipple(web_contents(), static_cast<int>(last_cursor_dip_.x()),
+                  static_cast<int>(last_cursor_dip_.y()));
+  StepDone("ok");
+}
+
+void AgentController::OnActorActed(
+    std::vector<actor::ActionResultWithLatencyInfo> results) {
+  StepDone(SummarizeResults(results));
+}
+
+void AgentController::StepDone(const std::string& observation_note) {
+  // Record a compact "what I did -> what happened" line for the next prompt's
+  // history block (this is the memory we keep instead of full page dumps).
+  history_.push_back(base::StrCat({"step ", base::NumberToString(step_ + 1),
+                                   ": ", pending_action_desc_, " => ",
+                                   observation_note}));
+  LOG(ERROR) << "[ai_agent] " << history_.back();
+  pending_observation_ = observation_note;
+  // One in-flight action == one consumed plan slot (whether it was replayed or
+  // healed). Advance so the next observation resolves the following step.
+  if (consuming_plan_step_) {
+    ++plan_pos_;
+    consuming_plan_step_ = false;
+  }
+  if (++step_ >= max_steps_) {
+    Finish(false, base::StrCat({"reached step limit (",
+                                base::NumberToString(max_steps_),
+                                ") before completing the task"}));
+    return;
+  }
+  // Give navigation / client-side JS a moment to settle before re-observing,
+  // so the next observation reflects the action's effect (avoids the agent
+  // re-clicking because the page hadn't updated yet).
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&AgentController::Observe, weak_factory_.GetWeakPtr()),
+      base::Milliseconds(400));
+}
+
+void AgentController::Finish(bool success, const std::string& final_text) {
+  HideInPageOverlay(web_contents());
+  if (!task_id_.is_null() && browser_context()) {
+    if (actor::ActorKeyedService* aks =
+            actor::ActorKeyedService::Get(browser_context())) {
+      aks->StopTask(task_id_, actor::ActorTask::StoppedReason::kTaskComplete);
+    }
+  }
+  if (callback_) {
+    std::string steps_json;
+    base::JSONWriter::Write(executed_steps_, &steps_json);
+    std::move(callback_).Run(success, final_text, steps_json);
+  }
+  delete this;
+}
+
+void AgentController::WriteTranscript(const std::string& label,
+                                      const std::string& text) {
+  LOG(ERROR) << "[ai_agent] " << label << " step=" << (step_ + 1) << ":\n"
+             << text;
+  if (!transcript_path_.empty()) {
+    const std::string block =
+        base::StrCat({"\n==== step ", base::NumberToString(step_ + 1), " ",
+                      label, " ====\n", text, "\n"});
+    base::AppendToFile(base::FilePath::FromUTF8Unsafe(transcript_path_), block);
+  }
+}
+
+content::WebContents* AgentController::web_contents() const {
+  return web_contents_.get();
+}
+
+content::RenderWidgetHost* AgentController::render_widget_host() const {
+  content::WebContents* wc = web_contents();
+  if (!wc || !wc->GetRenderWidgetHostView()) {
+    return nullptr;
+  }
+  return wc->GetRenderWidgetHostView()->GetRenderWidgetHost();
+}
+
+content::BrowserContext* AgentController::browser_context() const {
+  content::WebContents* wc = web_contents();
+  return wc ? wc->GetBrowserContext() : nullptr;
+}
+
+float AgentController::device_scale_factor() const {
+  content::WebContents* wc = web_contents();
+  if (wc && wc->GetRenderWidgetHostView()) {
+    const float dsf = wc->GetRenderWidgetHostView()->GetDeviceScaleFactor();
+    if (dsf > 0) {
+      return dsf;
+    }
+  }
+  return 1.0f;
+}
+
+std::string AgentController::MainFrameDocumentIdentifier() const {
+  content::WebContents* wc = web_contents();
+  if (!wc || !wc->GetPrimaryMainFrame()) {
+    return std::string();
+  }
+  return optimization_guide::DocumentIdentifierUserData::GetDocumentIdentifier(
+             wc->GetPrimaryMainFrame()->GetGlobalFrameToken())
+      .value_or(std::string());
+}
+
+}  // namespace ai_agent
diff --git a/chrome/browser/ai_agent/agent_controller.h b/chrome/browser/ai_agent/agent_controller.h
new file mode 100644
index 0000000000000..1026aff9b509b
--- /dev/null
+++ b/chrome/browser/ai_agent/agent_controller.h
@@ -0,0 +1,180 @@
+// Copyright 2026 The ChromiumFish Authors
+// Use of this source code is governed by an MIT-style license.
+//
+// AgentController is the native, browser-process "brain loop" for the AI agent
+// layer. For a given tab and a natural-language goal it repeatedly:
+//   1. OBSERVE  - optimization_guide::GetAIPageContent (ACTIONABLE_ELEMENTS).
+//   2. SERIALIZE- PageSerializer -> indexed interactive-element text + map.
+//   3. THINK    - LlmClient -> OpenAI-compatible /chat/completions -> JSON act.
+//   4. ACT      - clicks/moves via the fork's humanized mouse path; type/
+//                 scroll/select/navigate/wait via Chrome's Actor framework.
+// ...until the model emits `done` or max steps is hit.
+//
+// It is self-owned (Start() news it; it deletes itself after invoking the
+// completion callback exactly once). All work runs on the UI thread.
+
+#ifndef CHROME_BROWSER_AI_AGENT_AGENT_CONTROLLER_H_
+#define CHROME_BROWSER_AI_AGENT_AGENT_CONTROLLER_H_
+
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/functional/callback.h"
+#include "base/memory/weak_ptr.h"
+#include "base/types/expected.h"
+#include "base/values.h"
+#include "chrome/browser/ai_agent/llm_client.h"
+#include "chrome/common/actor/action_result.h"
+#include "chrome/common/actor/task_id.h"
+#include "ui/gfx/geometry/point_f.h"
+
+namespace content {
+class BrowserContext;
+class RenderWidgetHost;
+class WebContents;
+}  // namespace content
+
+namespace optimization_guide {
+struct AIPageContentResult;
+}  // namespace optimization_guide
+
+namespace ai_agent {
+
+class LlmClient;
+struct SerializedPage;
+struct InteractiveElement;
+
+class AgentController {
+ public:
+  // Reports task completion: `success`, a final human-readable message, and a
+  // JSON array of the resolved/executed steps (the flow plan, each step tagged
+  // recorded|replayed|healed) for the caller's flow cache.
+  using ResultCallback =
+      base::OnceCallback<void(bool success,
+                              const std::string& final_text,
+                              const std::string& steps_json)>;
+
+  // Starts an agent task against `web_contents`. Self-owned; runs `callback`
+  // once when finished. If the LLM config (--agent-llm-*) is incomplete or the
+  // tab is invalid, fails fast via `callback`.
+  //
+  // `plan_json` (optional, "" = none) is a JSON array of previously-recorded
+  // steps. When supplied, the agent REPLAYS: each step's target descriptor is
+  // re-resolved against the live page and dispatched without calling the LLM;
+  // a step whose target no longer matches is HEALED via the LLM and continues.
+  static void Start(content::WebContents* web_contents,
+                    const std::string& goal,
+                    int max_steps,
+                    const std::string& model_override,
+                    const std::string& plan_json,
+                    ResultCallback callback);
+
+  AgentController(const AgentController&) = delete;
+  AgentController& operator=(const AgentController&) = delete;
+
+ private:
+  AgentController(content::WebContents* web_contents,
+                  const std::string& goal,
+                  int max_steps,
+                  const std::string& model_override,
+                  const std::string& plan_json,
+                  ResultCallback callback);
+  ~AgentController();
+
+  // Loop phases.
+  void BeginTask();
+  void OnTabAdded(actor::mojom::ActionResultPtr result);
+  void Observe();
+  void OnObserved(
+      base::expected<optimization_guide::AIPageContentResult, std::string>
+          result);
+  void Think(std::unique_ptr<SerializedPage> page);
+  void OnThought(std::unique_ptr<SerializedPage> page, LlmResponse resp);
+
+  // Replay path: if a cached plan is active, resolve the next plan step against
+  // `page` (no LLM) and dispatch it; otherwise (no plan / exhausted / a step
+  // that no longer matches) fall through to Think() so the LLM drives/heals.
+  void ReplayOrThink(std::unique_ptr<SerializedPage> page);
+  // Synthesizes an action dict {action, index, text/value/url/...} from a plan
+  // step by re-resolving its {role,name,ordinal} descriptor against `page`.
+  // Sets *matched=false if the descriptor's target can't be located.
+  base::DictValue SynthesizeFromPlan(const base::DictValue& step,
+                                     const SerializedPage& page,
+                                     bool* matched);
+  // Appends a durable record of `action` (verb + {role,name,ordinal} target
+  // descriptor + payload + `status`) to executed_steps_ for the flow cache.
+  void RecordExecutedStep(const base::DictValue& action,
+                          const SerializedPage& page,
+                          const char* status);
+
+  // Action dispatch. Returns false if the action could not be started (the
+  // caller then advances with an error note).
+  bool DispatchAction(const base::DictValue& action,
+                      const SerializedPage& page,
+                      std::string* error_out);
+  // Browser-level humanized click at `el`'s viewport center. Routed through the
+  // cross-process input router, so unlike the Actor node-id click it reaches
+  // out-of-process (cross-origin) iframes. Used by DispatchAction and as the
+  // fallback for cross-origin-frame elements in the batch path.
+  bool HumanizedClickElement(const InteractiveElement& el,
+                             std::string* error_out);
+  void OnHumanizedClickDone();
+  // "read" action: pull the page's main readable text into the next observation
+  // so the model can summarize/extract body content (the element list is
+  // actionable-only). Async: runs JS, then OnReadPageText advances the loop.
+  void DoReadPageText();
+  void OnReadPageText(base::Value result);
+  void OnActorActed(std::vector<actor::ActionResultWithLatencyInfo> results);
+
+  // Advances to the next step (or finishes when steps are exhausted) after
+  // recording `observation_note` as the prior action's outcome for the model.
+  void StepDone(const std::string& observation_note);
+  void Finish(bool success, const std::string& final_text);
+
+  // Appends a SENT/RECV block to the transcript (--agent-log-file) + LOG.
+  void WriteTranscript(const std::string& label, const std::string& text);
+
+  // Live accessors derived from the (weak) WebContents; null when the tab is
+  // gone.
+  content::WebContents* web_contents() const;
+  content::RenderWidgetHost* render_widget_host() const;
+  content::BrowserContext* browser_context() const;
+  float device_scale_factor() const;
+  std::string MainFrameDocumentIdentifier() const;
+
+  base::WeakPtr<content::WebContents> web_contents_;
+  const std::string goal_;
+  const int max_steps_;
+  const std::string model_override_;
+  ResultCallback callback_;
+
+  std::unique_ptr<LlmClient> llm_;
+  actor::TaskId task_id_;
+  int step_ = 0;
+  gfx::PointF last_cursor_dip_;
+  base::ListValue messages_;          // Static preamble: [system] only.
+  std::vector<std::string> history_;  // Compact "step N: action => result" log.
+  std::string pending_action_desc_;   // Description of the action in flight.
+  std::string pending_observation_;   // outcome note for the next user turn.
+  std::string pending_read_text_;     // one-shot page text from a "read" action,
+                                      // injected into the NEXT prompt then cleared
+                                      // (kept out of history_ to avoid bloat).
+  std::string last_url_;              // for change detection across steps.
+  std::string last_page_text_;        // for change detection across steps.
+  std::string transcript_path_;       // --agent-log-file (empty = disabled).
+
+  // Flow cache: replay state + the resolved steps emitted back to the caller.
+  base::ListValue plan_;              // cached steps to replay ([] = none).
+  size_t plan_pos_ = 0;               // index of the next plan step to consume.
+  bool replaying_ = false;            // a non-empty plan was supplied.
+  bool consuming_plan_step_ = false;  // the in-flight action consumes plan_[pos].
+  const char* pending_status_ = "recorded";  // tag for the in-flight LLM step.
+  base::ListValue executed_steps_;    // resolved steps (recorded|replayed|healed).
+
+  base::WeakPtrFactory<AgentController> weak_factory_{this};
+};
+
+}  // namespace ai_agent
+
+#endif  // CHROME_BROWSER_AI_AGENT_AGENT_CONTROLLER_H_
