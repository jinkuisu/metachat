# =============================================================================
# MetaChat Branding: Replace Chromium product name with MetaChat
# =============================================================================
# Based on Fish's branding/branding.patch (ChromiumFish -> MetaChat)
#
# Modifies:
#   1. chrome/app/app-Info.plist
#      - CFBundleDisplayName: \ -> #      - CFBundleExecutable: \ -> #      - macOS only (plist file, affects macOS app bundle name)
#
#   2. chrome/app/chromium_strings.grd
#      - IDS_PRODUCT_NAME: Chromium -> MetaChat
#      - IDS_SHORT_PRODUCT_NAME: Chromium -> MetaChat
#
#   3. chrome/app/theme/chromium/BRANDING
#      - PRODUCT_FULLNAME: Chromium -> MetaChat
#      - PRODUCT_SHORTNAME: Chromium -> MetaChat
#      - PRODUCT_INSTALLER_FULLNAME -> MetaChat Installer
#      - PRODUCT_INSTALLER_SHORTNAME -> MetaChat Installer
#
# Fish vs MetaChat:
#   Fish: Chromium -> ChromiumFish
#   We:   Chromium -> MetaChat
# =============================================================================
diff --git a/chrome/app/app-Info.plist b/chrome/app/app-Info.plist
index 6fada0a2b1a1f..98ed078d1439b 100644
--- a/chrome/app/app-Info.plist
+++ b/chrome/app/app-Info.plist
@@ -5,7 +5,7 @@
 	<key>CFBundleDevelopmentRegion</key>
 	<string>en</string>
 	<key>CFBundleDisplayName</key>
-	<string>${EXECUTABLE_NAME}</string>
+	<string>${CHROMIUM_SHORT_NAME}</string>
 	<key>CFBundleDocumentTypes</key>
 	<array>
 		<dict>
@@ -146,7 +146,7 @@
 		</dict>
 	</array>
 	<key>CFBundleExecutable</key>
-	<string>${EXECUTABLE_NAME}</string>
+	<string>${CHROMIUM_SHORT_NAME}</string>
 	<key>CFBundleIconFile</key>
 	<string>app.icns</string>
 	<key>CFBundleIconName</key>
diff --git a/chrome/app/chromium_strings.grd b/chrome/app/chromium_strings.grd
index cb212bf396c79..94c1718e9ab11 100644
--- a/chrome/app/chromium_strings.grd
+++ b/chrome/app/chromium_strings.grd
@@ -294,10 +294,10 @@ If you update this file, be sure also to update google_chrome_strings.grd. -->
         </then>
         <else>
           <message name="IDS_PRODUCT_NAME" desc="The Chrome application name" translateable="false">
-            Chromium
+            MetaChat
           </message>
           <message name="IDS_SHORT_PRODUCT_NAME" desc="The Chrome application short name." translateable="false">
-            Chromium
+            MetaChat
           </message>
         </else>
       </if>
diff --git a/chrome/app/theme/chromium/BRANDING b/chrome/app/theme/chromium/BRANDING
index f8363d5b294fe..5b78e3a959f3f 100644
--- a/chrome/app/theme/chromium/BRANDING
+++ b/chrome/app/theme/chromium/BRANDING
@@ -1,9 +1,9 @@
 COMPANY_FULLNAME=The Chromium Authors
 COMPANY_SHORTNAME=The Chromium Authors
-PRODUCT_FULLNAME=Chromium
-PRODUCT_SHORTNAME=Chromium
-PRODUCT_INSTALLER_FULLNAME=Chromium Installer
-PRODUCT_INSTALLER_SHORTNAME=Chromium Installer
+PRODUCT_FULLNAME=MetaChat
+PRODUCT_SHORTNAME=MetaChat
+PRODUCT_INSTALLER_FULLNAME=MetaChat Installer
+PRODUCT_INSTALLER_SHORTNAME=MetaChat Installer
 COPYRIGHT=Copyright @LASTCHANGE_YEAR@ The Chromium Authors. All rights reserved.
 MAC_BUNDLE_ID=org.chromium.Chromium
 MAC_CREATOR_CODE=Cr24
 