diff --git a/third_party/blink/renderer/bindings/core/v8/local_window_proxy.cc b/third_party/blink/renderer/bindings/core/v8/local_window_proxy.cc
index a3f5649de4219..38437864c7d0a 100644
--- a/third_party/blink/renderer/bindings/core/v8/local_window_proxy.cc
+++ b/third_party/blink/renderer/bindings/core/v8/local_window_proxy.cc
@@ -217,6 +217,52 @@ void LocalWindowProxy::Initialize() {
 
   InstallConditionalFeatures();
 
+  // Persona prototype trim: REMOVE only the properties that are genuinely
+  // in our build (Chromium 150 source) but NOT in real Chrome 148. The
+  // previous revision of this patch trimmed 47 Navigator.prototype
+  // properties (bluetooth, clipboard, credentials, gpu, hid, serial,
+  // serviceWorker, deviceMemory, etc.) based on the false claim that
+  // real Chrome 148 on Windows lacked them. Direct A/B comparison
+  // against real Chrome 148.0.7778.179 on the same host (driven via
+  // CDP, both pages on https://example.com/ secure context) proved the
+  // opposite: real Chrome 148 exposes all of those. Trimming them made
+  // our fork advertise a stripped Navigator that didn't match ANY real
+  // Chrome version — instant anti-detect tell for bot-detection services.
+  //
+  // Verified actual diff (Chromium 150 source − Chrome 148 stable):
+  //   * Element.prototype:        'pseudo'
+  //   * HTMLElement.prototype:    'pseudo', 'focusGroup', 'focusGroupStart'
+  //   * Navigator.prototype:      'modelContext'
+  //   * window-level constructors that landed after Chrome 148:
+  //                               'ModelContext', 'WebMCPEvent', 'CSSPseudoElement'
+  // Other diffs (BarcodeDetector, XSLTProcessor missing in fork on real
+  // Chrome 148; browsingTopics/when missing in fork on Document) go the
+  // other way and are caused by upstream feature defaults / disabled
+  // features — NOT something we can fix here.
+  if (World().IsMainWorld()) {
+    static constexpr const char kTrimScript[] =
+        "(function(){"
+        "try{delete Element.prototype['pseudo'];}catch(e){}"
+        "var h=['pseudo','focusGroup','focusGroupStart'];"
+        "for(var i=0;i<h.length;i++){"
+        "try{delete HTMLElement.prototype[h[i]];}catch(e){}}"
+        "try{delete Navigator.prototype['modelContext'];}catch(e){}"
+        "var w=['ModelContext','WebMCPEvent','CSSPseudoElement'];"
+        "for(var j=0;j<w.length;j++){try{delete window[w[j]];}catch(e){}}"
+        "})();";
+    v8::Local<v8::String> source =
+        v8::String::NewFromUtf8(GetIsolate(), kTrimScript,
+                                v8::NewStringType::kInternalized,
+                                sizeof(kTrimScript) - 1)
+            .ToLocalChecked();
+    v8::TryCatch try_catch(GetIsolate());
+    try_catch.SetVerbose(false);
+    v8::Local<v8::Script> script;
+    if (v8::Script::Compile(context, source).ToLocal(&script)) {
+      std::ignore = script->Run(context);
+    }
+  }
+
   if (World().IsMainWorld()) {
     probe::DidCreateMainWorldContext(GetFrame());
     GetFrame()->Loader().DispatchDidClearWindowObjectInMainWorld();
