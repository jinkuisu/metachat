+// Lightweight-fork: derive realistic smooth/powerEfficient for a
+// MediaDecodingConfiguration without querying the host's actual
+// VideoDecodePerfHistory (that would leak host-specific perf signals
+// per playback record). The heuristic matches what a typical Win10/11
+// desktop with hardware-accelerated h264/vp9/aac would report:
+//
+//   * audio-only or HD-or-below video → smooth + powerEfficient
+//   * 4K h264/vp9/aac → smooth + powerEfficient (hw decoded on most modern GPUs)
+//   * >1080p HEVC/AV1 → smooth but NOT powerEfficient (software-decoded on Intel UHD)
+//   * Above 4K (8K+) → neither smooth nor powerEfficient
+//   * >60fps at >1080p → not smooth
+//   * Bitrate >50 Mbps at 1080p+ → not powerEfficient
+//
+// Returns a fixed pair regardless of host hardware so fpjs and similar
+// see the same per-persona values on every host.
+struct PerfHeuristic {
+  bool smooth;
+  bool power_efficient;
+};
+PerfHeuristic DerivePerformanceHeuristic(const MediaDecodingConfiguration* config) {
+  // Audio-only configs: always smooth + powerEfficient.
+  if (!config->hasVideo()) {
+    return {true, true};
+  }
+  const auto* video = config->video();
+  if (!video) {
+    return {true, true};
+  }
+  const uint32_t w = video->hasWidth() ? video->width() : 0u;
+  const uint32_t h = video->hasHeight() ? video->height() : 0u;
+  const double fps = video->hasFramerate() ? video->framerate() : 30.0;
+  const uint64_t bitrate = video->hasBitrate() ? video->bitrate() : 0u;
+  const String content_type =
+      video->hasContentType() ? video->contentType() : String();
+
+  const uint64_t pixels = static_cast<uint64_t>(w) * h;
+  // 1920×1080 = 2,073,600 ; 3840×2160 = 8,294,400 ; 7680×4320 = 33,177,600
+  const bool is_above_hd = pixels > 2'100'000ull;       // > ~1080p
+  const bool is_above_4k = pixels > 8'400'000ull;       // > ~4K
+  const bool is_high_fps_above_hd = is_above_hd && fps > 60.0;
+  const bool is_high_bitrate =
+      bitrate > 50'000'000ull && is_above_hd;  // > 50 Mbps above 1080p
+
+  // Codec category — coarse lowercase match.
+  const String lc = content_type.ToAsciiLower();
+  const std::string lc_utf8 = lc.Utf8();
+  const bool is_hw_codec_friendly =
+      (lc_utf8.find("avc1") != std::string::npos) || (lc_utf8.find("h264") != std::string::npos) ||
+      (lc_utf8.find("vp9") != std::string::npos) || (lc_utf8.find("vp09") != std::string::npos) ||
+      (lc_utf8.find("vp8") != std::string::npos) || (lc_utf8.find("mp4a") != std::string::npos) ||
+      (lc_utf8.find("opus") != std::string::npos) || (lc_utf8.find("aac") != std::string::npos);
+  const bool is_hw_codec_strained =
+      (lc_utf8.find("av01") != std::string::npos) || (lc_utf8.find("av1") != std::string::npos) ||
+      (lc_utf8.find("hev1") != std::string::npos) || (lc_utf8.find("hvc1") != std::string::npos) || (lc_utf8.find("hevc") != std::string::npos) ||
+      (lc_utf8.find("dvh") != std::string::npos) /* Dolby Vision */;
+
+  // 8K+ or high-bitrate-above-HD: choke point for every consumer GPU.
+  if (is_above_4k || is_high_bitrate) {
+    return {false, false};
+  }
+  // 4K HEVC / AV1: hardware-decoded on newer chips, software on older
+  // Intel UHD — be conservative and call it smooth but not powerEfficient.
+  if (is_above_hd && is_hw_codec_strained) {
+    return {true, false};
+  }
+  // High framerate above HD: typically not smooth on integrated GPUs.
+  if (is_high_fps_above_hd) {
+    return {false, true};
+  }
+  // 4K hw-friendly codecs (h264/vp9): smooth + powerEfficient on modern desktop GPUs.
+  if (is_above_hd && is_hw_codec_friendly) {
+    return {true, true};
+  }
+  // HD-or-below: always smooth + powerEfficient.
+  if (!is_above_hd) {
+    return {true, true};
+  }
+  // Anything else above HD: smooth but pessimistic on power efficiency.
+  return {true, false};
+}
+
+ScriptPromise<MediaCapabilitiesDecodingInfo>
+CreateRealisticDecodingInfo(ScriptState* script_state,
+                             const MediaDecodingConfiguration* config) {
+  PerfHeuristic perf = DerivePerformanceHeuristic(config);
+  MediaCapabilitiesDecodingInfo* info = MediaCapabilitiesDecodingInfo::Create();
+  info->setSupported(true);
+  info->setSmooth(perf.smooth);
+  info->setPowerEfficient(perf.power_efficient);
+  return ToResolvedPromise<MediaCapabilitiesDecodingInfo>(script_state, info);
+}
