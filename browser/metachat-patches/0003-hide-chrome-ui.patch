+// MetaChat: configurable command blocklist for --metachat-mode.
+// Returns true if |id| should be blocked.
+// Gating logic:
+//   1. Allowlist check: if id is explicitly allowed, return false.
+//   2. Blocklist check: if id is in default OR custom blocklist, return true.
+//   3. Otherwise: return false (command runs normally).
+static bool IsMetachatModeBlockedCommand(int id) {
+  const auto* cmdline = base::CommandLine::ForCurrentProcess();
+  if (!cmdline->HasSwitch(switches::kMetachatMode)) {
+    return false;
+  }
+
+  // Build allowlist set from --metachat-mode-allowlist.
+  static std::set<int> s_allowlist = []() {
+    std::set<int> ids;
+    std::string list = base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+        switches::kMetachatModeAllowList);
+    if (list.empty()) return ids;
+    for (const auto& name : base::SplitString(
+             list, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+      int cmd_id = 0;
+      if (base::StringToInt(name, &cmd_id)) {
+        ids.insert(cmd_id);
+      }
+    }
+    return ids;
+  }();
+  if (s_allowlist.find(id) != s_allowlist.end()) {
+    return false;
+  }
+
+  // Default blocklist: commands irrelevant to the messaging-browser experience.
+  switch (id) {
+    case IDC_OPEN_FILE:
+    case IDC_SAVE_PAGE:
+    case IDC_PRINT:
+#if BUILDFLAG(ENABLE_PRINTING)
+    case IDC_BASIC_PRINT:
+#endif
+    case IDC_BOOKMARK_THIS_TAB:
+    case IDC_BOOKMARK_ALL_TABS:
+    case IDC_BOOKMARKS_MENU:
+    case IDC_SHOW_BOOKMARK_BAR:
+    case IDC_SHOW_BOOKMARK_MANAGER:
+    case IDC_SHOW_BOOKMARK_SIDE_PANEL:
+    case IDC_SHOW_HISTORY:
+    case IDC_SHOW_HISTORY_SIDE_PANEL:
+    case IDC_SHOW_HISTORY_CLUSTERS_SIDE_PANEL:
+    case IDC_SHOW_DOWNLOADS:
+    case IDC_RECENT_TABS_MENU:
+    case IDC_RECENT_TABS_LOGIN_FOR_DEVICE_TABS:
+    case IDC_RECENT_TABS_SEE_DEVICE_TABS:
+    case IDC_READING_LIST_MENU:
+    case IDC_READING_LIST_MENU_ADD_TAB:
+    case IDC_READING_LIST_MENU_SHOW_UI:
+    case IDC_OPTIONS:
+    case IDC_PERFORMANCE:
+    case IDC_IMPORT_SETTINGS:
+    case IDC_CLEAR_BROWSING_DATA:
+    case IDC_ABOUT:
+    case IDC_HELP_MENU:
+    case IDC_HELP_PAGE_VIA_KEYBOARD:
+    case IDC_HELP_PAGE_VIA_MENU:
+    case IDC_FEEDBACK:
+    case IDC_SHOW_AVATAR_MENU:
+    case IDC_PROFILE_MENU_IN_APP_MENU:
+    case IDC_CLOSE_PROFILE:
+    case IDC_OPEN_GUEST_PROFILE:
+    case IDC_ADD_NEW_PROFILE:
+    case IDC_MANAGE_CHROME_PROFILES:
+    case IDC_SHOW_SIGNIN:
+    case IDC_MANAGE_GOOGLE_ACCOUNT:
+    case IDC_SHOW_PASSWORD_MANAGER:
+    case IDC_SAFETY_HUB_SHOW_PASSWORD_CHECKUP:
+    case IDC_SHOW_PAYMENT_METHODS:
+    case IDC_SHOW_ADDRESSES:
+    case IDC_SHOW_COMMENTS_SIDE_PANEL:
+    case IDC_SHOW_READING_MODE_SIDE_PANEL:
+    case IDC_SHOW_CUSTOMIZE_CHROME_SIDE_PANEL:
+    case IDC_SHOW_CUSTOMIZE_CHROME_TOOLBAR:
+    case IDC_CUSTOMIZE_CHROME:
+    case IDC_SHOW_CHROME_LABS:
+    case IDC_SHOW_TRANSLATE:
+    case IDC_CONTENT_CONTEXT_TRANSLATE:
+    case IDC_ROUTE_MEDIA:
+    case IDC_LIVE_CAPTION:
+    case IDC_INSTALL_PWA:
+    case IDC_CREATE_SHORTCUT:
+    case IDC_OPEN_IN_PWA_WINDOW:
+    case IDC_WEB_APP_SETTINGS:
+    case IDC_UPGRADE_DIALOG:
+    case IDC_CHROME_WHATS_NEW:
+    case IDC_CHROME_TIPS:
+      return true;
+    default:
+      break;
+  }
+
+  // Check custom blocklist from --metachat-mode-blocklist.
+  static std::set<int> s_blocklist = []() {
+    std::set<int> ids;
+    std::string list = base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+        switches::kMetachatModeBlockList);
+    if (list.empty()) return ids;
+    for (const auto& name : base::SplitString(
+             list, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+      int cmd_id = 0;
+      if (base::StringToInt(name, &cmd_id)) {
+        ids.insert(cmd_id);
+      }
+    }
+    return ids;
+  }();
+  return s_blocklist.find(id) != s_blocklist.end();
+}
