+// MetaChat: centralized command gate for --metachat-mode. Blocks native
+// Chrome UI commands irrelevant to the messaging-browser experience.
+// Preserved: Reload (F5), DevTools (F12), Extensions management, Find,
+// New Tab, Zoom, Cut/Copy/Paste — all work as keyboard shortcuts.
+// Checked in SupportsCommand, IsCommandEnabled, ExecuteCommand, and
+// ExecuteCommandWithDisposition.
+bool IsMetachatModeBlockedCommand(int id) {
+  if (!base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kMetachatMode)) {
+    return false;
+  }
+  switch (id) {
+    // File/host integration — no file dialog or print in --metachat-mode.
+    case IDC_OPEN_FILE:
+    case IDC_SAVE_PAGE:
+    case IDC_PRINT:
+#if BUILDFLAG(ENABLE_PRINTING)
+    case IDC_BASIC_PRINT:
+#endif
+    // Bookmarks, history, downloads, reading list.
+    case IDC_BOOKMARK_THIS_TAB:
