// MetaChat: add --metachat-mode command-line switch that enables
// MetaChat Browser mode. When present, the browser hides native Chrome
// UI and presents the MetaChat WebUI shell for multi-account management.
// Applied after ChromiumFish patches.

diff --git a/chrome/common/chrome_switches.h b/chrome/common/chrome_switches.h
index 0000000000000..1111111111111
--- a/chrome/common/chrome_switches.h
+++ b/chrome/common/chrome_switches.h
@@ -30,6 +30,15 @@
 // //chrome/browser/  code.
 // TODO(crbug.com/40258183): Remove these after the ChromeRootWindowController
 // migration.
+// MetaChat: --metachat-mode activates the MetaChat Browser environment.
+// When set, the browser hides native Chrome UI and loads the MetaChat WebUI.
+extern const char kMetachatMode[];
+// MetaChat: comma-separated list of IDC command IDs to additionally block
+// when --metachat-mode is active. Overrides the default blocklist.
+extern const char kMetachatModeBlockList[];
+// MetaChat: comma-separated list of IDC command IDs to allow even when
+// they are on the default blocklist. Takes precedence over blocklist.
+extern const char kMetachatModeAllowList[];
 // TODO(crbug.com/402502018): remove this.
 extern const char kAcceptLangSetClear[];
 extern const char kAcceptLangSetClearMostVisitedURL[];

diff --git a/chrome/browser/ui/browser_command_controller.cc b/chrome/browser/ui/browser_command_controller.cc
--- a/chrome/browser/ui/browser_command_controller.cc
+++ b/chrome/browser/ui/browser_command_controller.cc
@@ -38,6 +38,10 @@
 #include "base/functional/bind.h"
 #include "base/location.h"
 #include "base/metrics/user_metrics.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_split.h"
+#include "chrome/common/chrome_switches.h"
 #include "base/time/time.h"
 #include "build/branding_buildflags.h"
 #include "build/build_config.h"
